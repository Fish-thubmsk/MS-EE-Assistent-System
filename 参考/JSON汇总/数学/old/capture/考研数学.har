count = parseInt(thecount) + 1; \r\n                setStorage(\"thecount\", thecount, 720);\r\n                return true;\r\n            } \r\n\r\n        } else {\r\n            //\u53d8\u91cf\u4e0d\u5b58\u5728\r\n\r\n            if (parseInt(thecount) >= 15) {\r\n                return false;\r\n            }\r\n            else {\r\n                thecount = parseInt(thecount) + 1;\r\n                setStorage(\"thecount\", thecount, 720);\r\n                return true;\r\n            } \r\n\r\n        }\r\n\r\n\r\n\r\n    }\r\n\r\n\r\n}"}, "headers":[{"name":"content-type", "value":"application/javascript"}, {"name":"last-modified", "value":"Thu, 16 Oct 2025 09:29:29 GMT"}, {"name":"accept-ranges", "value":"bytes"}, {"name":"etag", "value":"\"bd49b5f7f3edc1:0\""}, {"name":"server", "value":"Microsoft-IIS/10.0"}, {"name":"x-powered-by", "value":"ASP.NET"}, {"name":"access-control-allow-origin", "value":"*"}, {"name":"strict-transport-security", "value":"max-age=32503000"}, {"name":"date", "value":"Tue, 31 Mar 2026 17:21:25 GMT"}, {"name":"content-length", "value":"2479"}], "statusText":"200", "status":200, "bodySize":2479, "headersSize":335}, "time":70, "cache":{}}, {"request":{"postData":{"text":"", "mimeType":""}, "url":"https://kmath.cn/WebResource.axd?d=pynGkmcFUV13He1Qd6_TZJsyL16rBWm7JIpm1-YHDQdqqwgpcHBOcmiIFzFQJIcJZmx3m7Afat0dAxcsS2iOTA2&t=638369492483918269", "cookies":[{"name":"ASP.NET_SessionId", "value":"oeyjgewbvhfmh505lhzshfu4"}, {"name":"Hm_lvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977501"}, {"name":"HMACCOUNT", "value":"F95E3757DD521F24"}, {"name":"Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977628"}], "httpVersion":"HTTP/2", "headers":[{"name":"pragma", "value":"no-cache"}, {"name":"cache-control", "value":"no-cache"}, {"name":"sec-ch-ua-platform", "value":"\"Windows\""}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"}, {"nam