on (data, othis) {  \r\n                       Cookies.set(\"areavalue\", data.id, { expires: 30, path:\"/\", domain: domain });\r\n                       window.location = \"default.aspx\";   \r\n                   }\r\n               }); \r\n       });\r\n   </script>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n     \r\n    <!--  \u767e\u5ea6\u7edf\u8ba1\u4ee3\u7801 --> \r\n\r\n    <script>\r\n        var _hmt = _hmt || [];\r\n        (function () {\r\n            var hm = document.createElement(\"script\");\r\n            hm.src = \"https://hm.baidu.com/hm.js?ee774b6bd20afa25f617ec112c13eed4\";\r\n            var s = document.getElementsByTagName(\"script\")[0];\r\n            s.parentNode.insertBefore(hm, s);\r\n        })();\r\n    </script> \r\n\r\n     <!--  /\u7edf\u8ba1\u4ee3\u7801 -->\r\n   \r\n\r\n\r\n     \r\n     \r\n\r\n\r\n</body>\r\n</html>\r\n"}, "headers":[{"name":"cache-control", "value":"public, max-age=60"}, {"name":"content-type", "value":"text/html; charset=utf-8"}, {"name":"expires", "value":"Tue, 31 Mar 2026 17:23:42 GMT"}, {"name":"last-modified", "value":"Tue, 31 Mar 2026 17:22:42 GMT"}, {"name":"vary", "value":"*"}, {"name":"server", "value":"Microsoft-IIS/10.0"}, {"name":"x-aspnet-version", "value":"4.0.30319"}, {"name":"x-powered-by", "value":"ASP.NET"}, {"name":"access-control-allow-origin", "value":"*"}, {"name":"strict-transport-security", "value":"max-age=32503000"}, {"name":"date", "value":"Tue, 31 Mar 2026 17:22:42 GMT"}, {"name":"content-length", "value":"77801"}], "statusText":"200", "status":200, "bodySize":77801, "headersSize":403}, "time":35, "cache":{}}], "creator":{"name":"Fiddler", "version":"6.0.0.0", "comment":"https://fiddler2.com"}, "comment":"exported @ 2026/4/1 1:24:02"}}
