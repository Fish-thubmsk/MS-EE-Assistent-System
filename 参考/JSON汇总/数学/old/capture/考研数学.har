lick=\"sethot('cz',819);\" target=\"_blank\" href=\"Paper_List.aspx#819\"><img src=\"/ad/\u521d\u4e2d.png\" class=\"ad\" /></a>\r\n             <a onclick=\"sethot('gz',816);\" target=\"_blank\"  href=\"Paper_List.aspx#816\">  <img src=\"/ad/\u9ad8\u8003.png\"  class=\"ad\"/></a> \r\n             <a onclick=\"sethot('dx',287);\" target=\"_blank\"  href=\"Paper_List.aspx#287\">  <img src=\"/ad/\u8003\u7814.png\"  class=\"ad\"/></a>\r\n\r\n          </div>\r\n\r\n\r\n\r\n\r\n        \r\n        \r\n      <div class=\"block\">\r\n                  <h3>\u8bd5\u5377\u4e8c\u7ef4\u7801</h3>\r\n            <div class=\"intro\">\r\n\r\n                              \r\n             <div id=\"qrcodeimg\" ></div>\r\n                     \r\n\r\n               <script>\r\n\r\n                   var qrcode = new QRCode(\"qrcodeimg\", {\r\n                       text: \"https://kmath.cn/math/Papername.aspx?id=1221\",\r\n        width: 128,\r\n        height: 128,\r\n        colorDark: \"#000000\",\r\n        colorLight: \"#ffffff\",\r\n        correctLevel: QRCode.CorrectLevel.H\r\n    });\r\n\r\n               </script>\r\n               <div style=\"margin:10px 0px;\">\r\n                   \u5206\u4eab\u6b64\u4e8c\u7ef4\u7801\u5230\u7fa4\uff0c\u8ba9\u66f4\u591a\u670b\u53cb\u53c2\u4e0e\r\n               </div>\r\n                \r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n        \r\n         <div class=\"block\">\r\n                  <h3>\u8bd5\u5377\u767d\u677f</h3>\r\n            <div class=\"intro\">\r\n\r\n                              \r\n              \u8bd5\u5377\u767d\u677f\u63d0\u4f9b\u4e86\u4e00\u4e2a\u7b80\u5355\u7684\u89e6\u6478\u4e66\u5199\u677f\uff0c\u53ef\u4f9b\u8001\u5e08\u4e0a\u8bfe\u3001\u6216\u8005\u89c6\u9891\u76f4\u64ad\u65f6\uff0c\r\n                \u76f4\u63a5\u5229\u7528\u767d\u677f\u7ed9\u5b66\u751f\u8bb2\u89e3\u8bd5\u9898\uff0c\u5982\u6709\u610f\u89c1\uff0c\u6b22\u8fce\u53cd\u9988\u3002\r\n               \r\n                \r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n\r\n\r\n\r\n        \r\n      <div class=\"block\">\r\n                  <h3>\u76f8\u5173\u8bd5\u5377</h3>\r\n            <div class=\"intro\">\r\n\r\n                   \r\n           <a href=\"Papername.aspx?paperid=924&papername=2024\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2024\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=921&papername=2023\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2023\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=918&papername=2022\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2022\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=913&papername=2021\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2021\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=909&papername=2020\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2020\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n\r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n     \r\n\r\n    </div>\r\n     \r\n  \r\n        \r\n    \r\n    </div>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n     \r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n     \r\n\r\n \r\n\r\n\r\n   <script>\r\n\r\n\r\n\r\n       function Add(id, obj) {\r\n            \r\n           $(obj).html(\"\u79fb\u9664\u9898\u76ee\");\r\n           $(obj).removeClass(\"layui-border-green\").addClass(\"layui-border-red\");\r\n\r\n           paper.add1(id);\r\n           renderCount(); \r\n           $(obj).off('click')\r\n           $(obj).attr(\"onclick\", \"\").on(\"click\", function () { Remove(id, obj) })\r\n            \r\n       }\r\n\r\n\r\n\r\n\r\n       function Remove(id, obj) {\r\n\r\n\r\n           $(obj).html(\"\u52a0\u5165\u8bd5\u5377\");\r\n           $(obj).removeClass(\"layui-border-red\").addClass(\"layui-border-green\");\r\n\r\n           paper.remove1(id);\r\n           renderCount();\r\n\r\n           $(obj).off('click')\r\n           $(obj).attr(\"onclick\", \"\").on(\"click\", function () { Add(id, obj) });\r\n\r\n\r\n       }\r\n\r\n\r\n\r\n\r\n   </script>\r\n\r\n\r\n    <script>\r\n        $(\".cat span\").each(function (idx) {\r\n            var old = $(this).html().trim();\r\n            if (idx == 0) {\r\n                $(this).html( \"\u4e00\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 1) {\r\n                $(this).html(\"\u4e8c\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 2) {\r\n                $(this).html(\"\u4e09\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 3) {\r\n                $(this).html(\"\u56db\u3001\" + old);\r\n            }\r\n            if (idx == 4) {\r\n                $(this).html(\"\u4e94\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 5) {\r\n                $(this).html(\"\u516d\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 6) {\r\n                $(this).html(\"\u4e03\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 7) {\r\n                $(this).html(\"\u516b\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 8) {\r\n                $(this).html(\"\u4e5d\u3001\" + old);\r\n            }\r\n           \r\n\r\n        });\r\n\r\n\r\n        $(\".ques .idx\").each(function (_idx) {\r\n            var old = $(this).html().trim();\r\n            $(this).html((_idx + 1) + \"\" + old+\".\");\r\n\r\n        });\r\n\r\n    </script>\r\n\r\n\r\n                 \r\n     \r\n\r\n     \r\n      \r\n        <script>\r\n\r\n            $(\".view_ques\").click(function () {\r\n\r\n                var tid = $(this).data(\"tid\");\r\n                var answer = $(this).find(\"div.answer\");\r\n\r\n                if (answer.is(':visible')) {\r\n\r\n                    answer.hide();\r\n                }\r\n                else {\r\n                    if (answer.html().trim() == \"\") {\r\n\r\n                        addhis(tid);\r\n                        if (!canview()) {\r\n                            layer.msg(\"\u6bcf\u65e5\u67e5\u770b\u6b21\u6570\u5df2\u7ecf\u7528\u5b8c\uff0c\u5347\u7ea7\u4e3aVIP\u65e0\u9650\u5236\u67e5\u770b\");\r\n                            return;\r\n                        } \r\n\r\n                        $.getJSON(\"/math/jssvr/answer.aspx?id=\" + tid, function (r1) {\r\n                            var ans1 = r1.answer;\r\n                            var analyse = r1.analyse;\r\n\r\n                            if (analyse.trim() != \"\") {\r\n                                answer.html(\"<b>\u7b54\u6848</b>\uff1a\" + ans1 + \" <br> <b>\u89e3\u6790</b>\uff1a\" + analyse);\r\n                            }\r\n                            else {\r\n                                answer.html(\"<b>\u7b54\u6848</b>\uff1a\" + ans1);\r\n                            }\r\n\r\n                            MathJax.typesetPromise();\r\n                        });\r\n\r\n                    }\r\n                    answer.show();\r\n                }\r\n\r\n\r\n\r\n\r\n            });\r\n\r\n\r\n\r\n            $(\".zan\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myzan(tid, this);\r\n            });\r\n\r\n\r\n\r\n            $(\".fav\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myfav(tid, this);\r\n            });\r\n\r\n            $(\".err\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myerr(tid, this);\r\n            });\r\n\r\n\r\n            if (isvip != \"1\") {\r\n                $(\".vip\").hide()\r\n            }\r\n\r\n        </script>\r\n\r\n \r\n\r\n\r\n    \r\n \r\n         </form>    \r\n \r\n\r\n\r\n           \r\n\r\n    \r\n\r\n      \r\n      \r\n\r\n\r\n       \r\n\r\n    <div  class=\"footer-wrapper\" >\r\n        \r\n        <div>\r\n        <a href=\"/Default.aspx\"> &copy; \u79d1\u6570\u7f51 \u4e13\u4e1a\u7684\u6570\u5b66\u7ec4\u5377\u7cfb\u7edf</a>\r\n        </div>\r\n     \r\n\r\n         <div class=\"footer-nav\"> \r\n           <a href=default.aspx>\u79d1\u6570\u7f51</