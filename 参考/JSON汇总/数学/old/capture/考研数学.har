1F24; Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4=1774977628"}, {"name":"host", "value":"kmath.cn"}], "headersSize":820, "queryString":[{"name":"v", "value":"20250928"}], "bodySize":0, "method":"GET"}, "timings":{"ssl":0, "send":0, "dns":0, "wait":70, "receive":0, "connect":0, "blocked":-1}, "connection":"ClientPort:42229;EgressPort:20226", "startedDateTime":"2026-04-01T01:21:25.4686852+08:00", "_publicFiddlerId":27, "response":{"cookies":[], "redirectURL":"", "httpVersion":"HTTP/2", "content":{"compression":0, "mimeType":"application/javascript", "size":1741, "text":"\r\npaper = { \r\n\r\n    get1: function () {\r\n      //  console.log(\"get\");\r\n        var data = localStorage.getItem(\"cart\");\r\n        if (data != null) {\r\n            return JSON.parse(data);\r\n        }\r\n        else {\r\n            return [];\r\n        }\r\n    },\r\n\r\n\r\n    add1 : function(ID) {\r\n        \r\n        var obj = { id: ID };\r\n        var arr = paper.get1();\r\n         \r\n\r\n        var _result = [];\r\n        for (var i = 0; i < arr.length; i++) {\r\n            var elem = arr[i];\r\n            if (elem.id != ID) {\r\n                _result.push(elem);\r\n            }\r\n        }\r\n\r\n        arr = _result;\r\n        arr.push(obj);\r\n        result = JSON.stringify(arr);\r\n        localStorage.setItem(\"cart\", result);\r\n        return arr.length; \r\n},\r\n\r\n\r\n    removeAll: function () { \r\n        localStorage.removeItem(\"cart\");\r\n    },\r\n    \r\n    remove1: function (ID) {\r\n       // console.log(\"remove1\");\r\n   \r\n        var arr = paper.get1();\r\n\r\n\r\n        var _result = [];\r\n        for (var i = 0; i < arr.length; i++) {\r\n            var elem = arr[i];\r\n            if (elem.id != ID) {\r\n                _result.push(elem);\r\n            }\r\n        }\r\n\r\n        arr = _result; \r\n        result = JSON.stringify(arr);\r\n        localStorage.setItem(\"cart\", result);\r\n\r\n   \r\n        return arr.length;\r\n    }\r\n\r\n     \r\n};\r\n\r\n\r\n \r\n\r\nfunction renderCount() {\r\n   \r\n    var arr = paper.get1();\r\n        var c = arr.length;\r\n    if (c > 0) {\r\n        $(\"#pcount\").parent().show();\r\n            $(\"#pcount\").html(\"<span>\" + arr.length + '</span>');\r\n        }\r\n    else {\r\n        $(\"#pcount\").parent().hide();\r\n        $(\"#pcount\").html(arr.length);\r\n        }    \r\n}\r\n\r\n\r\n\r\n\r\n\r\n$(document).ready(function () {\r\n            renderCount();\r\n })\r\n"}, "headers":[{"name":"content-type", "value":"application/javascript"}, {"name":"last-modified", "value":"Fri, 19 Jul 2024 00:02:37 GMT"}, {"name":"accept-ranges", "value":"bytes"}, {"name":"etag", "value":"\"5bb346f76ed9da1:0\""}, {"name":"server", "value":"Microsoft-IIS/10.0"}, {"name":"x-powered-by", "value":"ASP.NET"}, {"name":"access-control-allow-origin", "value":"*"}, {"name":"strict-transport-security", "value":"max-age=32503000"}, {"name":"date", "value":"Tue, 31 Mar 2026 17:21:25 GMT"}, {"name":"content-length", "value":"1741"}], "statusText":"200", "status":200, "bodySize":1741, "headersSize":336}, "time":70, "cache":{}}, {"request":{"postData":{"text":"", "mimeType":""}, "url":"https://kmath.cn/javascript/layTree.js?v=20250928", "cookies":[{"name":"ASP.NET_SessionId", "value":"oeyjgewbvhfmh505lhzshfu4"}, {"name":"Hm_lvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977501"}, {"name":"HMACCOUNT", "value":"F95E3757DD521F24"}, {"name":"Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977628"}], "httpVersion":"HTTP/2", "headers":[{"name":"pragma", "value":"no-cache"}, {"name":"cache-control", "value":"no-cache"}, {"name":"sec-ch-ua-platform", "value":"\"Windows\""}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"}, {"name":"sec-ch-ua", "value":"\"Chromium\";v=\"146\", \"Not-A.Brand\";v=\"24\", \"Google Chrome\";v=\"146\""}, {"name":"sec-ch-ua-mobile",