\"\u4fe1\u606f\u8bf4\u660e\";\r\n        }\r\n    }\r\n\r\n    else {\r\n\r\n        if (!_width) {\r\n            _width = 800;\r\n        }\r\n\r\n        if (!_height) {\r\n            _height = 550;\r\n        }\r\n\r\n        if (!_title) {\r\n            _title = \"\u4fe1\u606f\u8bf4\u660e\";\r\n        }\r\n\r\n    }\r\n\r\n\r\n\r\n    layer.open({\r\n        type: 2,\r\n        title: _title,\r\n        shadeClose: true,\r\n        shade: 0.8,\r\n        area: [_width + 'px', _height + 'px'],\r\n        content: _src\r\n    });\r\n\r\n}\r\n\r\n\r\n\r\n\r\n\r\nfunction disablescroll() {\r\n    $(\"body\").addClass(\"hdbody\");\r\n\r\n}\r\n\r\nfunction enablescroll() {\r\n    $(\"body\").removeClass(\"hdbody\");\r\n}\r\n\r\n\r\n\r\n\r\nfunction popDrawer(id) {\r\n    disablescroll();\r\n     \r\n    if (ismobile) {\r\n\r\n\r\n          index = layer.open({\r\n            type: 2,\r\n            content: \"/math/detail.aspx?id=\" + id,\r\n            area: ['320px', '195px'],\r\n            maxmin: true\r\n        });\r\n\r\n        setTimeout(() => layer.full(index),1000);\r\n\r\n \r\n        //\r\n        //layer.open({\r\n        //    type: 2,\r\n        //    offset: 'r',\r\n        //    title: '\u53c2\u8003\u7b54\u6848',\r\n        //    anim: 5,\r\n        //    area: ['300px', '100%'],\r\n        //    content: \"/math/detail.aspx?id=\" + id,\r\n        //    cancel: function (index) {\r\n        //        enablescroll();\r\n        //    }\r\n        //})\r\n        //\r\n\r\n\r\n    }\r\n    else { \r\n    layer.open({\r\n        type: 2,\r\n        offset: 'r',\r\n        title: '\u53c2\u8003\u7b54\u6848',\r\n        anim: 5,\r\n        area: ['700px', '100%'],\r\n        content: \"/math/detail.aspx?id=\" + id,\r\n        cancel: function (index) {\r\n            enablescroll();\r\n        } \r\n       })\r\n    }\r\n\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n \r\n\r\n\r\n\r\n\r\nfunction popSlide(title,url) {\r\n    disablescroll();\r\n\r\n    if (ismobile) {\r\n        layer.open({\r\n            type: 2,\r\n            offset: 'r',\r\n            title: title,\r\n            anim: 5,\r\n            area: ['300px', '100%'],\r\n            content: url,\r\n            cancel: function (index) {\r\n                enablescroll();\r\n            }\r\n        })\r\n    }\r\n    else {\r\n        layer.open({\r\n            type: 2,\r\n            offset: 'r',\r\n            title: title,\r\n            anim: 5,\r\n            area: ['700px', '100%'],\r\n            content: url,\r\n            cancel: function (index) {\r\n                enablescroll();\r\n            }\r\n        })\r\n    }\r\n\r\n}"}, "headers":[{"name":"content-type", "value":"application/javascript"}, {"name":"last-modified", "value":"Thu, 29 Aug 2024 01:19:24 GMT"}, {"name":"accept-ranges", "value":"bytes"}, {"name":"etag", "value":"\"f22fd47bb1f9da1:0\""}, {"name":"server", "value":"Microsoft-IIS/10.0"}, {"name":"x-powered-by", "value":"ASP.NET"}, {"name":"access-control-allow-origin", "value":"*"}, {"name":"strict-transport-security", "value":"max-age=32503000"}, {"name":"date", "value":"Tue, 31 Mar 2026 17:21:25 GMT"}, {"name":"content-length", "value":"2974"}], "statusText":"200", "status":200, "bodySize":2974, "headersSize":336}, "time":69, "cache":{}}, {"request":{"postData":{"text":"", "mimeType":""}, "url":"https://kmath.cn/javascript/myop.js?v=20250928", "cookies":[{"name":"ASP.NET_SessionId", "value":"oeyjgewbvhfmh505lhzshfu4"}, {"name":"Hm_lvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977501"}, {"name":"HMACCOUNT", "value":"F95E3757DD521F24"}, {"name":"Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977628"}], "httpVersion":"HTTP/2", "headers":[{"name":"pragma", "value":"no-cache"}, {"name":"cache-control", "value":"no-cache"}, {"name":"sec-ch-ua-platform", "value":"\"Windows\""}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0