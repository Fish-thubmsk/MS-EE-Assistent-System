'[+]': ['boldsymbol', 'unicode'] }\r\n\r\n\r\n    }\r\n\r\n};\r\n\r\n\r\n "}, "headers":[{"name":"content-type", "value":"application/javascript"}, {"name":"last-modified", "value":"Mon, 01 Jan 2024 00:57:33 GMT"}, {"name":"accept-ranges", "value":"bytes"}, {"name":"etag", "value":"\"ae4b2c814d3cda1:0\""}, {"name":"server", "value":"Microsoft-IIS/10.0"}, {"name":"x-powered-by", "value":"ASP.NET"}, {"name":"access-control-allow-origin", "value":"*"}, {"name":"strict-transport-security", "value":"max-age=32503000"}, {"name":"date", "value":"Tue, 31 Mar 2026 17:21:25 GMT"}, {"name":"content-length", "value":"654"}], "statusText":"200", "status":200, "bodySize":654, "headersSize":335}, "time":27, "cache":{}}, {"request":{"postData":{"text":"", "mimeType":""}, "url":"https://kmath.cn/style/list-item.css?v=20250928", "cookies":[{"name":"ASP.NET_SessionId", "value":"oeyjgewbvhfmh505lhzshfu4"}, {"name":"Hm_lvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977501"}, {"name":"HMACCOUNT", "value":"F95E3757DD521F24"}, {"name":"Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977628"}], "httpVersion":"HTTP/2", "headers":[{"name":"pragma", "value":"no-cache"}, {"name":"cache-control", "value":"no-cache"}, {"name":"sec-ch-ua-platform", "value":"\"Windows\""}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"}, {"name":"sec-ch-ua", "value":"\"Chromium\";v=\"146\", \"Not-A.Brand\";v=\"24\", \"Google Chrome\";v=\"146\""}, {"name":"sec-ch-ua-mobile", "value":"?0"}, {"name":"accept", "value":"text/css,*/*;q=0.1"}, {"name":"sec-fetch-site", "value":"same-origin"}, {"name":"sec-fetch-mode", "value":"no-cors"}, {"name":"sec-fetch-dest", "value":"style"}, {"name":"referer", "value":"https://kmath.cn/math/collection.aspx?id=643"}, {"name":"accept-encoding", "value":"gzip, deflate, br, zstd"}, {"name":"accept-language", "value":"en-US,en;q=0.9,zh-CN;q=0.8,zh;q=0.7"}, {"name":"priority", "va