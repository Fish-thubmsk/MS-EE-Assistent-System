> \r\n                            <span class=\"idx\"></span> \u8bbe $f(u)$ \u5728 $(0,+\\infty)$ \u5185\u5177\u6709\u4e8c\u9636\u5bfc\u6570\uff0c\u4e14 $z=f\\left(\\sqrt{x^2+y^2}\\right)$\u6ee1\u8db3\u7b49\u5f0f $\\frac{\\partial^2 z}{\\partial x^2}+\\frac{\\partial^2 z}{\\partial y^2}=0$.<br>(1) \u9a8c\u8bc1 $f^{\\prime \\prime}(u)+\\frac{f^{\\prime}(u)}{u}=0$<br>\uff082\uff09\u82e5 $f(1)=0, f^{\\prime}(1)=1$ \uff0c\u6c42\u51fd\u6570 $f(u)$ \u7684\u8868\u8fbe\u5f0f.\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=15787\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=15787\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=15787'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=15787')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=15787')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=15787')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"15787\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"15787\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=15787\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"15787\" onclick=\"Add(15787, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=15788  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u8bbe\u5728\u4e0a\u534a\u5e73\u9762 $D=\\{(x, y) \\mid y&gt;0\\}$ \u5185\uff0c\u6570 $f(x, y)$ \u662f\u6709\u8fde\u7eed\u504f\u5bfc\u6570\uff0c\u4e14\u5bf9\u4efb\u610f\u7684 $t&gt;0$ \u90fd\u6709 $f(t x, t y)=t^{-2} f(x, y)$.<br>\u8bc1\u660e\uff1a\u5bf9 $D$ \u5185\u7684\u4efb\u610f\u5206\u6bb5\u5149\u6ed1\u7684\u6709\u5411\u7b80\u5355\u95ed\u66f2\u7ebf $L$ \uff0c\u90fd\u6709<br>$$<br>\\oint_L y f(x, y) \\mathrm{d} x-x f(x, y) \\mathrm{d} y=0<br>$$\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=15788\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=15788\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=15788'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=15788')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=15788')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=15788')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"15788\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"15788\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=15788\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"15788\" onclick=\"Add(15788, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=15789  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u5df2\u77e5 \u975e\u9f50\u6b21\u7ebf\u6027\u65b9\u7a0b\u7ec4$$<br>\\left\\{\\begin{array}{l}<br>x_1+x_2+x_3+x_4=-1 \\\\<br>4 x_1+3 x_2+5 x_3-x_4=-1 \\\\<br>a x_1+x_2+3 x_3+b x_4=1<br>\\end{array}\\right. \\text { \uff0c }<br>$$<br>\u6709 3 \u4e2a\u7ebf\u6027\u65e0\u5173\u7684\u89e3.<br>(1) \u8bc1\u660e\u65b9\u7a0b\u7ec4\u7cfb\u6570\u77e9\u9635 $A$ \u7684\u79e9 $r(A)=2$ \uff1b<br>(2) \u6c42 $a, b$ \u7684\u503c\u53ca\u65b9\u7a0b\u7ec4\u7684\u901a\u89e3.\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=15789\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=15789\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=15789'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=15789')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=15789')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=15789')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"15789\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"15789\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=15789\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"15789\" onclick=\"Add(15789, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=15790  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u8bbe\u4e09\u9636\u5b9e\u5bf9\u79f0\u77e9\u9635 $A$ \u7684\u5404\u884c\u5143\u7d20\u4e4b\u548c\u5747\u4e3a 3 , \u5411\u91cf $\\alpha_1=(-1,2,-1)^T, \\alpha_2=(0,-1,1)^T$ \u662f\u7ebf\u6027 \u65b9\u7a0b \u7ec4 $A x=0$ \u7684\u4e24\u4e2a\u89e3.<br>(1) \u6c42 $A$ \u7684\u7279\u5f81\u503c\u4e0e\u7279\u5f81\u5411\u91cf<br>(2) \u6c42\u6b63\u4ea4\u77e9\u9635 $Q$ \u548c\u5bf9\u89d2\u77e9\u9635 $\\Lambda$ \uff0c\u4f7f\u5f97 $Q^T A Q=\\Lambda$.\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=15790\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=15790\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=15790'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=15790')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=15790')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=15790')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"15790\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"15790\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=15790\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"15790\" onclick=\"Add(15790, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=15791  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u968f\u673a\u53d8\u91cf $\\boldsymbol{X}$ \u7684\u6982\u7387\u5bc6\u5ea6\u4e3a<br>$$<br>f_X(x)=\\left\\{\\begin{array}{l}<br>1 / 2,-1 < x < 0 \\\\<br>1 / 4,0 \\leq x < 2 \\\\<br>0 \\quad, \\text { \u5176\u4ed6 }<br>\\end{array}\\right.<br>$$<br><br>\u4ee4 $Y=X^2 \uff0c F(x, y)$ \u4e3a\u4e8c\u7ef4\u968f\u673a\u53d8\u91cf $(X, Y)$ \u7684\u5206\u5e03\u51fd\u6570.<br>(1) \u6c42 $Y$ \u7684\u6982\u7387\u5bc6\u5ea6 $f_Y(y)$;<br>(2) $F\\left(-\\frac{1}{2}, 4\\right)$.\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=15791\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=15791\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=15791'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=15791')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=15791')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=15791')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"15791\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"15791\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=15791\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"15791\" onclick=\"Add(15791, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=15792  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u8bbe\u603b\u4f53 $X$ \u7684\u6982\u7387\u5bc6\u5ea6\u4e3a<br>$$<br>f(x ; \\theta)=\\left\\{\\begin{array}{lc}<br>\\theta, & 0 < x < 1 \\\\<br>1-\\theta, 1 \\leq x < 2 \\\\<br>0, & \\text { \u5176\u4ed6 }<br>\\end{array}\\right.<br>$$<br><br>\u5176\u4e2d $\\theta$ \u662f\u672a\u77e5\u53c2\u6570 $(0 < \\theta < 1) \uff0c X_1, X_2, \\cdots, X_n$ \u4e3a\u6765\u81ea\u603b\u4f53 $X$ \u7684\u7b80\u5355\u968f\u673a\u6837\u672c\uff0c\u8bb0 $N$ \u4e3a\u6837\u672c\u503c $x_1, x_2 \\ldots, x_n$ \u4e2d\u5c0f\u4e8e 1 \u7684\u4e2a\u6570\uff0c\u6c42 $\\theta$ \u7684\u6700\u5927\u4f3c\u7136\u4f30\u8ba1.\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=15792\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=15792\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=15792'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=15792')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=15792')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=15792')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"15792\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"15792\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=15792\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"15792\" onclick=\"Add(15792, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n\r\n          \r\n</div>\r\n\r\n\r\n\r\n                \r\n\r\n         \r\n             \r\n              \r\n\r\n        \r\n\r\n\r\n\r\n                \r\n\r\n         \r\n       \r\n\r\n\r\n       \r\n\r\n       <! --  /end  -->\r\n\r\n      \r\n     \r\n\r\n\r\n  </div>\r\n\r\n    \r\n        </div>\r\n         \r\n           \r\n        \r\n    </div>\r\n\r\n  </div>\r\n\r\n    <div class=\"kmath2_right\">\r\n        \r\n        <div class=\"vip_block\">\r\n            \u975e\u4f1a\u5458\u6bcf\u5929\u53ef\u4ee5\u67e5\u770b15\u9053\u8bd5\u9898\u3002\r\n\u5f00\u901a\u4f1a\u5458\uff0c\u6d77\u91cf\u8bd5\u9898\u65e0\u9650\u5236\u67e5\u770b\u3002\r\n\r\n            <ul>\r\n                <li>\r\n                    <span class=\"layui-icon-find-fill layui-icon\"> </span> <br />\r\n                    \u65e0\u9650\u770b\u8bd5\u9898\r\n                </li>\r\n\r\n                 <li>\r\n     <span class=\"layui-icon-circle-dot layui-icon\"> </span> <br />\r\n     \u4e0b\u8f7d\u8bd5\u9898\r\n </li>\r\n\r\n                 <li>\r\n     <span class=\"layui-icon-star-fill layui-icon\"> </span> <br />\r\n     \u7ec4\u5377\r\n </li>\r\n\r\n            </ul>\r\n           \r\n            <a href=\"Vip.aspx\" style=\"margin-top:20px;\">\u5f00\u901a\u4f1a\u5458</a>\r\n        </div>\r\n\r\n\r\n\r\n\r\n                 \r\n          <div class=\"block\">\r\n                <h3>\u70ed\u70b9\u63a8\u8350</h3>\r\n            <a onclick=\"sethot('cz',819);\" target=\"_blank\" href=\"Paper_List.aspx#819\"><img src=\"/ad/\u521d\u4e2d.png\" class=\"ad\" /></a>\r\n             <a onclick=\"sethot('gz',816);\" target=\"_blank\"  href=\"Paper_List.aspx#816\">  <img src=\"/ad/\u9ad8\u8003.png\"  class=\"ad\"/></a> \r\n             <a onclick=\"sethot('dx',287);\" target=\"_blank\"  href=\"Paper_List.aspx#287\">  <img src=\"/ad/\u8003\u7814.png\"  class=\"ad\"/></a>\r\n\r\n          </div>\r\n\r\n\r\n\r\n\r\n        \r\n        \r\n      <div class=\"block\">\r\n                  <h3>\u8bd5\u5377\u4e8c\u7ef4\u7801</h3>\r\n            <div class=\"intro\">\r\n\r\n                              \r\n             <div id=\"qrcodeimg\" ></div>\r\n                     \r\n\r\n               <script>\r\n\r\n                   var qrcode = new QRCode(\"qrcodeimg\", {\r\n                       text: \"https://kmath.cn/math/Papername.aspx?id=815\",\r\n        width: 128,\r\n        height: 128,\r\n        colorDark: \"#000000\",\r\n        colorLight: \"#ffffff\",\r\n        correctLevel: QRCode.CorrectLevel.H\r\n    });\r\n\r\n               </script>\r\n               <div style=\"margin:10px 0px;\">\r\n                   \u5206\u4eab\u6b64\u4e8c\u7ef4\u7801\u5230\u7fa4\uff0c\u8ba9\u66f4\u591a\u670b\u53cb\u53c2\u4e0e\r\n               </div>\r\n                \r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n        \r\n         <div class=\"block\">\r\n                  <h3>\u8bd5\u5377\u767d\u677f</h3>\r\n            <div class=\"intro\">\r\n\r\n                              \r\n              \u8bd5\u5377\u767d\u677f\u63d0\u4f9b\u4e86\u4e00\u4e2a\u7b80\u5355\u7684\u89e6\u6478\u4e66\u5199\u677f\uff0c\u53ef\u4f9b\u8001\u5e08\u4e0a\u8bfe\u3001\u6216\u8005\u89c6\u9891\u76f4\u64ad\u65f6\uff0c\r\n                \u76f4\u63a5\u5229\u7528\u767d\u677f\u7ed9\u5b66\u751f\u8bb2\u89e3\u8bd5\u9898\uff0c\u5982\u6709\u610f\u89c1\uff0c\u6b22\u8fce\u53cd\u9988\u3002\r\n               \r\n                \r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n\r\n\r\n\r\n        \r\n      <div class=\"block\">\r\n                  <h3>\u76f8\u5173\u8bd5\u5377</h3>\r\n            <div class=\"intro\">\r\n\r\n                   \r\n           <a href=\"Papername.aspx?paperid=812&papername=2005\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2005\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=809&papername=2004\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2004\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=806&papername=2003\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2003\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=803&papername=2002\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2002\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=800&papername=2001\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2001\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n\r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n     \r\n\r\n    </div>\r\n     \r\n  \r\n        \r\n    \r\n    </div>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n     \r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n     \r\n\r\n \r\n\r\n\r\n   <script>\r\n\r\n\r\n\r\n       function Add(id, obj) {\r\n            \r\n           $(obj).html(\"\u79fb\u9664\u9898\u76ee\");\r\n           $(obj).removeClass(\"layui-border-green\").addClass(\"layui-border-red\");\r\n\r\n           paper.add1(id);\r\n           renderCount(); \r\n           $(obj).off('click')\r\n           $(obj).attr(\"onclick\", \"\").on(\"click\", function () { Remove(id, obj) })\r\n            \r\n       }\r\n\r\n\r\n\r\n\r\n       function Remove(id, obj) {\r\n\r\n\r\n           $(obj).html(\"\u52a0\u5165\u8bd5\u5377\");\r\n           $(obj).removeClass(\"layui-border-red\").addClass(\"layui-border-green\");\r\n\r\n           paper.remove1(id);\r\n           renderCount();\r\n\r\n           $(obj).off('click')\r\n           $(obj).attr(\"onclick\", \"\").on(\"click\", function () { Add(id, obj) });\r\n\r\n\r\n       }\r\n\r\n\r\n\r\n\r\n   </script>\r\n\r\n\r\n    <script>\r\n        $(\".cat span\").each(function (idx) {\r\n            var old = $(this).html().trim();\r\n            if (idx == 0) {\r\n                $(this).html( \"\u4e00\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 1) {\r\n                $(this).html(\"\u4e8c\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 2) {\r\n                $(this).html(\"\u4e09\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 3) {\r\n                $(this).html(\"\u56db\u3001\" + old);\r\n            }\r\n            if (idx == 4) {\r\n                $(this).html(\"\u4e94\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 5) {\r\n                $(this).html(\"\u516d\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 6) {\r\n                $(this).html(\"\u4e03\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 7) {\r\n                $(this).html(\"\u516b\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 8) {\r\n                $(this).html(\"\u4e5d\u3001\" + old);\r\n            }\r\n           \r\n\r\n        });\r\n\r\n\r\n        $(\".ques .idx\").each(function (_idx) {\r\n            var old = $(this).html().trim();\r\n            $(this).html((_idx + 1) + \"\" + old+\".\");\r\n\r\n        });\r\n\r\n    </script>\r\n\r\n\r\n                 \r\n     \r\n\r\n     \r\n      \r\n        <script>\r\n\r\n            $(\".view_ques\").click(function () {\r\n\r\n                var tid = $(this).data(\"tid\");\r\n                var answer = $(this).find(\"div.answer\");\r\n\r\n                if (answer.is(':visible')) {\r\n\r\n                    answer.hide();\r\n                }\r\n                else {\r\n                    if (answer.html().trim() == \"\") {\r\n\r\n                        addhis(tid);\r\n                        if (!canview()) {\r\n                            layer.msg(\"\u6bcf\u65e5\u67e5\u770b\u6b21\u6570\u5df2\u7ecf\u7528\u5b8c\uff0c\u5347\u7ea7\u4e3aVIP\u65e0\u9650\u5236\u67e5\u770b\");\r\n                            return;\r\n                        } \r\n\r\n                        $.getJSON(\"/math/jssvr/answer.aspx?id=\" + tid, function (r1) {\r\n                            var ans1 = r1.answer;\r\n                            var analyse = r1.analyse;\r\n\r\n                            if (analyse.trim() != \"\") {\r\n                                answer.html(\"<b>\u7b54\u6848</b>\uff1a\" + ans1 + \" <br> <b>\u89e3\u6790</b>\uff1a\" + analyse);\r\n                            }\r\n                            else {\r\n                                answer.html(\"<b>\u7b54\u6848</b>\uff1a\" + ans1);\r\n                            }\r\n\r\n                            MathJax.typesetPromise();\r\n                        });\r\n\r\n                    }\r\n                    answer.show();\r\n                }\r\n\r\n\r\n\r\n\r\n            });\r\n\r\n\r\n\r\n            $(\".zan\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myzan(tid, this);\r\n            });\r\n\r\n\r\n\r\n            $(\".fav\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myfav(tid, this);\r\n            });\r\n\r\n            $(\".err\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myerr(tid, this);\r\n            });\r\n\r\n\r\n            if (isvip != \"1\") {\r\n                $(\".vip\").hide()\r\n            }\r\n\r\n        </script>\r\n\r\n \r\n\r\n\r\n    \r\n \r\n         </form>    \r\n \r\n\r\n\r\n           \r\n\r\n    \r\n\r\n      \r\n      \r\n\r\n\r\n       \r\n\r\n    <div  class=\"footer-wrapper\" >\r\n        \r\n        <div>\r\n        <a href=\"/Default.aspx\"> &copy; \u79d1\u6570\u7f51 \u4e13\u4e1a\u7684\u6570\u5b66\u7ec4\u5377\u7cfb\u7edf</a>\r\n        </div>\r\n     \r\n\r\n         <div class=\"footer-nav\"> \r\n           <a href=default.aspx>\u79d1\u6570\u7f51</a>   \r\n              \r\n\r\n              <a href=paper_list.aspx>\u8bd5\u5377</a>   \r\n\r\n               <a href=\"Collection.aspx\" >\u540c\u6b65\u8bad\u7ec3</a>   \r\n              \r\n              <a href=\"book.aspx\" >\u6559\u6750</a>   \r\n\r\n      \r\n              <a href=\"//kb.kmath.cn\" target=\"_blank\">\u5728\u7ebf\u5b66\u4e60</a>   \r\n                \r\n\r\n             <a href=\"vip.aspx\"    target=\"_blank\">VIP</a> \r\n             \r\n                 <a href=\"https://kb.kmath.cn/kbase/detail.aspx?id=1502\">\u5173\u4e8e</a>   \r\n\r\n              <a href=rec.aspx>\u6295\u7a3f</a>   \r\n   \r\n         </div>\r\n\r\n\r\n\r\n    