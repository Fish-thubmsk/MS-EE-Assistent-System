n:10px 0px\r\n\r\n }\r\n\r\n .cat span{   display:inline-block;  \r\n              background: #f2f2f2;\r\n              padding:5px 10px;\r\n              margin-bottom:0px;\r\n\r\n }\r\n       \r\n\r\n\r\n       \r\n\r\n\r\n .cnt .answer{ font-size:12px; background-color:#f5f5f5; padding:10px; margin:10px; border-radius:5px; }\r\n .cnt b{ color:#1E9FFF }\r\n .view_ques{ cursor:pointer}\r\n    </style>\r\n\r\n\r\n    <div class=\"kmath2\">\r\n\r\n   \r\n  <div class=\"kmath2_left\">\r\n\r\n          <div class=\"cnt\" style=\"background-color:#FFFFFF; margin-top:20px;\">\r\n       \r\n         <div   class=\"paper_detail\" >\r\n\r\n      \r\n       <div  class=\"theop\" >\r\n\r\n\r\n\r\n               <a  href=\"###\" class=fav_paper data-paperid=\"1221\" data-papername=\"\">  <span class=\"layui-icon-rate-solid layui-icon\"></span> \u6536\u85cf\u8bd5\u5377</a> \r\n \r\n\r\n               <a  href=\"###\" data-paperid=\"1221\" class=\"down_paper\">   <img src=\"images/down.svg\" />\u4e0b\u8f7dWord</a> \r\n\r\n\r\n    <a  href=\"Export_Setting.aspx?id=1221&name=\">   <img src=\"images/down.svg\" />\u5bfc\u51fa\u8bd5\u5377</a> \r\n \r\n           \r\n    <a  href=\"../print/Export_Pdf.aspx?id=1221&name=\">   <img src=\"images/down.svg\" />\u6253\u5370\u8bd5\u5377</a> \r\n \r\n\r\n\r\n    <a   href=\"paper_jx.aspx?id=1221&name=\" target=\"_blank\" >   <span class=\"layui-icon-reply-fill layui-icon\"></span> \u8bd5\u5377\u767d\u677f  </a> \r\n \r\n\r\n            \r\n  <script>\r\n\r\n      $(\".down_paper\").click(function () {\r\n          var paperid = $(this).data(\"paperid\");\r\n          Pop(\"Down_Paper.aspx?paperid=\" + paperid);\r\n          return;\r\n      });\r\n\r\n      $(\".fav_paper\").click(function () {\r\n          var paperid = $(this).data(\"paperid\");\r\n          var papername = $(this).data(\"papername\");\r\n           \r\n          add_fav_paper(this, paperid, papername);\r\n          return;\r\n      });\r\n  </script>\r\n\r\n     </div>\r\n\r\n \r\n     \r\n\r\n\r\n\r\n <div   >  \r\n\r\n          <h3 class=\"papername\">\r\n              <span id=\"ctl00_body_lbl_papername\">2025\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</span>\r\n          </h3>\r\n\r\n      \r\n\r\n     <br /><br />\r\n       \r\n\r\n    <! --  start  -->\r\n\r\n     \r\n        \r\n     \r\n             \r\n              \r\n\r\n        <div id=\"ctl00_body_rpt_types_ctl00_pnl_ques\">\r\n\t \r\n                  <div   class=\"cat\">\r\n                    <span id=\"ctl00_body_rpt_types_ctl00_lbl_single\"> \u5355\u9009\u9898 \uff08\u5171 10 \u9898 \uff09\uff0c\u6bcf\u9898\u53ea\u6709\u4e00\u4e2a\u9009\u9879\u6b63\u786e </span>\r\n                  </div>\r\n          \r\n             \r\n                 \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=21736  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u5df2\u77e5\u51fd\u6570 $f(x)=\\int_0^x e ^{t^2} \\sin t d t, g(x)=\\int_0^x e ^{t^2} d t \\cdot \\sin ^2 x$ \uff0c\u5219 ( ).<br>\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n         \r\n               <div class=\"opts1\">  \r\n                  <span id=\"preview_option1\" class=\"opt\"  > $\\text{A.}$  $x=0$ \u662f $f(x)$ \u7684\u6781\u503c\u70b9\uff0c\u4e5f\u662f $g(x)$ \u7684\u6781\u503c\u70b9 </span>\r\n                  <span id=\"preview_option2\" class=\"opt\"  > $\\text{B.}$  $x=0$ \u662f $f(x)$ \u7684\u6781\u503c\u70b9\uff0c $(0,0)$ \u662f\u66f2\u7ebf $y=g(x)$ \u7684\u62d0\u70b9 </span>\r\n                  <span id=\"preview_option3\" class=\"opt\"  > $\\text{C.}$  $(0,0)$ \u662f $y=f(x)$ \u7684\u62d0\u70b9\uff0c $x=0$ \u662f $g(x)$ \u7684\u6781\u503c\u70b9  </span>\r\n                  <span id=\"preview_option4\" class=\"opt\"   > $\\text{D.}$  $(0,0)$ \u