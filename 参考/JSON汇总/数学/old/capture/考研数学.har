typesname {\r\n    font-size: 13px;\r\n    color: #888\r\n}\r\n\r\n.opts1, .opts2, .opts4 {\r\n    margin: 24px 10px;\r\n}\r\n\r\n.opt {\r\n    margin: 10px;\r\n}\r\n\r\n\r\n\r\n.opts1 {\r\n    display: flex;\r\n    flex-direction: column\r\n}\r\n\r\n.opts2 .opt {\r\n    display: inline-block;\r\n    width: 40%;\r\n}\r\n\r\n.opts4 {\r\n    display: flex;\r\n    justify-content: space-between\r\n}\r\n\r\n@media screen and (max-width: 800px) {\r\n    .opts1, .opts2, .opts4 {\r\n        display: flex;\r\n        flex-direction: column\r\n    }\r\n\r\n        .opts2 .opt {\r\n            display: inline-block;\r\n            width: 100%;\r\n        }\r\n\r\n    img {\r\n        max-width: 98%;\r\n    }\r\n}\r\n"}, "headers":[{"name":"content-type", "value":"text/css"}, {"name":"last-modified", "value":"Fri, 19 Jul 2024 05:04:48 GMT"}, {"name":"accept-ranges", "value":"bytes"}, {"name":"etag", "value":"\"67a0cd2d99d9da1:0\""}, {"name":"server", "value":"Microsoft-IIS/10.0"}, {"name":"x-powered-by", "value":"ASP.NET"}, {"name":"access-control-allow-origin", "value":"*"}, {"name":"strict-transport-security", "value":"max-age=32503000"}, {"name":"date", "value":"Tue, 31 Mar 2026 17:21:25 GMT"}, {"name":"content-length", "value":"1757"}], "statusText":"200", "status":200, "bodySize":1757, "headersSize":322}, "time":68, "cache":{}}, {"request":{"postData":{"text":"", "mimeType":""}, "url":"https://kmath.cn/style/math.css?v=20250928", "cookies":[{"name":"ASP.NET_SessionId", "value":"oeyjgewbvhfmh505lhzshfu4"}, {"name":"Hm_lvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977501"}, {"name":"HMACCOUNT", "value":"F95E3757DD521F24"}, {"name":"Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977628"}], "httpVersion":"HTTP/2", "headers":[{"name":"pragma", "value":"no-cache"}, {"name":"cache-control", "value":"no-cache"}, {"name":"sec-ch-ua-platform", "value":"\"Windows\""}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, l