$<br>$A a=a+\\beta$ \u975e\u96f6\u5217\u5411\u91cf $a, \\beta$\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=21845\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=21845\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=21845'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=21845')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=21845')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=21845')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"21845\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"21845\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=21845\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"21845\" onclick=\"Add(21845, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=21846  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u6295\u4fdd\u4eba\u7684\u635f\u5931\u4e8b\u4ef6\u53d1\u751f\u65f6\uff0c\u4fdd\u9669\u516c\u53f8\u7684\u8d54\u4ed8\u989d $Y$ \u4e0e\u6295\u4fdd\u4eba\u7684\u635f\u5931\u989d X \u7684\u5173\u7cfb\u4e3a<br><br>$$<br>Y=\\left\\{\\begin{array}{l}<br>0, x \\leq 0 \\\\<br>x-100, x&gt;100<br>\\end{array}\\right. <br>$$<br><br>, \u8bbe\u635f\u5931\u4e8b\u4ef6\u53d1\u751f\u65f6, \u6295\u4fdd\u4eba\u7684\u635f\u5931\u989d $X$ \u6982\u7387\u5bc6\u5ea6\u4e3a<br>$$<br>f(x)=\\left\\{\\begin{array}{l}<br>\\frac{2 \\times 100^2}{(100+x)^3}, x&gt;0 \\\\<br>0, x \\leq 0<br>\\end{array} .\\right.<br>$$<br><br>(1)\u6c42 $P\\{Y&gt;0\\}$ \u53ca $E Y$<br>(2)\u8fd9\u79cd\u635f\u5931\u4e8b\u4ef6\u5728\u4e00\u5e74\u5185\u53d1\u751f\u7684\u6b21\u6570\u8bb0\u4e3a N \u4fdd\u9669\u516c\u53f8\u5728\u4e00\u5e74\u5185\u5c31\u8fd9\u79cd\u635f\u5931\u4e8b\u4ef6\u4ea7\u751f\u6b21\u6570\u8bb0\u4e3a $M$ \u3002\u5047\u8bbe $N$ \u670d\u4ece\u53c2\u6570\u4e3a 8 \u7684\u6cca\u677e\u5206\u5e03\uff0c\u5728 $N=n(n \\geq 1)$ \u7684\u6761\u4ef6\u4e0b\uff0cM \u670d\u7684\u7406\u8d54<br>\u4ece\u4e8c\u9879\u5206\u5e03 $B ( n , p )$, \u5176\u4e2d $p=P(Y&gt;0)$ \u6c42 M \u7684\u6982\u7387\u5206\u5e03.\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=21846\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=21846