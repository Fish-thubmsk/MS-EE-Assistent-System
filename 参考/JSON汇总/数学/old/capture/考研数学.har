etItem(params) {\r\n        let obj = {\r\n            name: '',\r\n            value: '',\r\n            exp: \"\",\r\n            startTime: new Date().getTime()//\u8bb0\u5f55\u4f55\u65f6\u5c06\u503c\u5b58\u5165\u7f13\u5b58\uff0c\u6beb\u79d2\u7ea7\r\n        }\r\n        let options = {};\r\n        //\u5c06obj\u548c\u4f20\u8fdb\u6765\u7684params\u5408\u5e76\r\n        Object.assign(options, obj, params);\r\n        if (options.exp) {\r\n            //\u5982\u679coptions.exp\u8bbe\u7f6e\u4e86\u7684\u8bdd\r\n            //\u4ee5options.name\u4e3akey\uff0coptions\u4e3a\u503c\u653e\u8fdb\u53bb\r\n            localStorage.setItem(options.name, JSON.stringify(options));\r\n        } else {\r\n            //\u5982\u679coptions.exp\u6ca1\u6709\u8bbe\u7f6e\uff0c\u5c31\u5224\u65ad\u4e00\u4e0bvalue\u7684\u7c7b\u578b\r\n            let type = Object.prototype.toString.call(options.value);\r\n            //\u5982\u679cvalue\u662f\u5bf9\u8c61\u6216\u8005\u6570\u7ec4\u5bf9\u8c61\u7684\u7c7b\u578b\uff0c\u5c31\u5148\u7528JSON.stringify\u8f6c\u4e00\u4e0b\uff0c\u518d\u5b58\u8fdb\u53bb\r\n            if (Object.prototype.toString.call(options.value) == '[object Object]') {\r\n                options.value = JSON.stringify(options.value);\r\n            }\r\n            if (Object.prototype.toString.call(options.value) == '[object Array]') {\r\n                options.value = JSON.stringify(options.value);\r\n            }\r\n            localStorage.setItem(options.name, options.value);\r\n        }\r\n    }\r\n    //\u62ff\u5230\u7f13\u5b58\r\n    getItem(name) {\r\n        let item = localStorage.getItem(name);\r\n        if (item == null)\r\n            return null;\r\n\r\n        //\u5148\u5c06\u62ff\u5230\u7684\u8bd5\u7740\u8fdb\u884cjson\u8f6c\u4e3a\u5bf9\u8c61\u7684\u5f62\u5f0f\r\n        try {\r\n            item = JSON.parse(item);\r\n        } catch (error) {\r\n            //\u5982\u679c\u4e0d\u884c\u5c31\u4e0d\u662fjson\u7684\u5b57\u7b26\u4e32\uff0c\u5c31\u76f4\u63a5\u8fd4\u56de\r\n            item = item;\r\n        }\r\n        //\u5982\u679c\u6709startTime\u7684\u503c\uff0c\u8bf4\u660e\u8bbe\u7f6e\u4e86\u5931\u6548\u65f6\u95f4\r\n        if (item.startTime) {\r\n            let date = new Date().getTime();\r\n            //\u4f55\u65f6\u5c06\u503c\u53d6\u51fa\u51cf\u53bb\u521a\u5b58\u5165\u7684\u65f6\u95f4\uff0c\u4e0eitem.exp\u6bd4\u8f83\uff0c\u5982\u679c\u5927\u4e8e\u5c31\u662f\u8fc7\u671f\u4e86\uff0c\u5982\u679c\u5c0f\u4e8e\u6216\u7b49\u4e8e\u5c31\u8fd8\u6ca1\u8fc7\u671f\r\n            if (date - item.startTime > item.exp*1000*3600) {\r\n                //\u7f13\u5b58\u8fc7\u671f\uff0c\u6e05\u9664\u7f13\u5b58\uff0c\u8fd4\u56defalse\r\n                localStorage.removeItem(name);\r\n                return false;\r\n            } else {\r\n                //\u7f13\u5b58\u672a\u8fc7\u671f\uff0c\u8fd4\u56de\u503c\r\n                return item.value;\r\n            }\r\n        } else {\r\n            //\u5982\u679c\u6ca1\u6709\u8bbe\u7f6e\u5931\u6548\u65f6\u95f4\uff0c\u76f4\u63a5\u8fd4\u56de\u503c\r\n            return item;\r\n        }\r\n    }\r\n    //\u79fb\u51fa\u7f13\u5b58\r\n    removeItem(name) {\r\n        localStorage.removeItem(name);\r\n    }\r\n    //\u79fb\u51fa\u5168\u90e8\u7f13\u5b58\r\n    clear() {\r\n        localStorage.clear();\r\n    }\r\n}\r\n"}, "headers":[{"name":"content-type", "value":"application/javascript"}, {"name":"last-modified", "value":"Thu, 11 Jul 2024 13:19:24 GMT"}, {"name":"accept-ranges", "value":"bytes"}, {"name":"etag", "value":"\"3888c9f294d3da1:0\""}, {"name":"server", "value":"Microsoft-IIS/10.0"}, {"name":"x-powered-by", "value":"ASP.NET"}, {"name":"access-control-allow-origin", "value":"*"}, {"name":"strict-transport-security", "value":"max-age=32503000"}, {"name":"date", "value":"Tue, 31 Mar 2026 17:21:25 GMT"}, {"name":"content-length", "value":"2647"}], "statusText":"200", "status":200, "bodySize":2647, "headersSize":336}, "time":30, "cache":{}}, {"request":{"postData":{"text":"", "mimeType":""}, "url":"https://kmath.cn/javascript/simple_storage.js?v=20250928", "cookies":[{"name":"ASP.NET_SessionId", "value":"oeyjgewbvhfmh505lhzshfu4"}, {"name":"Hm_lvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977501"}, {"name":"HMACCOUNT", "value":"F95E3757DD521F24"}, {"name":"Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977628"}], "httpVersion":"HTTP/2", "headers":[{"name":"pragma", "value":"no-cache"}, {"name":"cache-control", "value":"no-cache"}, {"name":"sec-ch-ua-platform", "value":"\"Windows\""}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"}, {"name":"sec-ch-ua", "value":"\"Chromium\";v=\"146\", \"Not-A.Brand\";v=\"24\", \"Google Chrome\";v=\"146\""}, {"name":"sec-ch-ua-mobile", "value":"?0"}, {"name":"accept", "value":"*/*"}, {"name":"sec-fetch-site", "value":"same-origin"}, {"name":"sec-fetch-mode", "value":"no-cors"}, {"name":"sec-fetch-dest", "value":"script"}, {"name":"referer", "value":"https://kmath.cn/math/collection.aspx?id=643"}, {"name":"accept-encoding", "value":"gzip, deflate, br, zstd"}, {"name":"accept-language", "value":"en-US,en;q=0.9,zh-CN;q=0.8,zh;q=0.7"}, {"name":"priority", "value":"u=1"}, {"name":"cookie", "value":"ASP.NET_SessionId=oeyjgewbvhfmh505lhzshfu4; Hm_lvt_ee774b6bd20afa25f617ec112c13eed4=1774977501; HMACCOUNT=F95E3757DD521F24; Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4=1774977628"}, {"name":"host", "value":"kmath.cn"}], "headersSize":830, "queryString":[{"name":"v", "value":"20250928"}], "bodySize":0, "method":"GET"}, "timings":{"ssl":0, "send":0, "dns":0, "wait":31, "receive":0, "connect":0, "blocked":-1}, "connection":"ClientPort:42229;EgressPort:20226", "startedDateTime":"2026-04-01T01:21:25.4621715+08:00", "_publicFiddlerId":17, "response":{"cookies":[], "redirectURL":"", "httpVersion":"HTTP/2", "content":{"compression":0, "mimeType":"application/javascript", "size":648, "text":" \r\nfunction setStorage(key, value, exphour) {\r\n    var obj = new Object();\r\n    obj.val = value;\r\n    obj.overtime = exphour;\r\n    obj.starttime = new Date().getTime();  \r\n    obj = JSON.stringify(obj)\r\n    localStorage.setItem(key, obj);\r\n}\r\n\r\n\r\n \r\nfunction getStorage(key) {\r\n    var a = localStorage.getItem(key);\r\n    if (!a) {  \r\n        return null;\r\n    } else {\r\n        var obj = JSON.parse(a);\r\n        var b = new Date().getTime()\r\n        \r\n        var c = (b - obj.starttime) / 3600000.0;\r\n       \r\n        if (c >= obj.overtime) {  \r\n            return null;\r\n        } else {   \r\n            return obj.val;\r\n        }\r\n    }\r\n}\r\n"}, "headers":[{"name":"content-type", "value":"application/javascript"}, {"name":"last-modified", "value":"Mon, 09 Jan 2023 11:19:18 GMT"}, {"name":"accept-ranges", "value":"bytes"}, {"name":"etag", "value":"\"ae34cb361c24d91:0\""}, {"name":"server", "value":"Microsoft-IIS/10.0"}, {"name":"x-powered-by", "value":"ASP.NET"}, {"name":"access-control-allow-origin", "value":"*"}, {"name":"strict-transport-security", "value":"max-age=32503000"}, {"name":"date", "value":"Tue, 31 Mar 2026 17:21:25 GMT"}, {"name":"content-length", "value":"648"}], "statusText":"200", "status":200, "bodySize":648, "headersSize":335}, "time":31, "cache":{}}, {"request":{"postData":{"text":"", "mimeType":""}, "url":"https://kmath.cn/javascript/Mathjax_Config.js?v=20250928", "cookies":[{"name":"ASP.NET_SessionId", "value":"oeyjgewbvhfmh505lhzshfu4"}, {"name":"Hm_lvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977501"}, {"name":"HMACCOUNT", "value":"F95E3757DD521F24"}, {"name":"Hm_lpvt_ee774b6bd20afa25f617ec112c13eed4", "value":"1774977628"}], "httpVersion":"HTTP/2", "headers":[{"name":"pragma", "value":"no-cache"}, {"name":"cache-control", "value":"no-cache"}, {"name":"sec-ch-ua-platform", "value":"\"Windows\""}, {"name":"user-agent", "value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko