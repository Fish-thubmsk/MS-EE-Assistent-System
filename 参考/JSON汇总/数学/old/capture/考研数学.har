ask.aspx?id=35459')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"35459\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"35459\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=35459\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"35459\" onclick=\"Add(35459, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=35460  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u8bbe $f(u)$ \u5728 $(0,+\\infty)$ \u5185\u5177\u6709 3 \u9636\u8fde\u7eed\u5bfc\u6570\uff0c\u4e14\u5b58\u5728\u53ef\u5fae\u51fd\u6570 $F(x, y)$ \u4f7f<br><br>$$<br>d F(x, y)=\\frac{f(x y)}{x^2 y} d x+\\frac{f^{\\prime \\prime}(x y)}{x y^2} d y(x y&gt;0) .<br>$$<br><br>\uff081\uff09\u8bc1\u660e\uff1a$\\frac{f^{\\prime \\prime}(u)}{u}-\\frac{f(u)}{u}=c, c$ \u4e3a\u5e38\u6570\uff1b<br>\uff082\uff09\u8bbe $f(1)=1, f^{\\prime}(1)=-1, f^{\\prime \\prime}(1)=0$ \uff0c\u6c42 $f(u)$ \u7684\u8868\u8fbe\u5f0f\uff0e\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=35460\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=35460\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=35460'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=35460')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=35460')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=35460')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"35460\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"35460\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=35460\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"35460\" onclick=\"Add(35460, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=35461  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u8bbe\u6709\u5411\u66f2\u7ebf $L$ \u4e3a\u692d\u5706 $x^2+3 y^2=1$ \u4e0a\u6cbf\u9006\u65f6\u9488\u65b9\u5411\u4ece\u70b9 $A\\left(-\\frac{1}{2},-\\frac{1}{2}\\right)$ \u5230\u70b9 $B\\left(\\frac{1}{2}, \\frac{1}{2}\\right)$ \u7684\u90e8\u5206\uff0c\u8ba1\u7b97\u66f2\u7ebf\u79ef\u5206 $I=\\int_L\\left(e^{x^2} \\sin x-2 x y\\right) d x+\\left(6 x-x^2-y \\cos ^4 y\\right) d y$ \uff0e\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=35461\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=35461\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=35461'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=35461')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=35461')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=35461')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"35461\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"35461\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=35461\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"35461\" onclick=\"Add(35461, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=35462  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u8bbe\u53ef\u5bfc\u51fd\u6570 $f(x)$ \u4e25\u683c\u5355\u8c03\u9012\u589e\u4e14\u6ee1\u8db3 $\\int_{-1}^1 f(x) d x=0$ \uff0c\u8bb0 $a=\\int_0^1 f(x) d x$ \uff0e<br>\uff081\uff09\u8bc1\u660e $a&gt;0$ \uff1b<br>\uff082\uff09\u4ee4 $F(x)=a\\left(1-x^2\\right)+\\int_1^x f(t) d t$ \uff0c\u8bc1\u660e\uff1a\u5b58\u5728 $\\xi \\in(-1,1)$ \u4f7f $F^{\\prime \\prime}(\\xi)=0$ \uff0e\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=35462\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=35462\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=35462'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=35462')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=35462')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=35462')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"35462\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"35462\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=35462\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"35462\" onclick=\"Add(35462, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=35463  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u5df2\u77e5\u5411\u91cf\u7ec4 $\\alpha_1=\\left(\\begin{array}{c}1 \\\\ 0 \\\\ -1 \\\\ -1\\end{array}\\right), \\alpha_2=\\left(\\begin{array}{c}1 \\\\ -1 \\\\ 0 \\\\ -2\\end{array}\\right), \\alpha_3=\\left(\\begin{array}{c}0 \\\\ -1 \\\\ 1 \\\\ -1\\end{array}\\right), \\alpha_4=\\left(\\begin{array}{c}0 \\\\ 1 \\\\ -1 \\\\ 1\\end{array}\\right)$ \uff0c\u8bb0 $A=\\left(\\alpha_1, \\alpha_2, \\alpha_3, \\alpha_4\\right)$ \uff0c $G=\\left(\\alpha_1, \\alpha_2\\right)$<br>\uff081\uff09\u8bc1\u660e\uff1a$\\alpha_1, \\alpha_2$ \u662f $\\alpha_1, \\alpha_2, \\alpha_3, \\alpha_4$ \u7684\u6781\u5927\u7ebf\u6027\u65e0\u5173\u7ec4\uff0e<br>\uff082\uff09\u6c42\u77e9\u9635 $H$ \u4f7f\u5f97 $A=G H$ \uff0c\u5e76\u6c42 $A^{10}$ \uff0e\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=35463\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=35463\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=35463'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=35463')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=35463')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=35463')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"35463\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"35463\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=35463\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"35463\" onclick=\"Add(35463, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n                  <div style=\" padding:10px 0 30px 10px;\"  data-tid=35464  class=\"view_ques\">\r\n\r\n                    <div class=\"ques\"> \r\n                            <span class=\"idx\"></span> \u5047\u8bbe\u67d0\u79cd\u5143\u4ef6\u5bff\u547d\u670d\u4ece\u6307\u6570\u5206\u5e03\uff0c\u5176\u5747\u503c $\\theta$ \u662f\u672a\u77e5\u53c2\u6570\uff0c\u4e3a\u4f30\u8ba1 $\\theta$ \uff0c\u53d6 $n$ \u4e2a\u8fd9\u79cd\u5143\u4ef6\u540c\u65f6\u505a\u5bff\u547d\u5b9e\u9a8c\uff0c\u8bd5\u9a8c\u76f4\u5230\u51fa\u73b0 $k(1 \\leq k \\leq n)$ \u4e2a\u5143\u4ef6\u5931\u6548\u65f6\u505c\u6b62\uff0e<br>\uff081\uff09\u82e5 $k=1$ \uff0c\u5931\u6548\u5143\u4ef6\u5bff\u547d\u8bb0\u4e3a $T$ \uff0c\uff08i\uff09\u6c42 $T$ \u7684\u6982\u7387\u5bc6\u5ea6\uff1b\uff08ii\uff09\u786e\u5b9a $a$ \uff0c\u4f7f $\\hat{\\theta}=a T$ \u662f $\\theta$ \u7684\u65e0\u504f\u4f30\u8ba1\uff0c\u5e76\u6c42 $D(\\hat{\\theta})$ \uff1b<br>\uff082\uff09\u5df2\u77e5 $k$ \u4e2a\u5931\u6548\u5143\u4ef6\u5bff\u547d\u503c\u5206\u522b\u4e3a $t_1, t_2, \\cdots, t_k$ \uff0c\u4e14 $t_1 \\leq t_2 \\leq \\cdots \\leq t_k$ \uff0c\u4f3c\u7136\u51fd\u6570\u4e3a $L(\\theta)=\\frac{1}{\\theta^k} e^{-\\frac{1}{\\theta}\\left[\\sum_{i=1}^k t_i+(n-k) t_k\\right]}$ \uff0c\u6c42 $\\theta$ \u7684\u6700\u5927\u4f3c\u7136\u4f30\u8ba1\u503c\uff0e\r\n                     </div>\r\n\r\n\r\n\r\n       \r\n            \r\n \r\n \r\n            \r\n         <div class=\"answer\" style=\"display:none\" ></div>\r\n  \r\n          <br />\r\n\r\n\r\n                <div style=\"clear:both\">\r\n\r\n                </div> \r\n\r\n         </div>\r\n          \r\n\r\n                    \r\n<div class=\"layui-card-foot\"> \r\n  \r\n \r\n\r\n     <span class=\"prop\">\r\n\r\n    <a target=\"_blank\" href=\"detail.aspx?id=35464\">\u67e5\u770b</a> &nbsp;&nbsp;\r\n      <a target=\"_blank\" href=\"share.aspx?id=35464\">\u5206\u4eab</a> &nbsp;&nbsp;\r\n\r\n     <a class=\"vip\" href='ques_new.aspx?id=35464'  target=_blank>\u7f16\u8f91</a> &nbsp;&nbsp; \r\n </span>\r\n\r\n\r\n\r\n<span style=\"float:right\">  \r\n\r\n     \r\n     <a  class=\"layui-btn layui-btn-warm layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Down_Ti.aspx?id=35464')\" >\u4e0b\u8f7d\u6b64\u9898</a>\r\n        <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('Copy.aspx?id=35464')\" >\u590d\u5236\u5230\u5fae\u4fe1/\u77e5\u4e4e</a>\r\n       <a  class=\"layui-btn layui-btn-primary layui-btn-xs  \"  href=\"###\" onclick=\"Pop('ask.aspx?id=35464')\" >\u95eeAI</a>\r\n\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs fav\" data-tid=\"35464\">\u6536\u85cf(<span class=\"thefav \">0</span>)</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs err\" data-tid=\"35464\">\u9519\u9898\u672c(<span class=\"theerr \">0</span>)</a>\r\n\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs \" target=\"_blank\" href=\"/math/jx.aspx?id=35464\">\u767d\u677f</a>\r\n    <a class=\"layui-btn layui-btn-primary layui-btn-xs   layui-border-green op\" data-tid=\"35464\" onclick=\"Add(35464, this)\" href=\"###\">\u52a0\u5165\u8bd5\u5377</a>\r\n</span>\r\n\r\n    <div style=\"clear:both\"></div>\r\n    <div style=\"border-bottom:dotted 1px #ccc;margin-top:10px;\"></div>\r\n </div>\r\n\r\n\r\n\r\n                \r\n\r\n\r\n          \r\n</div>\r\n\r\n\r\n\r\n                \r\n\r\n         \r\n             \r\n              \r\n\r\n        \r\n\r\n\r\n\r\n                \r\n\r\n         \r\n       \r\n\r\n\r\n       \r\n\r\n       <! --  /end  -->\r\n\r\n      \r\n     \r\n\r\n\r\n  </div>\r\n\r\n    \r\n        </div>\r\n         \r\n           \r\n        \r\n    </div>\r\n\r\n  </div>\r\n\r\n    <div class=\"kmath2_right\">\r\n        \r\n        <div class=\"vip_block\">\r\n            \u975e\u4f1a\u5458\u6bcf\u5929\u53ef\u4ee5\u67e5\u770b15\u9053\u8bd5\u9898\u3002\r\n\u5f00\u901a\u4f1a\u5458\uff0c\u6d77\u91cf\u8bd5\u9898\u65e0\u9650\u5236\u67e5\u770b\u3002\r\n\r\n            <ul>\r\n                <li>\r\n                    <span class=\"layui-icon-find-fill layui-icon\"> </span> <br />\r\n                    \u65e0\u9650\u770b\u8bd5\u9898\r\n                </li>\r\n\r\n                 <li>\r\n     <span class=\"layui-icon-circle-dot layui-icon\"> </span> <br />\r\n     \u4e0b\u8f7d\u8bd5\u9898\r\n </li>\r\n\r\n                 <li>\r\n     <span class=\"layui-icon-star-fill layui-icon\"> </span> <br />\r\n     \u7ec4\u5377\r\n </li>\r\n\r\n            </ul>\r\n           \r\n            <a href=\"Vip.aspx\" style=\"margin-top:20px;\">\u5f00\u901a\u4f1a\u5458</a>\r\n        </div>\r\n\r\n\r\n\r\n\r\n                 \r\n          <div class=\"block\">\r\n                <h3>\u70ed\u70b9\u63a8\u8350</h3>\r\n            <a onclick=\"sethot('cz',819);\" target=\"_blank\" href=\"Paper_List.aspx#819\"><img src=\"/ad/\u521d\u4e2d.png\" class=\"ad\" /></a>\r\n             <a onclick=\"sethot('gz',816);\" target=\"_blank\"  href=\"Paper_List.aspx#816\">  <img src=\"/ad/\u9ad8\u8003.png\"  class=\"ad\"/></a> \r\n             <a onclick=\"sethot('dx',287);\" target=\"_blank\"  href=\"Paper_List.aspx#287\">  <img src=\"/ad/\u8003\u7814.png\"  class=\"ad\"/></a>\r\n\r\n          </div>\r\n\r\n\r\n\r\n\r\n        \r\n        \r\n      <div class=\"block\">\r\n                  <h3>\u8bd5\u5377\u4e8c\u7ef4\u7801</h3>\r\n            <div class=\"intro\">\r\n\r\n                              \r\n             <div id=\"qrcodeimg\" ></div>\r\n                     \r\n\r\n               <script>\r\n\r\n                   var qrcode = new QRCode(\"qrcodeimg\", {\r\n                       text: \"https://kmath.cn/math/Papername.aspx?id=2223\",\r\n        width: 128,\r\n        height: 128,\r\n        colorDark: \"#000000\",\r\n        colorLight: \"#ffffff\",\r\n        correctLevel: QRCode.CorrectLevel.H\r\n    });\r\n\r\n               </script>\r\n               <div style=\"margin:10px 0px;\">\r\n                   \u5206\u4eab\u6b64\u4e8c\u7ef4\u7801\u5230\u7fa4\uff0c\u8ba9\u66f4\u591a\u670b\u53cb\u53c2\u4e0e\r\n               </div>\r\n                \r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n        \r\n         <div class=\"block\">\r\n                  <h3>\u8bd5\u5377\u767d\u677f</h3>\r\n            <div class=\"intro\">\r\n\r\n                              \r\n              \u8bd5\u5377\u767d\u677f\u63d0\u4f9b\u4e86\u4e00\u4e2a\u7b80\u5355\u7684\u89e6\u6478\u4e66\u5199\u677f\uff0c\u53ef\u4f9b\u8001\u5e08\u4e0a\u8bfe\u3001\u6216\u8005\u89c6\u9891\u76f4\u64ad\u65f6\uff0c\r\n                \u76f4\u63a5\u5229\u7528\u767d\u677f\u7ed9\u5b66\u751f\u8bb2\u89e3\u8bd5\u9898\uff0c\u5982\u6709\u610f\u89c1\uff0c\u6b22\u8fce\u53cd\u9988\u3002\r\n               \r\n                \r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n\r\n\r\n\r\n        \r\n      <div class=\"block\">\r\n                  <h3>\u76f8\u5173\u8bd5\u5377</h3>\r\n            <div class=\"intro\">\r\n\r\n                   \r\n           <a href=\"Papername.aspx?paperid=1221&papername=2025\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2025\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=924&papername=2024\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2024\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=921&papername=2023\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2023\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=918&papername=2022\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2022\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n           <a href=\"Papername.aspx?paperid=913&papername=2021\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)\" > <span class=\"layui-icon-triangle-r layui-icon\"></span>  2021\u5e74\u5168\u56fd\u7855\u58eb\u7814\u7a76\u751f\u62db\u751f\u7edf\u4e00\u8003\u8bd5\u6570\u5b66\u8bd5\u9898\u53ca\u8be6\u7ec6\u53c2\u8003\u89e3\u7b54(\u6570\u4e00)</a>\r\n       \r\n\r\n\r\n                </div>\r\n          </div>\r\n\r\n\r\n     \r\n\r\n    </div>\r\n     \r\n  \r\n        \r\n    \r\n    </div>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n     \r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n     \r\n\r\n \r\n\r\n\r\n   <script>\r\n\r\n\r\n\r\n       function Add(id, obj) {\r\n            \r\n           $(obj).html(\"\u79fb\u9664\u9898\u76ee\");\r\n           $(obj).removeClass(\"layui-border-green\").addClass(\"layui-border-red\");\r\n\r\n           paper.add1(id);\r\n           renderCount(); \r\n           $(obj).off('click')\r\n           $(obj).attr(\"onclick\", \"\").on(\"click\", function () { Remove(id, obj) })\r\n            \r\n       }\r\n\r\n\r\n\r\n\r\n       function Remove(id, obj) {\r\n\r\n\r\n           $(obj).html(\"\u52a0\u5165\u8bd5\u5377\");\r\n           $(obj).removeClass(\"layui-border-red\").addClass(\"layui-border-green\");\r\n\r\n           paper.remove1(id);\r\n           renderCount();\r\n\r\n           $(obj).off('click')\r\n           $(obj).attr(\"onclick\", \"\").on(\"click\", function () { Add(id, obj) });\r\n\r\n\r\n       }\r\n\r\n\r\n\r\n\r\n   </script>\r\n\r\n\r\n    <script>\r\n        $(\".cat span\").each(function (idx) {\r\n            var old = $(this).html().trim();\r\n            if (idx == 0) {\r\n                $(this).html( \"\u4e00\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 1) {\r\n                $(this).html(\"\u4e8c\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 2) {\r\n                $(this).html(\"\u4e09\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 3) {\r\n                $(this).html(\"\u56db\u3001\" + old);\r\n            }\r\n            if (idx == 4) {\r\n                $(this).html(\"\u4e94\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 5) {\r\n                $(this).html(\"\u516d\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 6) {\r\n                $(this).html(\"\u4e03\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 7) {\r\n                $(this).html(\"\u516b\u3001\" + old);\r\n            }\r\n\r\n            if (idx == 8) {\r\n                $(this).html(\"\u4e5d\u3001\" + old);\r\n            }\r\n           \r\n\r\n        });\r\n\r\n\r\n        $(\".ques .idx\").each(function (_idx) {\r\n            var old = $(this).html().trim();\r\n            $(this).html((_idx + 1) + \"\" + old+\".\");\r\n\r\n        });\r\n\r\n    </script>\r\n\r\n\r\n                 \r\n     \r\n\r\n     \r\n      \r\n        <script>\r\n\r\n            $(\".view_ques\").click(function () {\r\n\r\n                var tid = $(this).data(\"tid\");\r\n                var answer = $(this).find(\"div.answer\");\r\n\r\n                if (answer.is(':visible')) {\r\n\r\n                    answer.hide();\r\n                }\r\n                else {\r\n                    if (answer.html().trim() == \"\") {\r\n\r\n                        addhis(tid);\r\n                        if (!canview()) {\r\n                            layer.msg(\"\u6bcf\u65e5\u67e5\u770b\u6b21\u6570\u5df2\u7ecf\u7528\u5b8c\uff0c\u5347\u7ea7\u4e3aVIP\u65e0\u9650\u5236\u67e5\u770b\");\r\n                            return;\r\n                        } \r\n\r\n                        $.getJSON(\"/math/jssvr/answer.aspx?id=\" + tid, function (r1) {\r\n                            var ans1 = r1.answer;\r\n                            var analyse = r1.analyse;\r\n\r\n                            if (analyse.trim() != \"\") {\r\n                                answer.html(\"<b>\u7b54\u6848</b>\uff1a\" + ans1 + \" <br> <b>\u89e3\u6790</b>\uff1a\" + analyse);\r\n                            }\r\n                            else {\r\n                                answer.html(\"<b>\u7b54\u6848</b>\uff1a\" + ans1);\r\n                            }\r\n\r\n                            MathJax.typesetPromise();\r\n                        });\r\n\r\n                    }\r\n                    answer.show();\r\n                }\r\n\r\n\r\n\r\n\r\n            });\r\n\r\n\r\n\r\n            $(\".zan\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myzan(tid, this);\r\n            });\r\n\r\n\r\n\r\n            $(\".fav\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myfav(tid, this);\r\n            });\r\n\r\n            $(\".err\").click(function () {\r\n                var tid = $(this).data(\"tid\");\r\n                myerr(tid, this);\r\n            });\r\n\r\n\r\n            if (isvip != \"1\") {\r\n                $(\".vip\").hide()\r\n            }\r\n\r\n        </script>\r\n\r\n \r\n\r\n\r\n    \r\n \r\n         </form>    \r\n \r\n\r\n\r\n           \r\n\r\n    \r\n\r\n      \r\n      \r\n\r\n\r\n       \r\n\r\n    <div  class=\"footer-wrapper\" >\r\n        \r\n        <div>\r\n        <a href=\"/Default.aspx\"> &copy; \u79d1\u6570\u7f51 \u4e13\u4e1a\u7684\u6570\u5b66\u7ec4\u5377\u7cfb\u7edf</a>\r\n        </div>\r\n     \r\n\r\n         <div class=\"footer-nav\"> \r\n           <a href=default.aspx>\u79d1\u6570\u7f51</a>   \r\n              \r\n\r\n              <a href=paper_list.aspx>\u8bd5\u5377</a>   \r\n\r\n               <a href=\"Collection.aspx\" >\u540c\u6b65\u8bad\u7ec3</a>   \r\n              \r\n              <a href=\"book.aspx\" >\u6559\u6750</a>   \r\n\r\n      \r\n              <a href=\"//kb.kmath.cn\" target=\"_blank\">\u5728\u7ebf\u5b66\u4e60</a>   \r\n                \r\n\r\n             <a href=\"vip.aspx\"    target=\"_blank\">VIP</a> \r\n             \r\n                 <a href=\"https://kb.kmath.cn/kbase/detail.aspx?id=1502\">\u5173\u4e8e</a>   \r\n\r\n              <a href=rec.aspx>\u6295\u7a3f</a>   \r\n   \r\n         </div>\r\n\r\n\r\n\r\n        <div style=\"font-size:12px;\">\r\n        \u79d1\u6570\u7f51\u4e3a\u60a8\u63d0\u4f9b\u521d\u4e2d\u6570\u5b66\u9898\u5e93\u3001\u9ad8\u4e2d\u6570\u5b66\u9898\u5e93\u3001\u5927\u5b66\u6570\u5b66\u9898\u5e93\u3002 \r\n            <br />\r\n            \u516c\u5b89\u90e8\u5907\u6848\u53f7  <a href=\"https://www.beian.gov.cn/portal/registerSystemInfo?recordcode=34032102180059\">\u7696 34032102180059</a> \r\n\r\n            \u5de5\u4fe1\u90e8\u5907\u6848 <a href=\"https://beian.miit.gov.cn\">\u6caaICP\u59072021016285\u53f7-2</a> \r\n           \r\n           \u8bd5\u9898\u6536\u96c6\u4e92\u8054\u7f51\uff0c\u5982\u6709\u7248\u6743\u5f02\u8bae\u8bf7\u8054\u7cfb \u674e\u5148\u751f 18155261033\r\n         </div>\r\n    \r\n\r\n    </div>\r\n\r\n\r\n\r\n\r\n \r\n\r\n\r\n    \r\n   <script>\r\n       var json =[{\"name\":\"\u8003\u7814\u6570\u5b66\",\"value\":\"dx\",\"index\": \"1\"},{\"name\":\"\u9ad8\u4e2d\u6570\u5b66\",\"value\":\"gz\",\"index\": \"2\"}