"accept"}, {"value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36 MicroMessenger/7.0.20.1781(0x6700143B) NetType/WIFI MiniProgramEnv/Windows WindowsWechat/WMPF WindowsWechat(0x63090819)XWEB/11581", "name":"user-agent"}, {"value":"https://s6-xunke.cdn.ixunke.cn", "name":"origin"}, {"value":"cross-site", "name":"sec-fetch-site"}, {"value":"cors", "name":"sec-fetch-mode"}, {"value":"empty", "name":"sec-fetch-dest"}, {"value":"https://s6-xunke.cdn.ixunke.cn/", "name":"referer"}, {"value":"gzip, deflate, br", "name":"accept-encoding"}, {"value":"zh-CN,zh;q=0.9", "name":"accept-language"}, {"value":"api.wisapp.cn", "name":"host"}], "method":"GET", "postData":{"text":"", "mimeType":""}, "bodySize":0}, "response":{"headersSize":661, "cookies":[], "statusText":"200", "redirectURL":"", "status":200, "content":{"text":"{\"count\":16,\"totalPages\":1,\"pageSize\":16,\"currentPage\":1,\"data\":{\"questions\":[{\"id\":91232,\"type\":\"1\",\"stem\":\"<p>\u4e60\u8fd1\u5e73\u5f3a\u8c03\uff0c\u8981&quot;\u6811\u7acb\u5927\u519c\u4e1a\u89c2\u3001\u5927\u98df\u7269\u89c2\uff0c\u5411\u8015\u5730\u8349\u539f\u68ee\u6797\u6d77\u6d0b\u3001\u5411\u690d\u7269\u52a8\u7269\u5fae\u751f\u7269\u8981\u70ed\u91cf\u3001\u8981\u86cb\u767d\uff0c\u5168\u65b9\u4f4d\u591a\u9014\u5f84\u5f00\u53d1\u98df\u54c1\u8d44\u6e90&quot;,&quot;\u65e2\u5411\u9646\u5730\u8981\u98df\u7269\uff0c\u4e5f\u5411\u6d77\u6d0b\u8981\u98df\u7269\uff0c\u8015\u6d77\u7267\u6e14\uff0c\u5efa\u8bbe\u6d77\u4e0a\u7267\u573a\u3001'\u84dd\u8272\u7cae\u4ed3'&quot;,\u6784\u5efa\u591a\u5143\u5316\u98df\u7269\u4f9b\u7ed9\u4f53\u7cfb\u3002&quot;\u5927\u519c\u4e1a\u89c2&quot;&quot;\u5927\u98df\u7269\u89c2&quot;\u7a81\u51fa\u4f53\u73b0\u7684\u601d\u7ef4\u65b9\u5f0f\u662f</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u9898\u5e72&quot;\u6811\u7acb\u5927\u519c\u4e1a\u89c2\u3001\u5927\u98df\u7269\u89c2\uff0c\u5411\u8015\u5730\u8349\u539f\u68ee\u6797\u6d77\u6d0b\u3001\u5411\u690d\u7269\u52a8\u7269\u5fae\u751f\u7269\u8981\u70ed\u91cf\u3001\u8981\u86cb\u767d\uff0c\u5168\u65b9\u4f4d\u591a\u9014\u5f84\u5f00\u53d1\u98df\u54c1\u8d44\u6e90&quot;\u4f53\u73b0\u4e86\u4e16\u754c\u4e0a\u4e07\u4e8b\u4e07\u7269\u5f7c\u6b64\u4e4b\u95f4\u90fd\u662f\u76f8\u4e92\u8054\u7cfb\u7684\uff0c\u6d77\u6d0b\u3001\u9646\u5730\u3001\u8349\u539f\u3001\u4e4b\u95f4\u5f7c\u6b64\u662f\u76f8\u4e92\u8054\u7cfb\u7684\u3002\u5728\u601d\u7ef4\u4e0a\u8868\u73b0\u5373\u662f\u7cfb\u7edf\u601d\u7ef4\u3002\u6545\u672c\u9898\u9009C\u3002\u516d\u79cd\u601d\u7ef4\u80fd\u529b\u5f53\u4e2d\u6ca1\u6709\u6781\u9650\u601d\u7ef4\u3001\u9006\u5411\u601d\u7ef4\uff0c\u9898\u5e72\u6ca1\u6709\u4f53\u73b0\u5386\u53f2\u601d\u7ef4\u53d1\u5c55\u7684\u89c2\u70b9\uff0c\u56e0\u6b64\u6392\u9664\u3002</p>\\n\",\"options\":[\"<p>\u6781\u9650\u601d\u7ef4</p>\\n\",\"<p>\u5386\u53f2\u601d\u7ef4</p>\\n\",\"<p>\u7cfb\u7edf\u601d\u7ef4</p>\\n\",\"<p>\u9006\u5411\u601d\u7ef4</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":6336,\"rightCount\":6081,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":12720,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":91233,\"type\":\"1\",\"stem\":\"<p>\u9a6c\u514b\u601d\u8ba4\u4e3a:&quot;\u5bf9\u4eba\u7c7b\u751f\u6d3b\u5f62\u5f0f\u7684\u601d\u7d22\uff0c\u4ece\u800c\u5bf9\u8fd9\u4e9b\u5f62\u5f0f\u7684\u79d1\u5b66\u5206\u6790\uff0c\u603b\u662f\u91c7\u53d6\u540c\u5b9e\u9645\u53d1\u5c55\u76f8\u53cd\u7684\u9053\u8def\u3002\u8fd9\u79cd\u601d\u7d22\u662f\u4ece\u4e8b\u540e\u5f00\u59cb\u7684\uff0c\u5c31\u662f\u8bf4\uff0c\u662f\u4ece\u53d1\u5c55\u8fc7\u7a0b\u7684\u5b8c\u6210\u7684\u7ed3\u679c\u5f00\u59cb\u7684\u3002&quot;\u8fd9\u4e00\u65b9\u6cd5\u6240\u63ed\u793a\u7684\u5b9e\u9645\u5185\u6db5\u662f:\u5386\u53f2\u7684\u53d1\u5c55\u603b\u662f\u6309\u7167\u65f6\u95f4\u987a\u5e8f\u4ece\u8fc7\u53bb\u5230\u73b0\u5728\u4ee5\u81f3\u672a\u6765\uff0c\u800c\u5bf9\u5386\u53f2\u7684\u8ba4\u8bc6\u5219\u8981\u9075\u5faa\u76f8\u53cd\u7684\u987a\u5e8f\uff0c\u4e0e\u4ece\u540e\u601d\u7d22\u6cd5\u4e00\u81f4\u7684\u662f</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u9898\u5e72\u5f3a\u8c03\u7684\u662f&quot;\u4ece\u540e\u601d\u7d22\u6cd5&quot;\u3002\u53ea\u6709\u9009\u9879&quot;\u4eba\u4f53\u89e3\u5256\u662f\u5bf9\u7334\u5b50\u89e3\u5256\u7684\u94a5\u5319&quot;\u8fd9\u4e00\u300a\u8d44\u672c\u8bba\u300b\u4e2d\u7684\u89c2\u70b9\uff0c\u4f53\u73b0\u4e86\u4ece\u540e\u601d\u7d22\u3002A\u9009\u9879&quot;\u6211\u601d\u6545\u6211\u5728&quot;,\u662f\u5178\u578b\u7684\u552f\u5fc3\u4e3b\u4e49\u7684\u89c2\u70b9\uff0c\u6392\u9664\u3002C\u9009\u9879\u903b\u8f91\u548c\u5386\u53f2\u5728\u5177\u4f53\u73af\u8282\u4e0a\u5177\u6709\u4e00\u81f4\u6027\uff0c\u8bf4\u6cd5\u9519\u8bef\u6392\u9664\uff0cD\u9009\u9879\u4e16\u754c\u53d1\u5c55\u7684\u4e00\u822c\u8fc7\u7a0b\u62d2\u65a5\u4e8b\u7269\u4e2a\u522b\u53d1\u5c55\u8fc7\u7a0b\u7684\u7279\u6b8a\u6027\uff0c\u8bf4\u6cd5\u9519\u8bef\uff0c\u4e16\u754c\u7684\u4e00\u822c\u8fc7\u7a0b\u4e0d\u6392\u9664\u7279\u6b8a\u6027\u3002\u6545\u672c\u9898\u9009B\u3002</p>\\n\",\"options\":[\"<p>\u6211\u601d\u6545\u6211\u5728</p>\\n\",\"<p>\u4eba\u4f53\u89e3\u5256\u662f\u5bf9\u7334\u5b50\u89e3\u5256\u7684\u94a5\u5319</p>\\n\",\"<p>\u903b\u8f91\u548c\u5386\u53f2\u5728\u5177\u4f53\u73af\u8282\u4e0a\u5177\u6709\u4e00\u81f4\u6027</p>\\n\",\"<p>\u4e16\u754c\u53d1\u5c55\u7684\u4e00\u822c\u8fc7\u7a0b\u62d2\u65a5\u4e8b\u7269\u4e2a\u522b\u53d1\u5c55\u8fc7\u7a0b\u7684\u7279\u6b8a\u6027</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":6153,\"rightCount\":4569,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":12720,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":91234,\"type\":\"1\",\"stem\":\"<p>\u552f\u7269\u53f2\u89c2\u4ece\u4eba\u6c11\u7fa4\u4f17\u521b\u9020\u5386\u53f2\u8fd9\u4e00\u524d\u63d0\u51fa\u53d1\uff0c\u65e2\u660e\u786e\u4e86\u4eba\u6c11\u7fa4\u4f17\u662f\u5386\u53f2\u7684\u521b\u9020\u8005\uff0c\u4e5f\u4e0d\u5426\u8ba4\u4e2a\u4eba\u5728\u5386\u53f2\u4e2d\u7684\u4f5c\u7528\u3002\u4e60\u8fd1\u5e73\u603b\u4e66\u8bb0\u5728\u7eaa\u5ff5\u6bdb\u6cfd\u4e1c\u8bde\u8fb0120\u5468\u5e74\u5ea7\u8c08\u4f1a\u4e0a\uff0c\u5bf9\u5386\u53f2\u4eba\u7269\u4f5c\u51fa\u4e86\u7cbe\u8f9f\u7684\u8bba\u8ff0:&quot;\u4e0d\u80fd\u628a\u5386\u53f2\u987a\u5883\u4e2d\u7684\u6210\u529f\u7b80\u5355\u5f52\u529f\u4e8e\u4e2a\u4eba\uff0c\u4e5f\u4e0d\u80fd\u628a\u5386\u53f2\u9006\u5883\u4e2d\u7684\u632b\u6298\u5f52\u548e\u4e8e\u4e2a\u4eba\uff0c\u4e0d\u80fd\u7528\u4eca\u5929\u7684\u65f6\u4ee3\u6761\u4ef6\u3001\u53d1\u5c55\u6c34\u5e73\u548c\u8ba4\u8bc6\u6c34\u5e73\u53bb\u8861\u91cf\uff0c\u8981\u6c42\u524d\u4eba\u8fbe\u5230\u4eca\u5929\u7684\u8981\u6c42\uff0c\u4e0d\u80fd\u82db\u6c42\u524d\u4eba\u505a\u51fa\u4eca\u5929\u4eba\u505a\u51fa\u7684\u6210\u679c\u3002&quot;\u8fd9\u4e00\u8bba\u8ff0\u8868\u660e</p>\\n\",\"answer\":[3],\"analysis\":\"<p>\u672c\u9898\u76f8\u5bf9\u7b80\u5355\u3002\u4eba\u6c11\u7fa4\u4f17\u662f\u5386\u53f2\u7684\u521b\u9020\u8005\uff0c\u5386\u53f2\u7684\u4e3b\u4f53;\u6770\u51fa\u4eba\u7269\u4e0e\u4eba\u6c11\u7fa4\u4f17\u7684\u5386\u53f2\u4f5c\u7528\u662f\u4e0d\u540c\u7684\uff0cA\u6392\u9664\u3002\u6770\u51fa\u4eba\u7269\u7684\u667a\u6167\u548c\u6027\u683c\u4e0d\u80fd\u6539\u53d8\u5386\u53f2\u53d1\u5c55\u7684\u57fa\u672c\u65b9\u5411\uff0c\u53ea\u80fd\u5f71\u54cd\u5386\u53f2\u8d70\u5411\uff0cB\u6392\u9664\u3002\u987a\u5883\u6bd4\u9006\u5883\u4f5c\u7528\u66f4\u5927\uff0cC\u6392\u9664\u3002\u53ea\u6709D\u9009\u9879\u672c\u8eab\u8bf4\u6cd5\u6b63\u786e\u4e14\u7b26\u5408\u9898\u5e72\u610f\u601d;\u6545\u672c\u9898\u9009D\u3002</p>\\n\",\"options\":[\"<p>\u6770\u51fa\u4eba\u7269\u4e0e\u4eba\u6c11\u7fa4\u4f17\u7684\u5386\u53f2\u4f5c\u7528\u662f\u540c\u7b49\u91cd\u8981\u7684</p>\\n\",\"<p>\u6770\u51fa\u4eba\u7269\u7684\u667a\u6167\u548c\u6027\u683c\u80fd\u591f\u6539\u53d8\u5386\u53f2\u53d1\u5c55\u7684\u57fa\u672c\u65b9\u5411</p>\\n\",\"<p>\u6770\u51fa\u4eba\u7269\u5728\u9006\u5883\u65f6\u53d1\u6325\u7684\u4f5c\u7528\u6bd4\u5728\u987a\u5883\u65f6\u66f4\u5927</p>\\n\",\"<p>\u8981\u4ece\u7279\u5b9a\u5386\u53f2\u6761\u4ef6\u51fa\u53d1\uff0c\u5bf9\u5386\u53f2\u4eba\u7269\u505a\u5177\u4f53\u5168\u9762\u7684\u8003\u5bdf\u548c\u8bc4\u4ef7</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":5867,\"rightCount\":5736,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":12720,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":1,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":91235,\"type\":\"1\",\"stem\":\"<p>1916\u5e74\u5217\u5b81\u5728\u300a\u65e0\u4ea7\u9636\u7ea7\u9769\u547d\u7684\u519b\u4e8b\u7eb2\u9886\u300b\u4e00\u6587\u4e2d\u6307\u51fa:&quot;\u793e\u4f1a\u4e3b\u4e49\u5c06\u5728\u4e00\u4e2a\u6216\u51e0\u4e2a\u56fd\u5bb6\u83b7\u5f97\u80dc\u5229\uff0c\u800c\u5176\u4f59\u7684\u56fd\u5bb6\u5728\u4e00\u6bb5\u65f6\u95f4\u5185\u5c06\u4ecd\u7136\u662f\u8d44\u4ea7\u9636\u7ea7\u7684\u6216\u8d44\u4ea7\u9636\u7ea7\u4ee5\u524d\u7684\u56fd\u5bb6&quot;,\u5217\u5b81\u5f97\u51fa\u8fd9\u4e00\u7ed3\u8bba\u7684\u4f9d\u636e\u662f</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u9898\u5e72\u95ee\u5217\u5b81\u5728\u300a\u65e0\u4ea7\u9636\u7ea7\u9769\u547d\u7684\u519b\u4e8b\u7eb2\u9886\u300b&quot;\u793e\u4f1a\u4e3b\u4e49\u5c06\u5728\u4e00\u4e2a\u6216\u51e0\u4e2a\u56fd\u5bb6\u83b7\u5f97\u80dc\u5229\uff0c\u800c\u5176\u4f59\u7684\u56fd\u5bb6\u5728\u4e00\u6bb5\u65f6\u95f4\u5185\u5c06\u4ecd\u7136\u662f\u8d44\u4ea7\u9636\u7ea7\u7684\u6216\u8d44\u4ea7\u9636\u7ea7\u4ee5\u524d\u7684\u56fd\u5bb6&quot;\u3002\u8fd9\u5c5e\u4e8e\u5217\u5b81\u5728\u9a6c\u514b\u601d\u4e3b\u4e49\u53d1\u5c55\u53f2\u4e0a\u8c08\u5230\u7684\u4e00\u4e2a\u91cd\u8981\u8bba\u6218&quot;\u4e00\u56fd\u80dc\u5229\u8bba&quot;,\u5373\u8d44\u672c\u4e3b\u4e49\u7684\u53d1\u5c55\u5728\u5404\u4e2a\u56fd\u5bb6\u6781\u4e0d\u5e73\u8861\u3002\u6545\u672c\u9898\u9009C\u3002ABD\u672c\u8eab\u8bf4\u6cd5\u9519\u8bef\u4e14\u4e0d\u7b26\u5408\u9898\u5e72\u3002</p>\\n\",\"options\":[\"<p>\u4e16\u754c\u5404\u56fd\u65e0\u4ea7\u9636\u7ea7\u7684\u56fd\u9645\u5927\u8054\u76df\u5df2\u7ecf\u5f62\u6210</p>\\n\",\"<p>\u8d44\u672c\u4e3b\u4e49\u666e\u9009\u5236\u4e3a\u793e\u4f1a\u4e3b\u4e49\u9769\u547d\u521b\u9020\u4e86\u65b0\u6761\u4ef6</p>\\n\",\"<p>\u8d44\u672c\u4e3b\u4e49\u7684\u53d1\u5c55\u5728\u5404\u4e2a\u56fd\u5bb6\u6781\u4e0d\u5e73\u8861</p>\\n\",\"<p>\u5de5\u4eba\u9636\u7ea7\u7684\u9769\u547d\u610f\u5fd7\u4e0e\u7ecf\u6d4e\u53d1\u5c55\u6c34\u5e73\u6b63\u76f8\u5173</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":5805,\"rightCount\":5102,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":12720,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":2,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":91236,\"type\":\"1\",\"stem\":\"<p>\u72ec\u7acb\u81ea\u4e3b\u662f\u6bdb\u6cfd\u4e1c\u601d\u60f3\u6d3b\u7684\u7075\u9b42\uff0c\u6bdb\u6cfd\u4e1c\u5728\u300a\u53cd\u5bf9\u672c\u672c\u4e3b\u4e49\u300b\u4e00\u6587\u4e2d\u6307\u51fa\uff0c&quot;\u4e2d\u56fd\u9769\u547d\u6597\u4e89\u7684\u80dc\u5229\u8981\u9760\u4e2d\u56fd\u540c\u5fd7\u4e86\u89e3\u4e2d\u56fd\u60c5\u51b5&quot;,\u8fd9\u662f\u6700\u521d\u5bf9\u72ec\u7acb\u81ea\u4e3b\u601d\u60f3\u7684\u660e\u786e\u8868\u8ff0\uff0c\u6bdb\u6cfd\u4e1c\u4f5c\u51fa\u8fd9\u4e00\u8868\u8ff0\u662f\u4e3a\u4e86</p>\\n\",\"answer\":[1],\"analysis\":\"<p>1930\u5e745\u6708\uff0c\u571f\u5730\u9769\u547d\u6218\u4e89\u65f6\u671f\uff0c\u6bdb\u6cfd\u4e1c\u5728\u300a\u53cd\u5bf9\u672c\u672c\u4e3b\u4e49\u300b\u4e00\u6587\u4e2d\uff0c\u9610\u660e\u4e86\u575a\u6301\u8fa9\u8bc1\u552f\u7269\u4e3b\u4e49\u7684\u601d\u60f3\u8def\u7ebf\u5373\u575a\u6301\u7406\u8bba\u4e0e\u5b9e\u9645\u76f8\u7ed3\u5408\u7684\u539f\u5219\u7684\u6781\u7aef\u91cd\u8981\u6027\uff0c\u63d0\u51fa\u4e86&quot;\u6ca1\u6709\u8c03\u67e5\uff0c\u6ca1\u6709\u53d1\u8a00\u6743&quot;\u548c&quot;\u4e2d\u56fd\u9769\u547d\u6597\u4e89\u7684\u80dc\u5229\u8981\u9760\u4e2d\u56fd\u540c\u5fd7\u4e86\u89e3\u4e2d\u56fd\u60c5\u51b5&quot;\u7684\u91cd\u8981\u601d\u60f3\uff0c\u6bdb\u6cfd\u4e1c\u4f5c\u51fa\u8fd9\u4e00\u8868\u8ff0\u662f\u4e3a\u4e86\u53cd\u5bf9\u515a\u5185\u5b58\u5728\u7684\u6559\u6761\u4e3b\u4e49\u503e\u5411\u3002B\u6b63\u786e\u3002\u5de9\u56fa\u548c\u53d1\u5c55\u7edf\u4e00\u6218\u7ebf\u662f\u6bdb\u6cfd\u4e1c\u5728\u6297\u65e5\u6218\u4e89\u65f6\u671f\u63d0\u51fa\u7684\u601d\u60f3\uff0c\u6545A\u9519\u8bef\u3002\u9632\u6b62\u5404\u79cd\u975e\u65e0\u4ea7\u9636\u7ea7\u601d\u60f3\u7684\u4ea7\u751f\u662f\u515a\u5728\u571f\u5730\u9769\u547d\u6218\u4e89\u65f6\u671f\u53e4\u7530\u4f1a\u8bae\u4e2d\u63d0\u51fa\u7684\uff0c\u7528\u65e0\u4ea7\u9636\u7ea7\u601d\u60f3\u514b\u670d\u5404\u79cd\u975e\u65e0\u4ea7\u9636\u7ea7\u7684\u601d\u60f3\uff0cC\u9519\u8bef\u3002D\u9879\u4e0e\u9898\u76ee\u65e0\u5173\u3002</p>\\n\",\"options\":[\"<p>\u5de9\u56fa\u548c\u53d1\u5c55\u7edf\u4e00\u6218\u7ebf</p>\\n\",\"<p>\u53cd\u5bf9\u515a\u5185\u5b58\u5728\u7684\u6559\u6761\u4e3b\u4e49\u503e\u5411</p>\\n\",\"<p>\u9632\u6b62\u5404\u79cd\u975e\u65e0\u4ea7\u9636\u7ea7\u601d\u60f3\u7684\u4ea7\u751f</p>\\n\",\"<p>\u53bb\u9664\u7ea2\u519b\u4e2d\u9057\u7559\u7684\u65e7\u519b\u961f\u4e0d\u826f\u4f5c\u98ce</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":5759,\"rightCount\":4945,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":12720,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":6,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":91237,\"type\":\"1\",\"stem\":\"<p>\u9093\u5c0f\u5e73\u7406\u8bba\u4f5c\u4e3a\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\u7406\u8bba\u4f53\u7cfb\u7684\u5f00\u7bc7\u4e4b\u4f5c\uff0c\u7b2c\u4e00\u6b21\u6bd4\u8f83\u7cfb\u7edf\u5730\u521d\u6b65\u56de\u7b54\u4e86\u5efa\u8bbe\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\u7684\u4e00\u7cfb\u5217\u57fa\u672c\u95ee\u9898\uff0c\u5176\u4e2d\u4e3a\u5efa\u8bbe