u7cfb&quot;\u3002A\u9009\u9879\u4eba\u4e0e\u81ea\u7136\u5173\u7cfb\u7eaf\u7cb9\u662f\u81ea\u7136\u754c\u751f\u7269\u6f14\u5316\u7684\u8fc7\u7a0b\uff0c\u8bf4\u6cd5\u9519\u8bef\uff0c\u628a\u4eba\u7b49\u540c\u4e8e\u7eaf\u7cb9\u7684\u751f\u7269\uff0c\u5ffd\u89c6\u4e86\u4eba\u7684\u5b9e\u8df5\u6d3b\u52a8\u91cd\u8981\u6027\u3002\u6392\u9664\u3002B\u9009\u9879\u4eba\u7c7b\u793e\u4f1a\u6d3b\u52a8\u7684\u89c4\u5f8b\u7531\u751f\u7269\u8fdb\u5316\u7684\u89c4\u5f8b\u51b3\u5b9a\uff0c\u8bf4\u6cd5\u9519\u8bef\uff0c\u5c5e\u4e8e\u5178\u578b\u7684\u5eb8\u4fd7\u8fdb\u5316\u8bba\uff0c\u540c\u6837\u5ffd\u89c6\u4e86\u4eba\u7684\u5b9e\u8df5\u6d3b\u52a8\u7684\u91cd\u8981\u6027\u3002\u53ea\u6709\u9009\u9879CD\u8bf4\u6cd5\u6b63\u786e\u4e14\u7b26\u5408\u9898\u5e72\uff0c\u6545\u672c\u9898\u9009CD\u3002</p>\\n\",\"options\":[\"<p>\u4eba\u4e0e\u81ea\u7136\u5173\u7cfb\u7eaf\u7cb9\u662f\u81ea\u7136\u754c\u751f\u7269\u6f14\u5316\u7684\u8fc7\u7a0b</p>\\n\",\"<p>\u4eba\u7c7b\u793e\u4f1a\u6d3b\u52a8\u7684\u89c4\u5f8b\u7531\u751f\u7269\u8fdb\u5316\u7684\u89c4\u5f8b\u51b3\u5b9a</p>\\n\",\"<p>\u4eba\u4e0e\u81ea\u7136\u548c\u8c10\u5171\u751f\u4ee5\u81ea\u7136\u754c\u7684\u5ba2\u89c2\u89c4\u5f8b\u4e3a\u57fa\u7840</p>\\n\",\"<p>\u4eba\u7684\u6d3b\u52a8\u548c\u9009\u62e9\u6027\u4e0e\u81ea\u7136\u754c\u5148\u8fdb\u6027\u662f\u52a8\u6001\u7edf\u4e00\u7684</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":4979,\"rightCount\":4042,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":12721,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"2\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":91249,\"type\":\"2\",\"stem\":\"<p>\u4eba\u673a\u63a5\u53e3\u6280\u672f\u53d8\u4e3a\u73b0\u5b9e\uff0c\u8868\u660e\u4eba\u7c7b\u610f\u8bc6:</p>\\n\",\"answer\":[0,3],\"analysis\":\"<p>\u9898\u5e72\u95ee\u4eba\u5de5\u667a\u80fd\u548c\u4eba\u7684\u610f\u8bc6\u7684\u5173\u7cfb\u3002BC\u9009\u9879\u672c\u8eab\u8bf4\u6cd5\u9519\u8bef\uff0c\u4eba\u5de5\u667a\u80fd\u4e0d\u5177\u5907\u60c5\u611f\u610f\u5fd7\u3001\u4e14\u4e0d\u80fd\u4ee3\u66ff\u4eba\u7c7b\u4ea4\u5f80\u771f\u60c5\u5b9e\u611f\u3002AD\u672c\u8eab\u8bf4\u6cd5\u6b63\u786e\uff0c\u4eba\u7684\u610f\u8bc6\u80fd\u591f\u901a\u8fc7\u4eba\u5de5\u667a\u80fd\u673a\u5668\u5b9e\u73b0\u5bf9\u8c61\u5316\u73b0\u5b9e\u5316\u3002\u4e14\u80fd\u591f\u7269\u5316\u4e3a\u673a\u5668\u7684\u7269\u8d28\u8fd0\u52a8\u800c\u5ef6\u4f38\u610f\u8bc6\u8f7d\u4f53\u7684\u529f\u80fd\u3002\u6545\u672c\u9898\u9009AD\u3002</p>\\n\",\"options\":[\"<p>\u80fd\u591f\u901a\u8fc7\u4eba\u5de5\u667a\u80fd\u673a\u5668\u5b9e\u73b0\u5bf9\u8c61\u5316\u73b0\u5b9e\u5316</p>\\n\",\"<p>\u80fd\u591f\u88ab\u5177\u6709\u60c5\u611f\u3001\u610f\u5ff5\u3001\u610f\u8bc6\u7684\u4eba\u5de5\u667a\u80fd\u53d6\u4ee3</p>\\n\",\"<p>\u80fd\u591f\u8fd8\u539f\u4e3a\u6570\u5b57\u7b26\u53f7\u5e76\u53d6\u4ee3\u4eba\u7c7b\u4ea4\u5f80\u771f\u60c5\u5b9e\u611f</p>\\n\",\"<p>\u80fd\u591f\u7269\u5316\u4e3a\u673a\u5668\u7684\u7269\u8d28\u8fd0\u52a8\u800c\u5ef6\u4f38\u610f\u8bc6\u8f7d\u4f53\u7684\u529f\u80fd</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":4846,\"rightCount\":4669,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":12721,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":0,\"pType\":\"2\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":91250,\"type\":\"2\",\"stem\":\"<p>\u7af9\u5b50\u5168\u8eab\u90fd\u662f\u5b9d\uff0c\u82cf\u4e1c\u5761\u66fe\u611f\u53f9:&quot;\u8bb0\u5cad\u5357\u7af9\u5cad\u5357\u4eba\uff0c\u5f53\u6709\u6127\u4e8e\u7af9\u3002\u98df\u8005\u7af9\u7b0b\uff0c\u5e87\u8005\u7af9\u74e6\uff0c\u8f7d\u8005\u7af9\u7b4f\uff0c\u7228\u8005\u7af9\u85aa\uff0c\u8863\u8005\u7af9\u76ae\uff0c\u4e66\u8005\u7af9\u7eb8\uff0c\u5c65\u8005\u7af9\u978b\uff0c\u771f\u53ef\u8c13\u4e00\u65e5\u4e0d\u53ef\u65e0\u6b64\u541b\u4e5f\u8036\u3002&quot;\u7af9\u5b50\u591a\u6837\u529f\u80fd\u8868\u660e\uff0c\u4e8b\u7269\u4ef7\u503c</p>\\n\",\"answer\":[0,2],\"analysis\":\"<p>\u9898\u5e72\u8003\u5bdf\u4ef7\u503c\u5173\u7cfb\u3002\u4ef7\u503c\u968f\u7740\u5ba2\u4f53\u3001\u4e3b\u4f53\u53ca\u5176\u76f8\u4e92\u5173\u7cfb\u7684\u53d8\u5316\u800c\u53d8\u5316\uff0c\u5e76\u4e14\u968f\u7740\u5b9e\u8df5\u7684\u53d1\u5c55\u800c\u53d1\u5c55\uff0c\u56e0\u6b64AC\u6b63\u786e\u3002\u9009\u9879B\u4ef7\u503c\u968f\u7740\u4e3b\u4f53\u5174\u8da3\u3001\u611f\u60c5\u548c\u6b32\u671b\u7684\u8f6c\u79fb\u800c\u53d8\u5316\uff0c\u5c5e\u4e8e\u5178\u578b\u7684\u552f\u5fc3\u4e3b\u4e49\uff0c\u6392\u9664\u3002\u4ef7\u503c\u5e76\u4e0d\u4f1a\u968f\u7740\u968f\u5ba2\u4f53\u5c5e\u6027\u7684\u81ea\u7136\u663e\u9732\u800c\u8f6c\u5316\u4e3a\u793e\u4f1a\u4ef7\u503c\uff0c\u9700\u8981\u901a\u8fc7\u4eba\u7c7b\u7684\u5b9e\u8df5\u6d3b\u52a8\u624d\u53ef\u4ee5\u8f6c\u5316\u4e3a\u793e\u4f1a\u4ef7\u503c\uff0c\u6392\u9664\u3002\u6545\u672c\u9898\u9009AC\u3002</p>\\n\",\"options\":[\"<p>\u968f\u7740\u5ba2\u4f53\u3001\u4e3b\u4f53\u53ca\u5176\u76f8\u4e92\u5173\u7cfb\u7684\u53d8\u5316\u800c\u53d8\u5316</p>\\n\",\"<p>\u968f\u4e3b\u4f53\u5174\u8da3\u3001\u611f\u60c5\u548c\u6b32\u671b\u7684\u8f6c\u79fb\u800c\u53d8\u5316</p>\\n\",\"<p>\u968f\u5b9e\u8df5\u7684\u53d1\u5c55\u7531\u6f5c\u5728\u7684\u4ef7\u503c\u8f6c\u