\u63d0\u9ad8</p>\\n\",\"<p>\u7406\u8bba\u5bf9\u5b9e\u8df5\u7684\u6307\u5bfc\u4f5c\u7528\u6ca1\u6709\u6b63\u786e\u4e0e\u9519\u8bef\u4e4b\u5206</p>\\n\",\"<p>\u7531\u5b9e\u8df5\u5230\u8ba4\u8bc6\u7684\u7b2c\u4e00\u6b21\u98de\u8dc3\u6bd4\u8ba4\u8bc6\u5230\u5b9e\u8df5\u7684\u7b2c\u4e8c\u6b21\u98de\u8dc3\u66f4\u91cd\u8981</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1232,\"rightCount\":1175,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":84,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":1,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1860,\"type\":\"1\",\"stem\":\"<p>\u793e\u4f1a\u5b58\u5728\u51b3\u5b9a\u793e\u4f1a\u610f\u8bc6\uff0c\u793e\u4f1a\u610f\u8bc6\u662f\u793e\u4f1a\u5b58\u5728\u7684\u53cd\u6620\u3002\u793e\u4f1a\u610f\u8bc6\u5177\u6709\u76f8\u5bf9\u72ec\u7acb\u6027\uff0c\u5373\u5b83\u5728\u53cd\u6620\u793e\u4f1a\u5b58\u5728\u7684\u540c\u65f6\uff0c\u8fd8\u6709\u81ea\u5df1\u7279\u6709\u7684\u53d1\u5c55\u5f62\u5f0f\u548c\u89c4\u5f8b\u3002\u793e\u4f1a\u610f\u8bc6\u76f8\u5bf9\u72ec\u7acb\u6027\u6700\u7a81\u51fa\u7684\u8868\u73b0\u662f</p>\\n\",\"answer\":[3],\"analysis\":\"<p>\u9009\u9879A,B,C,D\u5747\u4e3a\u793e\u4f1a\u610f\u8bc6\u76f8\u5bf9\u72ec\u7acb\u6027\u7684\u8868\u73b0\uff0c\u4f46\u793e\u4f1a\u610f\u8bc6\u72ec\u7acb\u6027\u6700\u7a81\u51fa\u7684\u8868\u73b0\u662f\u793e\u4f1a\u610f\u8bc6\u5bf9\u793e\u4f1a\u5b58\u5728\u5177\u6709\u80fd\u52a8\u7684\u53cd\u4f5c\u7528\u3002</p>\\n\",\"options\":[\"<p>\u793e\u4f1a\u610f\u8bc6\u4e0e\u793e\u4f1a\u5b58\u5728\u53d1\u5c55\u7684\u4e0d\u5b8c\u5168\u540c\u6b65\u6027</p>\\n\",\"<p>\u793e\u4f1a\u610f\u8bc6\u5185\u90e8\u5404\u79cd\u5f62\u5f0f\u4e4b\u95f4\u7684\u76f8\u4e92\u4f5c\u7528\u548c\u5f71\u54cd</p>\\n\",\"<p>\u793e\u4f1a\u610f\u8bc6\u5404\u79cd\u5f62\u5f0f\u5404\u81ea\u5177\u6709\u5176\u5386\u53f2\u7ee7\u627f\u6027</p>\\n\",\"<p>\u793e\u4f1a\u610f\u8bc6\u5bf9\u793e\u4f1a\u5b58\u5728\u5177\u6709\u80fd\u52a8\u7684\u53cd\u4f5c\u7528</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":1249,\"rightCount\":841,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":84,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":1,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1861,\"type\":\"1\",\"stem\":\"<p>\u7b2c\u4e8c\u6b21\u4e16\u754c\u5927\u6218\u4ee5\u540e\uff0c\u8d44\u672c\u4e3b\u4e49\u56fd\u5bb6\u7ecf\u5386\u4e86\u7b2c\u4e09\u6b21\u79d1\u6280\u9769\u547d\uff0c\u673a\u5668\u5927\u5de5\u4e1a\u53d1\u5c55\u5230\u81ea\u52a8\u5316\u9636\u6bb5\uff0c\u667a\u80fd\u5316\u5de5\u5382\u521b\u9020\u51fa\u4e86\u8f83\u9ad8\u7684\u751f\u4ea7\u6548\u7387\uff0c\u663e\u9732\u51fa\u5de8\u5927\u7684\u7ade\u4e89\u529b\uff0c\u4f01\u4e1a\u5728&quot;\u673a\u5668\u6362\u4eba&quot;\u4e2d\u53d6\u5f97\u4e86\u4e00\u5b9a\u7684\u7ecf\u6d4e\u6548\u76ca\u3002\u8fd9\u610f\u5473\u7740\u7387\u5148\u4f7f\u7528\u673a\u5668\u4eba\u7684\u4e2a\u522b\u4f01\u4e1a</p>\\n\",\"answer\":[0],\"analysis\":\"<p>\u8d44\u4ea7\u7684\u6280\u672f\u6784\u6210\u662f\u6307\uff0c\u6709\u751f\u4ea7\u6280\u672f\u51b3\u5b9a\u7684\u4e0d\u53d8\u8d44\u672c\u548c\u53ef\u53d8\u8d44\u672c\u7684\u678