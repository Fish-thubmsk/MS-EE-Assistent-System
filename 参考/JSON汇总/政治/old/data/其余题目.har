4e2d\u56fd\u4eba\u6c11\u4e0d\u65ad\u63a8\u8fdb\u4f1f\u5927\u793e\u4f1a\u9769\u547d\u3002\u4e60\u8fd1\u5e73\u603b\u4e66\u8bb0\u6307\u51fa\uff0c&quot;\u4e2d\u56fd\u5171\u4ea7\u515a\u4e3a\u4ec0\u4e48\u80fd\uff0c\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\u4e3a\u4ec0\u4e48\u597d\uff0c\u5f52\u6839\u5230\u5e95\u662f\u56e0\u4e3a\u9a6c\u514b\u601d\u4e3b\u4e49\\n\u884c!&quot;\u9a6c\u514b\u601d\u4e3b\u4e49\u4e4b\u6240\u4ee5&quot;\u884c&quot;\uff0c\u6839\u672c\u539f\u56e0\u5728\u4e8e</p>\",\"answer\":[2],\"analysis\":\"<p><span style=\\\"text-decoration: underline; color: rgb(255, 0, 0);\\\">\u9a6c\u514b\u601d\u4e3b\u4e49\u662f\u5bf9\u81ea\u7136\u3001\u793e\u4f1a\u548c\u4eba\u7c7b\u601d\u7ef4\u53d1\u5c55\u672c\u8d28\u548c\u89c4\u5f8b\u7684\u6b63\u786e\u53cd\u6620</span>\u3002\u5b83\u662f\u5728\u793e\u4f1a\u5b9e\u8df5\u548c\u79d1\u5b66\u53d1\u5c55\u7684\u57fa\u7840\u4e0a\u4ea7\u751f\u7684\uff0c\u5e76\u5728\u81ea\u8eab\u53d1\u5c55\u8fc7\u7a0b\u4e2d\u4e0d\u65ad\u603b\u7ed3\u5b9e\u8df5\u7ecf\u9a8c\uff0c\u5438\u53d6\u81ea\u7136\u79d1\u5b66\u548c\u793e\u4f1a\u79d1\u5b66\u53d1\u5c55\u7684\u6700\u65b0\u6210\u5c31\u3002<span style=\\\"color: rgb(255, 0, 0); text-decoration: underline;\\\">\u9a6c\u514b\u601d\u4e3b\u4e49\u5177\u6709\u79d1\u5b66\u7684\u4e16\u754c\u89c2\u548c\u65b9\u6cd5\u8bba\u57fa\u7840</span>\uff0c\u5373\u8fa9\u8bc1\u552f\u7269\u4e3b\u4e49\u548c\u5386\u53f2\u552f\u7269\u4e3b\u4e49\uff0c\u8fd9\u662f\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u4e00\u4e2a\u7a81\u51fa\u7279\u5f81\u548c\u7406\u8bba\u4f18\u52bf\uff0c\u4e5f\u662f\u9a6c\u514b\u601d\u4e3b\u4e49\u79d1\u5b66\u6027\u7684\u91cd\u8981\u4f53\u73b0\u3002\u9a6c\u514b\u601d\u4e3b\u4e49\u7406\u8bba\u662f\u4e00\u4e2a\u903b\u8f91\u4e25\u5bc6\u7684\u6709\u673a\u6574\u4f53\uff0c\u5b83\u7684\u5f62\u5f0f\u662f\u4e3b\u89c2\u7684\uff0c\u4f46\u5185\u5bb9\u662f\u5ba2\u89c2\u7684\uff0c\u5b83\u4ee5\u4e8b\u5b9e\u4e3a\u4f9d\u636e\u3001\u4ee5\u89c4\u5f8b\u4e3a\u5bf9\u8c61\uff0c\u5e76\u4ee5\u5b9e\u8df5\u4e3a\u68c0\u9a8c\u6807\u51c6\u3002\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u53d1\u5c55\u5177\u6709\u79d1\u5b66\u63a2\u7d22\u6027\uff0c\u662f\u4e00\u4e2a\u4e0d\u65ad\u63a2\u7d22\u548c\u638c\u63e1\u5ba2\u89c2\u89c4\u5f8b\u7684\u8fc7\u7a0b\u3002\\n\u6545 C\u9879\u6b63\u786e\u3002</p><p>ABD \u9879\u4e0d\u7b26\u5408\u9898\u610f\uff0c\u4e0d\u9009\u3002</p>\",\"options\":[\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u5177\u6709\u9c9c\u660e\u7684\u653f\u6cbb\u7acb\u573a</p>\",\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u5177\u6709\u81ea\u89c9\u7684\u5386\u53f2\u62c5\u5f53</p>\",\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u662f\u79d1\u5b66\u7684\u4e16\u754c\u89c2\u548c\u65b9\u6cd5\u8bba</p>\",\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u662f\u65e0\u4ea7\u9636\u7ea7\u653f\u515a\u81ea\u6211\u9769\u547d\u7684\u6b66\u5668</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":5065,\"rightCount\":4574,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":5,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1592,\"type\":\"1\",\"stem\":\"<p>\u515a\u7684\u5341\u516b\u5927\u4ee5\u6765\uff0c\u6211\u56fd\u4ece\u4e2d\u897f\u90e822\u4e2a\u7701\u4efd\u6709\u52b3\u52a8\u80fd\u529b\u7684\u5efa\u6863\u7acb\u5361\u8d2b\u56f0\u4eba\u53e3\u4e2d\u9009\u8058110.2\u4e07\u540d\u751f\u6001\u62a4\u6797\u5458\uff0c\u8d70\u51fa\u4e86\u4e00\u6761\u751f\u6001\u8865\u507f\u8131\u8d2b\u7684\u65b0\u8def\u5b50\uff0c\u5b9e\u73b0\u4e86\u751f\u6001\u4fdd\u62a4\u548c\u8131\u8d2b\u589e\u6536&quot;\u53cc\u8d62&quot;\uff0c\u5145\u5206\u4f53\u73b0\u4e86&quot;\u4eba\u4e0d\u8d1f\u9752\u5c71\uff0c\u9752\u5c71\u5b9a\u4e0d\u8d1f\u4eba&quot;\u7684\u6df1\u523b\u54f2\u7406\u3002&quot;\u4eba\u4e0d\u8d1f\u9752\u5c71\uff0c\u9752\u5c71\u5b9a\u4e0d\u8d1f\u4eba&quot;\u8868\u660e</p>\",\"answer\":[1],\"analysis\":\"<p>A\u9879\u8bf4\u6cd5\u9519\u8bef\uff0c\u81ea\u7136\u867d\u7136\u80fd\u591f\u4e3a\u4eba\u63d0\u4f9b\u793e\u4f1a\u751f\u6d3b\u548c\u751f\u4ea7\u8d44\u6599\uff0c\u4f46\u4e0d\u80fd\u4e3b\u52a8\u3001\u81ea\u53d1\u5730\u6ee1\u8db3\u4eba\u7684\u6240\u6709\u8981\u6c42\u3002\u4eba\u7684\u53d1\u5c55\u53ea\u80fd\u9002\u5e94\u81ea\u7136\u7684\u53d8\u5316\uff0c\u5ffd\u7565\u4e86\u4eba\u7684\u80fd\u52a8\u4f5c\u7528\uff0c\u8bf4\u6cd5\u9519\u8bef\uff0c\u6545\u6392\u9664C\u3002\u4eba\u53ef\u4ee5\u80fd\u52a8\u5730\u6539\u9020\u81ea\u7136\uff0c\u4f46\u81ea\u7136\u5e76\u4e0d\u5177\u6709\u80fd\u52a8\u6027\uff0c\u56e0\u6b64\u4e0d\u80fd\u8bf4\u81ea\u7136\u80fd\u52a8\u5730\u8865\u507f\u4eba\u7684\u52b3\u52a8\uff0c\u6392\u9664D\u9009\u9879\u3002\u6545\u7b54\u6848\u4e3aB\u3002</p>\",\"options\":[\"<p>\u4eba\u4e0e\u81ea\u7136\u662f\u540c\u4e00\u7684\uff0c\u81ea\u7136\u80fd\u591f\u81ea\u53d1\u6ee1\u8db3\u4eba\u7684\u8981\u6c42</p>\",\"<p>\u751f\u4ea7\u5305\u62ec\u81ea\u7136\u8981\u7d20\uff0c\u5408\u7406\u5f00\u53d1\u81ea\u7136\u80fd\u4fc3\u8fdb\u793e\u4f1a\u53d1\u5c55</p>\",\"<p>\u4eba\u662f\u81ea\u7136\u7684\u4e00\u90e8\u5206\uff0c\u4eba\u7684\u53d1\u5c55\u53ea\u80fd\u9002\u5e94\u81ea\u7136\u7684\u53d8\u5316</p>\",\"<p>\u4eba\u80fd\u52a8\u6539\u9020\u81ea\u7136\uff0c\u81ea\u7136\u80fd\u52a8\u8865\u507f\u4eba\u7684\u52b3\u52a8</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":4964,\"rightCount\":4175,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1593,\"type\":\"1\",\"stem\":\"<p>\u4e0e\u7b2c\u4e8c\u6b21\u4e16\u754c\u5927\u6218\u524d\u7684\u8d44\u672c\u4e3b\u4e49\u76f8\u6bd4\uff0c\u5f53\u4ee3\u8d44\u672c\u4e3b\u4e49\u5728\u8bb8\u591a\u65b9\u9762\u5df2\u7ecf\u5e76\u6b63\u5728\u53d1\u751f\u7740\u6df1\u523b\u7684\u53d8\u5316\u3002\u5f53\u4ee3\u8d44\u672c\u4e3b\u4e49\u793e\u4f1a\uff0c\u5927\u516c\u53f8\u7ecf\u8425\u6d3b\u52a8\u7684\u5b9e\u9645\u63a7\u5236\u8005\u662f</p>\",\"answer\":[0],\"analysis\":\"<p>\u5728\u5f53\u4ee3\u8d44\u672c\u4e3b\u4e49\u751f\u4ea7\u5173\u7cfb\u4e2d\uff0c\u793e\u4f1a\u9636\u5c42\u3001\u9636\u7ea7\u7ed3\u6784\u53d1\u751f\u4e86\u65b0\u7684\u53d8\u5316\u3002</p><p>\u4e00\u662f\u8d44\u672c\u5bb6\u7684\u5730\u4f4d\u548c\u4f5c\u7528\u53d1\u751f\u5f88\u5927\u7684\u53d8\u5316\uff0c\u8d44\u672c\u6240\u6709\u6743\u548c\u7ecf\u8425\u6743\u53d1\u751f\u5206\u79bb\uff0c\u62e5\u6709\u6240\u6709\u6743\u7684\u8d44\u672c\u5bb6\u4e00\u822c\u4e0d\u518d\u76f4\u63a5\u7ecf\u8425\u548c\u7ba1\u7406\u4f01\u4e1a\uff0c\u800c\u662f\u9760\u62e5\u6709\u7684\u4f01\u4e1a\u80a1\u7968\u7b49\u6709\u4ef7\u8bc1\u5238\u7684\u5229\u606f\u6536\u5165\u4e3a\u751f\u3002</p><p>\u4e8c\u662f\u9ad8\u7ea7\u804c\u4e1a\u7ecf\u7406\u6210\u4e3a\u5927\u516c\u53f8\u7ecf\u8425\u6d3b\u52a8\u7684\u5b9e\u9645\u63a7\u5236\u8005\u3002</p><p>\u4e09\u662f\u77e5\u8bc6\u578b\u548c\u670d\u52a1\u578b\u52b3\u52a8\u8005\u7684\u6570\u91cf\u4e0d\u65ad\u589e\u52a0\uff0c\u52b3\u52a8\u65b9\u5f0f\u53d1\u751f\u4e86\u65b0\u53d8\u5316\u3002</p><p>\u56e0\u6b64\uff0c\u672c\u9898\u6b63\u786e\u9009\u9879\u4e3aA\u3002</p>\",\"options\":[\"<p>\u9ad8\u7ea7\u804c\u4e1a\u7ecf\u7406</p>\\n\",\"<p>\u80a1\u4e1c\u5927\u4f1a</p>\\n\",\"<p>\u76d1\u4e8b\u4f1a</p>\\n\",\"<p>\u8463\u4e8b\u957f</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":3,\"studCount\":4923,\"rightCount\":3032,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":5,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1594,\"type\":\"1\",\"stem\":\"<p>\u9a6c\u514b\u601d\u5728\u300a\u8d44\u672c\u8bba\u300b\u4e2d\u6307\u51fa:&quot;\u4e00\u4e2a\u5546\u54c1\u5360\u6709\u8005\u51fa\u552e\u4ed6\u73b0\u6709\u7684\u5546\u54c1\uff0c\u800c\u53e6\u4e00\u4e2a\u5546\u54c1\u5360\u6709\u8005\u5374\u53ea\u662f\u4f5c\u4e3a\u8d27\u5e01\u7684\u4ee3\u8868\u6216\u4f5c\u4e3a\u672a\u6765\u8d27\u5e01\u7684\u4ee3\u8868\u6765\u8d2d\u4e70\u8fd9\u79cd\u5546\u54c1\u3002\u5356\u8005\u6210\u4e3a\u503a\u6743\u4eba\uff0c\u4e70\u8005\u6210\u4e3a\u503a\u52a1\u4eba\u3002\u7531\u4e8e\u5546\u54c1\u7684\u5f62\u6001\u53d8\u5316\u6216\u5546\u54c1\u7684\u4ef7\u503c\u5f62\u5f0f\u7684\u53d1\u5c55\u5728\u8fd9\u91cc\u8d77\u4e86\u53d8\u5316\uff0c\u8d27\u5e01\u4e5f\u5c31\u53d6\u5f97\u4e86\u53e6\u4e00\u79cd\u804c\u80fd\u3002&quot;\u8fd9\u91cc\u6240\u8bba\u8ff0\u7684\u8d27\u5e01&quot;\u53e6\u4e00\u79cd\u804c\u80fd&quot;\u6307\u7684\u662f</p>\",\"answer\":[3],\"analysis\":\"<p>\u8d27\u5e01\u5177\u6709\u4e94\u79cd\u57fa\u672c\u7684\u804c\u80fd\uff0c\u5373<span style=\\\"text-decoration: underline; color: rgb(255, 0, 0);\\\">\u4ef7\u503c\u5c3a\u5ea6\u3001\u6d41\u901a\u624b\u6bb5\u3001\u8d2e\u85cf\u624b\u6bb5\u3001\u652f\u4ed8\u624b\u6bb5\u548c\u4e16\u754c\u8d27\u5e01</span>\u3002\u968f\u7740\u8d27\u5e01\u7684\u4ea7\u751f\uff0c\u6574\u4e2a\u5546\u54c1\u4e16\u754c\u5206\u5316\u4e3a\u4e24\u6781:\u4e00\u6781\u662f\u5404\u79cd\u5404\u6837\u7684\u5177\u4f53\u5546\u54c1\uff0c\u5206\u522b\u4ee3\u8868\u4e0d\u540c\u7684\u4f7f\u7528\u4ef7\u503c;\u53e6\u4e00\u6781\u662f\u8d27\u5e01\uff0c\u53ea\u4ee3\u8868\u5546\u54c1\u7684\u4ef7\u503c\u3002\u6839\u636e\u9898\u5e72\u4e2d\u5173\u952e\u8bcd&quot;\u503a\\n\u6743\u4eba&quot;\u53ca&quot;\u4f5c\u4e3a\u8d27\u5e01\u7684\u4ee3\u8868\u6216\u4f5c\u4e3a\u672a\u6765\u8d27\u5e01\u7684\u4ee3\u8868&quot;\uff0c\u53ef\u4ee5\u5f97\u51fa\uff0c\u8fd9\u91cc\u7684&quot;\u53e6\u4e00\u79cd\u804c\u80fd&quot;\u6307\u7684\u662f\u652f\u4ed8\u624b\u6bb5\u3002\u56e0\u6b64\uff0c\u672c\u9898\u6b63\u786e\u9009\u9879\u4e3aD\u3002</p>\",\"options\":[\"<p>\u4ef7\u503c\u5c3a\u5ea6</p>\",\"<p>\u6d41\u901a\u624b\u6bb5</p>\",\"<p>\u8d2e\u85cf\u624b\u6bb5</p>\",\"<p>\u652f\u4ed8\u624b\u6bb5</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":5,\"studCount\":4830,\"rightCount\":2856,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":8,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1595,\"type\":\"1\",\"stem\":\"<p>\u5171\u540c\u5bcc\u88d5\u662f\u793e\u4f1a\u4e3b\u4e49\u7684\u672c\u8d28\u8981\u6c42\uff0c\u662f\u4e2d\u56fd\u5f0f\u73b0\u4ee3\u5316\u7684\u91cd\u8981\u7279\u5f81\u3002\u515a\u7684\u5341\u4e5d\u5c4a\u4e94\u4e2d\u5168\u4f1a\u5bf9\u624e\u5b9e\u63a8\u52a8\u5171\u540c\u5bcc\u88d5\u4f5c\u51fa\u91cd\u5927\u6218\u7565\u90e8\u7f72\uff0c\u660e\u786e\u63d0\u51fa\u4e86\u63a8\u8fdb\u5171\u540c\u5bcc\u88d5\u7684\\n2035 \u5e74\u8fdc\u666f\u76ee\u6807\u3002\u8fd9\u4e00\u76ee\u6807\u662f</p>\",\"answer\":[1],\"analysis\":\"<p>\u515a\u7684\u5341\u4e5d\u5927\u62a5\u544a\u63d0\u51fa\uff0c\u4ece2035\u5e74\u5230\u672c\u4e16\u7eaa\u4e2d\u53f6\uff0c\u5efa\u6210\u793e\u4f1a\u4e3b\u4e49\u73b0\u4ee3\u5316\u5f3a\u56fd\uff0c\u5168\u4f53\u4eba\u6c11\u5171\u540c\u5bcc\u88d5\u57fa\u672c\u5b9e\u73b0\uff0c\u6545\u6392\u9664\u9009\u9879A\u3002CD\u4e3a\u8ff7\u60d1\u9879\u3002\u4e60\u8fd1\u5e73\u603b\u4e66\u8bb0\u5728\u515a\u7684\u5341\u4e5d\u5c4a\u4e94\u4e2d\u5168\u4f1a\u516c\u62a5\u4e2d\u6307\u51fa:&quot;\u5341\u56db\u4e94&quot;<span style=\\\"text-decoration: underline; color: rgb(255, 0, 0);\\\">\u8981\u624e\u5b9e\u63a8\u52a8\u5171\u540c\u5bcc\u88d5\uff0c\u4e0d\u65ad\u589e\u5f3a\u4eba\u6c11\u7fa4\u4f17\u83b7\u5f97\u611f\u3001\u5e78\u798f\u611f\u3001\u5b89\u5168\u611f\uff0c\u4fc3\u8fdb\u4eba\u7684\u5168\u9762\u53d1\u5c55\u548c\u793e\u4f1a\u5168\u9762\u8fdb\u6b65</span>\u30022035\u5e74\u57fa\u672c\u5b9e\u73b0\u793e\u4f1a\u4e3b\u4e49\u73b0\u4ee3\u5316\u8fdc\u666f\u76ee\u6807\u5305\u62ec\u4eba\u6c11\u751f\u6d3b\u66f4\u52a0\u7f8e\u597d\uff0c\u4eba\u7684\u5168\u9762\u53d1\u5c55\u3001\u5168\u4f53\u4eba\u6c11\u5171\u540c\u5bcc\u88d5\u53d6\u5f97\u66f4\u4e3a\u660e\u663e\u7684\u5b9e\u8d28\u6027\u8fdb\u5c55\u3002\u6545\u6b63\u786e\u7b54\u6848\u4e3a\\nB\u3002</p>\",\"options\":[\"<p>\u5168\u4f53\u4eba\u6c11\u5171\u540c\u5bcc\u88d5\u57fa\u672c\u5b9e\u73b0</p>\\n\",\"<p>\u5168\u4f53\u4eba\u6c11\u5171\u540c\u5bcc\u88d5\u53d6\u5f97\u66f4\u4e3a\u660e\u663e\u7684\u5b9e\u8d28\u6027\u8fdb\u5c55</p>\\n\",\"<p>\u5168\u4f53\u4eba\u6c11\u5171\u540c\u5bcc\u88d5\u5168\u9762\u5b9e\u73b0</p>\\n\",\"<p>\u5168\u4f53\u4eba\u6c11\u5171\u540c\u5bcc\u88d5\u540c\u6b65\u5b9e\u73b0</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":3,\"studCount\":4671,\"rightCount\":3028,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":6,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1596,\"type\":\"1\",\"stem\":\"<p>\u53d1\u5c55\u683c\u5c40\u662f\u7ecf\u6d4e\u73b0\u4ee3\u5316\u7684\u8def\u5f84\u9009\u62e9,\u662f\u5173\u7cfb\u6211\u56fd\u53d1\u5c55\u5168\u5c40\u7684\u91cd\u5927\u6218\u7565\u4efb\u52a1\u3002\u7acb\u8db3\u65b0\u53d1\u5c55\u9636\u6bb5\u3002\u8d2f\u5f7b\u65b0\u53d1\u5c55\u7406\u5ff5\uff0c\u8981\u81f4\u529b\u6784\u5efa\u4ee5\u56fd\u5185\u5927\u5faa\u73af\u4e3a\u4e3b\u4f53\u3001\u56fd\u5185\u56fd\u9645\u53cc\u5faa\u73af\u76f8\u4e92\u4fc3\u8fdb\u7684\u65b0\u53d1\u5c55\u683c\u5c40\u3002\u6784\u5efa\u65b0\u53d1\u5c55\u683c\u5c40\u7684\u5173\u952e\u5728\u4e8e</p>\",\"answer\":[0],\"analysis\":\"<p>\u6784\u5efa\u65b0\u53d1\u5c55\u683c\u5c40\u6700\u672c\u8d28\u7684\u7279\u5f81\u662f\u5b9e\u73b0\u9ad8\u6c34\u5e73\u7684\u81ea\u7acb\u81ea\u5f3a\uff0c\u6392\u9664C\u3002BD\u662f\u6784\u5efa\u65b0\u53d1\u5c55\u683c\u5c40\u7684\u91cd\u8981\u4e3e\u63aa\uff0c\u6392\u9664\u3002\u4e60\u8fd1\u5e73\u6307\u51fa\uff0c<span style=\\\"text-decoration: underline; color: rgb(255, 0, 0);\\\">\u6784\u5efa\u65b0\u53d1\u5c55\u683c\u5c40\u7684\u5173\u952e\uff0c\u5728\u4e8e\u5185\u5faa\u73af\u4e3a\u4e3b\u4f53\u57fa\u7840\u4e0a\u4fc3\u8fdb\u7ecf\u6d4e\u53cc\u5faa\u73af\u7545\u901a\u65e0\u963b</span>\u3002\u6545\u6b63\u786e\u7b54\u6848\u4e3aA\u3002</p>\",\"options\":[\"<p>\u7ecf\u6d4e\u5faa\u73af\u7684\u7545\u901a\u65e0\u963b</p>\",\"<p>\u5e02\u573a\u4e3b\u4f53\u7684\u6d3b\u529b</p>\",\"<p>\u9ad8\u6c34\u5e73\u7684\u81ea\u7acb\u81ea\u5f3a</p>\",\"<p>\u4ea7\u4e1a\u94fe\u4f9b\u5e94\u94fe\u7684\u4f18\u5316\u5347\u7ea7</p>