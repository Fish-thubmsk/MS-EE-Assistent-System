avorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1603,\"type\":\"1\",\"stem\":\"<p>\u4e2d\u534e\u4f20\u7edf\u7f8e\u5fb7\u662f\u4e2d\u534e\u4f18\u79c0\u6587\u5316\u7684\u91cd\u8981\u7ec4\u6210\u90e8\u5206\uff0c\u5176\u5185\u5bb9\u535a\u5927\u7cbe\u6df1\uff0c\u6e90\u8fdc\u6d41\u957f\u3002\u4ece\u300a\u8bd7\u7ecf\u300b\u4e2d\u7684&quot;\u5919\u591c\u5728\u516c&quot;\u5230\u5c1a\u4e66\u7684&quot;\u4ee5\u516c\u706d\u79c1&quot;;\u4ece\u897f\u6c49\u8d3e\u8c0a\u300a\u6d3b\u5b89\u7b56\u300b\u4e2d\u7684&quot;\u56fd\u800c\u5fd8\u5bb6\uff0c\u516c\u800c\u5fd8\u79c1&quot;\u5230\u5b8b\u4ee3\u8303\u4ef2\u6df9\u300a\u5cb3\u9633\u697c\u8bb0\u300b\u4e2d\u7684&quot;\u5148\u5929\u4e0b\u4e4b\u5fe7\uff0c\u540e\u5929\u4e0b\u4e4b\u4e50\u800c\u4e50&quot;\uff0c\u518d\u5230\u6e05\u4ee3\u6797\u5219\u5f90\u7684&quot;\u82df\u5229\u56fd\u5bb6\u751f\u6b7b\u4ee5\uff0c\u5c82\u56e0\u7978\u798f\u907f\u8d8b\u4e4b&quot;\uff0c\u8d2f\u7a7f\u5176\u4e2d\u7684\u4f20\u7edf\u7f8e\u5fb7\u662f:</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u9898\u5e72&quot;\u4ee5\u516c\u706d\u79c1&quot;\u3001&quot;\u56fd\u800c\u5fd8\u5bb6\uff0c\u516c\u800c\u5fd8\u79c1&quot;\u3001&quot;\u5148\u5929\u4e0b\u4e4b\u5fe7\u800c\u5fe7\u3002\u540e\u5929\u4e0b\u4e4b\u4e50\u800c\u4e50&quot;\u3001&quot;\u82df\u5229\u56fd\u5bb6\u751f\u6b7b\u4ee5\uff0c\u5c82\u56e0\u7978\u798f\u907f\u8d8b\u4e4b&quot;\u90fd\u4f53\u73b0\u4e86\u91cd\u89c6\u6574\u4f53\u5229\u76ca\uff0c\u5f3a\u8c03\u8d23\u4efb\u5949\u732e\uff0c\u6545\u7b54\u6848\\nC \u6b63\u786e\u3002</p>\\n\",\"options\":[\"<p>\u5f3a\u8c03\u77e5\u884c\u5408\u4e00\uff0c\u6ce8\u91cd\u8eac\u884c\u5b9e\u8df5</p>\\n\",\"<p>\u63a8\u7d22&quot;\u4ec1\u7231&quot;\u539f\u5219\uff0c\u6ce8\u91cd\u4ee5\u548c\u4e3a\u8d35</p>\\n\",\"<p>\u91cd\u89c6\u6574\u4f53\u5229\u76ca\uff0c\u5f3a\u8c03\u8d23\u4efb\u5949\u732e</p>\\n\",\"<p>\u63d0\u5021\u4eba\u4f26\u4ef7\u503c\uff0c\