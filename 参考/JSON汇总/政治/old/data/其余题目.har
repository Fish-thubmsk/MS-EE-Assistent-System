751f\u7269\u79d1\u5b66\u53d1\u73b0\u4e2d\u7684\u4f5c\u7528\u8868\u660e</p>\\n\",\"answer\":[0,1,2],\"analysis\":\"<p>\u672c\u9898\u8003\u67e5\u7684\u662f\u8ba4\u8bc6\u4e0e\u5b9e\u8df5\u7684\u77e5\u8bc6\u70b9\u3002\u5b9e\u8df5\u7684\u57fa\u672c\u5f62\u5f0f\u5305\u62ec\u7269\u8d28\u751f\u4ea7\u5b9e\u8df5\u3001\u793e\u4f1a\u653f\u6cbb\u5b9e\u8df5\u548c\u79d1\u5b66\u6587\u5316\u5b9e\u8df5\u7b49\u3002\u7269\u8d28\u751f\u4ea7\u5b9e\u8df5\u662f\u4eba\u7c7b\u6700\u57fa\u672c\u7684\u5b9e\u8df5\u6d3b\u52a8\uff0c\u56e0\u6b64D\u7684\u8bf4\u6cd5\u9519\u8bef\u3002ABC\u5728\u6559\u6750\u4e2d\u6709\u539f\u6587\u8868\u8ff0\u3002</p>\\n\",\"options\":[\"<p>\u5b9e\u8df5\u4e3b\u4f53\u3001\u5ba2\u4f53\u548c\u4e2d\u4ecb\u4e09\u8005\u7684\u6709\u673a\u7edf\u4e00\u6784\u6210\u5b9e\u8df5\u7684\u57fa\u672c\u7ed3\u6784</p>\\n\",\"<p>\u5b9e\u8df5\u7684\u4e3b\u4f53\u548c\u5ba2\u4f53\u6b63\u662f\u4f9d\u9760\u4e2d\u4ecb\u7cfb\u7edf\u624d\u80fd\u591f\u76f8\u4e92\u4f5c\u7528</p>\\n\",\"<p>\u4eba\u7c7b\u8ba4\u8bc6\u6c34\u5e73\u7684\u63d0\u9ad8\u4e0e\u5b9e\u8df5\u6761\u4ef6\u7684\u8fdb\u6b65\u6709\u7740\u76f4\u63a5\u7684\u5173\u7cfb</p>\\n\",\"<p>\u63a2\u7d22\u672a\u77e5\u4e16\u754c\u7684\u79d1\u5b66\u5b9e\u9a8c\u662f\u4eba\u7c7b\u6700\u57fa\u672c\u7684\u5b9e\u8df5\u6d3b\u52a8</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":2,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":1266,\"rightCount\":982,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":82,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":2,\"pType\":\"2\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1806,\"type\":\"2\",\"ste