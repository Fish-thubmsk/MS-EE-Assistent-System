xistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1600,\"type\":\"1\",\"stem\":\"<p>\u5927\u9769\u547d\u5931\u8d25\u540e\uff0c\u8981\u4e0d\u8981\u575a\u6301\u9769\u547d?\u5982\u4f55\u575a\u6301\u9769\u547d?\u8fd9\u662f\u6446\u5728\u4e2d\u56fd\u5171\u4ea7\u515a\u9762\u524d\u7684\u4e24\u4e2a\u5e26\u6839\u672c\u6027\u7684\u95ee\u9898\u3002\u515a\u4ece\u6b8b\u9177\u7684\u73b0\u5b9e\u4e2d\u8ba4\u8bc6\u5230\uff0c\u6ca1\u6709\u9769\u547d\u7684\u6b66\u88c5\u4e4b\u5c24\u65e0\u6cd5\u6218\u80dc\u6b66\u88c5\u7684\u53cd\u9769\u547d\uff0c\u5c31\u65e0\u6cd5\u593a\u53d6\u4e2d\u56fd\u9769\u547d\u80dc\u5229,\u5c31\u65e0\u6cd5\u6539\u53d8\u4e2d\u56fd\u4eba\u6c11\u548c\u4e2d\u534e\u6c11\u65cf\u7684\u547d\u8fd0\uff0c\u5fc5\u987b\u4ee5\u6b66\u88c5\u7684\u9769\u547d\u53cd\u5bf9\u6b66\u88c5\u7684\u53cd\u9769\u547d.\u5357\u660c\u8d77\u4e49\u6253\u54cd\u4e86\u6b66\u88c5\u53cd\u6297\u56fd\u6c11\u515a\u53cd\u52a8\u6d3e\u7684\u7b2c\u4e00\u67aa\uff0c\u8fd9\u662f\u4e2d\u56fd\u5171\u4ea7\u515a</p>\",\"answer\":[3],\"analysis\":\"<p>\u6211\u515a\u5b9e\u65bd\u571f\u5730\u9769\u547d\u662f\u516b\u4e03\u4f1a\u8bae\u4e4b\u540e\u5f00\u59cb\u7684\uff0c\u4e0d\u662f\u516b\u4e00\u5357\u660c\u8d77\u4e49\uff0cA\u9519\u3002<span style=\\\"text-decoration: underline; color: rgb(255, 0, 0);\\\">\u4e09\u6e7e\u6539\u7f16\u4ece\u7ec4\u7ec7\u4e0a\u786e\u7acb\u4e86\u515a\u5bf9\u519b\u961f\u7684\u9886\u5bfc\uff0c\u662f\u5efa\u8bbe\u65e0\u4ea7\u9636\u7ea7\u9886\u5bfc\u7684\u65b0\u578b\u4eba\u6c11\u519b\u961f\u7684\u5f00\u7aef</span>\uff0cB\u9519\u3002\u4e95\u5188\u5c71\u519c\u6751\u9769\u547d\u6839\u636e\u5730\u7684\u521b\u5efa\u662f\u5b9e\u65bd\u5de5\u519c\u6b66\u88c5\u5272\u636e\u7684\u5f00\u59cb\uff0cC\u9519\u3002\u5357\u660c\u8d77\u4e49\uff0c\u6253\u54cd\u4e86\u6b66\u88c5\u53cd\u6297\u56fd\u6c11\u515a\u53cd\u52a8\u7edf\u6cbb\u7684\