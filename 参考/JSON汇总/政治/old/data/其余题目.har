\u65e2\u662f\u51b3\u5b9a\u793e\u4f1a\u9762\u8c8c\u3001\u6027\u8d28\u548c\u53d1\u5c55\u7684\u6839\u672c\u56e0\u7d20\uff0c\u4e5f\u662f\u51b3\u5b9a\u6cd5\u5f8b\u672c\u8d28\u3001\u5185\u5bb9\u548c\u53d1\u5c55\u65b9\u5411\u7684\u6839\u672c\u56e0\u7d20\u3002\u6545\u9009\u9879\\nB \u6b63\u786e\u3002</p>\",\"options\":[\"<p>\u5730\u7406\u73af\u5883</p>\",\"<p>\u7269\u8d28\u8d44\u6599\u7684\u751f\u4ea7\u65b9\u5f0f</p>\",\"<p>\u4eba\u53e3\u56e0\u7d20</p>\",\"<p>\u7edf\u6cbb\u9636\u7ea7\u610f\u5fd7</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":4051,\"rightCount\":3361,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":5,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1605,\"type\":\"1\",\"stem\":\"<p>2021\u5e749\u670827\u65e5\u81f328\u65e5\uff0c\u4e2d\u592e\u4eba\u624d\u5de5\u4f5c\u4f1a\u8bae\u5728\u5317\u4eac\u4e3e\u884c\uff0c\u4e2d\u5171\u4e2d\u592e\u603b\u4e66\u8bb0\u3001\u56fd\u5bb6\u4e3b\u5e2d\u3001\u4e2d\u592e\u519b\u59d4\u4e3b\u5e2d\u4e60\u8fd1\u5e73\u51fa\u5e2d\u4f1a\u8bae\u5e76\u53d1\u8868\u91cd\u8981\u8bb2\u8bdd\uff0c\u5f3a\u8c03\u8981\u575a\u6301\u515a\u7ba1\u4eba\u624d\uff0c\u575a\u6301\u9762\u5411\u4e16\u754c\u79d1\u6280\u524d\u6cbf\uff0c\u9762\u5411\u7ecf\u6d4e\u4e3b\u6218\u573a\uff0c\u9762\u5411\u56fd\u5bb6\u91cd\u5927\u9700\u6c42\uff0c\u9762\u5411\u4eba\u6c11\u751f\u547d\u5065\u5eb7\uff0c\u6df1\u5165\u5b9e\u65bd\u65b0\u65f6\u4ee3\u4eba\u624d\u5f3a\u56fd\u6218\u7565\uff0c\u5168\u65b9\u4f4d\u57f9\u517b\uff0c\u5f15\u8fdb\u3001\u7528\u597d\u4eba\u624d\uff0c\u52a0\u5feb\u5efa\u8bbe(\u2003\u2003)</p>\",\"answer\":[0],\"analysis\":\"<p>\u4e2d\u592e\u4eba\u624d\u5de5\u4f5c\u4f1a\u8bae9\u670827\u65e5\u81f328\u65e5\u5728\u5317\u4eac\u53ec\u5f00\u3002\u4e2d\u5171\u4e2d\u592e\u603b\u4e66\u8bb0\u3001\u56fd\u5bb6\u4e3b\u5e2d\u3001\u4e2d\u592e\u519b\u59d4\u4e3b\u5e2d\u4e60\u8fd1\u5e73\u51fa\u5e2d\u4f1a\u8bae\u5e76\u53d1\u8868\u91cd\u8981\u8bb2\u8bdd\uff0c<span style=\\\"text-decoration: underline; color: rgb(255, 0, 0);\\\">\u5f3a\u8c03\u8981\u575a\u6301\u515a\u7ba1\u4eba\u624d\uff0c\u575a\u6301\u9762\u5411\u4e16\u754c\u79d1\u6280\u524d\u6cbf\u3001\u9762\u5411\u7ecf\u6d4e\u4e3b\u6218\u573a\u3001\u9762\u5411\u56fd\u5bb6\u91cd\u5927\u9700\u6c42\u3001\u9762\u5411\u4eba\u6c11\u751f\u547d\u5065\u5eb7\uff0c\u6df1\u5165\u5b9e\u65bd\u65b0\u65f6\u4ee3\u4eba\u624d\u5f3a\u56fd\u6218\u7565\uff0c\u5168\u65b9\u4f4d\u57f9\u517b\u3001\u5f15\u8fdb\u3001\u7528\u597d\u4eba\u624d\uff0c\u52a0\u5feb\u5efa\u8bbe\u4e16\u754c\u91cd\u8981\u4eba\u624d\u4e2d\u5fc3\u548c\u521b\u65b0\u9ad8\u5730</span>\uff0c\u4e3a2035\u5e74\u57fa\u672c\u5b9e\u73b0\u793e\u4f1a\u4e3b\u4e49\u73b0\u4ee3\u5316\u63d0\u4f9b\u4eba\u624d\u652f\u6491\uff0c\u4e3a2050\u5e74\u5168\u9762\u5efa\u6210\u793e\u4f1a\u4e3b\u4e49\u73b0\u4ee3\u5316\u5f3a\u56fd\u6253\u597d\u4eba\u624d\u57fa\u7840\u3002\u56e0\u6b64\uff0c\u672c\u9898\u6b63\u786e\u9009\u9879\u4e3a A\u3002</p>\",\"options\":[\"<p>\u4e16\u754c\u91cd\u8981\u4eba\u624d\u4e2d\u5fc3\u548c\u521b\u65b0\u9ad8\u5730</p>\\n\",\"<p>\u5317\u4eac\u3001\u4e0a\u6d77\u7ca4\u6e2f\u6fb3\u5927\u6e7e\u533a\u9ad8\u6c34\u5e73\u4eba\u624d\u9ad8\u5730</p>\\n\",\"<p>\u4e00\u6279\u56fd\u5bb6\u5b9e\u9a8c\u5ba4\u548c\u65b0\u578b\u7814\u53d1\u673a\u6784</p>\\n\",\"<p>\u4e2d\u5fc3\u57ce\u5e02\u5438\u5f15\u548c\u805a\u96c6\u4eba\u624d\u7684\u5e73\u53f0</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":3946,\"rightCount\":2639,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1606,\"type\":\"1\",\"stem\":\"<p>\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u53cd\u5916\u56fd\u5236\u88c1\u6cd5\u300b\u4e8e2021\u5e746\u670810\u65e5\u8d77\u65bd\u884c\u3002\u8fd9\u662f\u4e00\u90e8\u6307\u5411\u6027\u3001\u9488\u5bf9\u6027\u9887\u5f3a\u7684\u4e13\u95e8\u6cd5\u5f8b\uff0c\u5171\u670916\u6761\uff0c\u8fd9\u90e8\u6cd5\u5f8b\u4e3b\u8981\u9488\u5bf9\u7684\u662f (\u2003)</p>\",\"answer\":[3],\"analysis\":\"<p>\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u53cd\u5916\u56fd\u5236\u88c1\u6cd5\u300b\u4e8e2021\u5e746\u670810\u65e5\u8d77\u65bd\u884c\uff0c\u8fd9\u90e8\u6cd5\u5f8b\u4e3b\u8981\u9488\u5bf9\u7684\u662f\u5916\u56fd\u5e72\u6d89\u4e2d\u56fd\u5185\u653f\u7684\u6240\u8c13&quot;\u5355\u8fb9\u5236\u88c1&quot;\uff0c\u4e3a\u6211\u56fd\u91c7\u53d6\u76f8\u5e94\u53cd\u5236\u63aa\u65bd\u63d0\u4f9b\u6cd5\u6cbb\u652f\u6491\u548c\u6cd5\u6cbb\u4fdd\u969c\u3002\u8fd9\u610f\u5473\u7740\uff0c<span style=\\\"text-decoration: underline; color: #FF0000;\\\">\u4e2d\u56fd\u5c06\u4ece\u56fd\u5bb6\u7acb\u6cd5\u7684\u9ad8\u5ea6\u548c\u529b\u5ea6\uff0c\u8fdb\u884c\u66f4\u7cfb\u7edf\u3001\u66f4\u5f7b\u5e95\u3001\u66f4\u6709\u529b\u7684\u53cd\u5236\uff0c\u4ee5\u634d\u536b\u56fd\u5bb6\u5c0a\u4e25\u548c\u6838\u5fc3\u5229\u76ca</span>\u3002\u6545\u672c\u9898\u6b63\u786e\u7b54\u6848\u4e3aD\u3002</p>\",\"options\":[\"<p>\u897f\u65b9\u67d0\u4e9b\u5927\u56fd\u8fd1\u5e74\u5bf9\u6211\u56fd\u7684&quot;\u8d38\u6613\u6218&quot;</p>\",\"<p>\u5c11\u6570\u56fd\u5bb6\u64cd\u7eb5\u56fd\u9645\u7ec4\u7ec7\u6311\u8d77\u7684&quot;\u8d27\u5e01\u6218&quot;</p>\",\"<p>\u8d44\u672c\u4e3b\u4e49\u5927\u56fd\u5bf9\u793e\u4f1a\u4e3b\u4e49\u56fd\u5bb6\u7684&quot;\u65b0\u6311\u6218&quot;</p>\",\"<p>\u5916\u56fd\u5e72\u6d89\u4e2d\u56fd\u5185\u653f\u7684\u6240\u8c13&quot;\u5355\u8fb9\u5236\u88c1&quot;</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":3965,\"rightCount\":2384,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":6,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1607,\"type\":\"2\",\"stem\":\"<p>\u5728\u6df1\u5165\u63a8\u52a8\u9ec4\u6cb3\u6d41\u57df\u751f\u6001\u4fdd\u62a4\u548c\u9ad8\u8d28\u91cf\u53d1\u5c55\u5ea7\u8c08\u4f1a\u4e0a\uff0c\u4e60\u8fd1\u5e73\u603b\u4e66\u8bb0\u8c08\u53ca\u6c34\u8d44\u6e90\u548c\u53d1\u5c55\u7684\u5173\u7cfb\u65f6\uff0c\u4ee5\u4f20\u7edf\u540d\u5403&quot;\u7f8a\u8089\u6ce1\u998d&quot;\u4f5c\u5f62\u8c61\u6bd4\u55bb\uff0c\u5f3a\u8c03\u8981\u5168\u65b9\u4f4d\u8d2f\u5f7b&quot;\u56db\u6c34\u56db\u5b9a&quot;\uff08\u4ee5\u6c34\u5b9a\u57df\u3001\u4ee5\u6c34\u5b9a\u5730\u3001\u4ee5\u6c34\u5b9a\u4eba\u3001\u4ee5\u6c34\u5b9a\u4ea7\uff09\u539f\u5219\uff0c\u7cbe\u6253\u7ec6\u7b97\u7528\u597d\u6c34\u8d44\u6e90\uff0c&quot;\u6709\u591a\u5c11\u6c64\u6ce1\u591a\u5c11\u998d&quot;\uff0c\u8ba9\u6c34\u8d44\u6e90\u7528\u5728\u6700\u8be5\u7528\u7684\u5730\u65b9\u3002&quot;\u6709\u591a\u5c11\u6c64\u6ce1\u591a\u5c11\u998d&quot;\u8574\u542b\u7684\u54f2\u5b66\u9053\u7406\u662f(\u2003\u2003)\u3002</p>\",\"answer\":[1,2,3],\"analysis\":\"<p>\u672c\u9898\u8003\u67e5<span style=\\\"text-decoration: underline; color: #FF0000;\\\">\u4e3b\u89c2\u80fd\u52a8\u6027\u548c\u5ba2\u89c2\u89c4\u5f8b\u6027\u7684\u7edf\u4e00</span>\u3002\u6839\u636e\u9898\u5e72\u4e2d:\u5f3a\u8c03\u8981\u5168\u65b9\u4f4d\u8d2f\u5f7b&quot;\u56db\u6c34\u56db\u5b9a&quot;(\u4ee5\u6c34\u5b9a\u57ce\u3001\\n\u4ee5\u6c34\u5b9a\u5730\u3001\u4ee5\u6c34\u5b9a\u4eba\u3001\u4ee5\u6c34\u5b9a\u4ea7)\u539f\u5219\uff0c\u7cbe\u6253\u7ec6\u7b97\u7528\u597d\u6c34\u8d44\u6e90\uff0c&quot;\u6709\u591a\u5c11\u6c64\u6ce1\u591a\u5c11\u998d&quot;\u4f53\u73b0\u4e86\u4e00\u5207\u4ece\u5b9e\u9645\u51fa\u53d1\uff0c\u5b9e\u4e8b\u6c42\u662f\uff0c\u5c0a\u91cd\u5ba2\u89c2\u89c4\u5f8b\uff0c\u628a\u63e1\u9002\u5ea6\u539f\u5219\uff0c\u56e0\u5730\u5236\u5b9c\uff0c\u56e0\u65f6\u5236\u5b9c\uff0c\u4ee5\u53ca\u521b\u9020\u6709\u5229\u6761\u4ef6\uff0c\u6545\u9009 BCD\u3002</p>\",\"options\":[\"<p>\u521b\u9020\u6761\u4ef6\uff0c\u5145\u5206\u53d1\u6325\u610f\u8bc6\u80fd\u52a8\u6027</p>\",\"<p>\u4e00\u5207\u4ece\u5b9e\u9645\u51fa\u53d1\uff0c\u5b9e\u4e8b\u6c42\u662f</p>\",\"<p>\u56e0\u5730\u5236\u5b9c\uff0c\u56e0\u65f6\u5236\u5b9c</p>\",\"<p>\u5c0a\u91cd\u89c4\u5f8b\uff0c\u628a\u63e1\u9002\u5ea6\u539f\u5219</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":2,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":8,\"studCount\":4027,\"rightCount\":2973,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":7,\"pType\":\"2\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1608,\"type\":\"2\",\"stem\":\"<p>\u4eba\u7c7b\u5386\u53f2\u4e0a\u7684\u6bcf\u4e00\u6b21\u79d1\u6280\u9769\u547d\u90fd\u4e0e\u6750\u6599\u7684\u53d1\u5c55\u606f\u606f\u76f8\u5173\uff0c\u800c\u65b0\u6750\u6599\u7684\u7814\u5236\u5374\u662f\u9887\u4e3a\u4e0d\u6613\u7684\uff0c\u4eba\u5de5\u667a\u80fd\u53ef\u4ee5\u501f\u52a9\u6570\u636e\u5171\u4eab\uff0c\u5bf9\u5148\u8fdb\u6750\u6599\u7684\u7269\u7406\u5316\u5b66\u6027\u8d28\u8fdb\u884c\u9884\u6d4b\u7b5b\u9009\uff0c\u4ece\u800c\u52a0\u5feb\u65b0\u6750\u6599\u7684\u5408\u6210\u548c\u751f\u4ea7\uff0c\u4f5c\u4e3a\u4eba\u5de5\u667a\u80fd\u7684\u4e00\u4e2a\u5206\u652f\uff0c\u673a\u5668\u5b66\u4e60\u7b97\u6cd5\u5728\u8f85\u52a9\u65b0\u6750\u6599\u8bbe\u8ba1\u65f6\u5c24\u4e3a&quot;\u5f97\u529b&quot;\uff0c\u5176\u5de5\u4f5c\u8fc7\u7a0b\u4e3b\u8981\u5305\u62ec&quot;\u63cf\u8ff0\u7b26&quot;\u751f\u6210\u3001\u6a21\u578b\u6784\u5efa\u548c\u9a8c\u8bc1\u3001\u6750\u6599\u9884\u6d4b\u3001\u5b9e\u9a8c\u9a8c\u8bc1\u7b49\u6b65\u9aa4\u3002\u4eba\u5de5\u667a\u80fd\u8f85\u52a9\u65b0\u6750\u6599\u7814\u53d1\u7684\u8fc7\u7a0b\u8868\u660e(\u2003\u2003)\u3002</p>\",\"answer\":[2,3],\"analysis\":\"<p>\u672c\u9898\u4e3b\u8981\u8003\u67e5\u8ba4\u8bc6\u7684\u4f5c\u7528\u3002\u79d1\u5b66\u7814\u7a76\u4e0d\u80fd\u591f\u4efb\u610f\u6539\u53d8\u7269\u8d28\u7684\u6027\u8d28\u548c\u7ed3\u6784\uff0c\u9009\u9879A\u9519\u8bef\u3002</p><p>\u4eba\u5de5\u667a\u80fd\u53ea\u662f\u610f\u8bc6\u7684\u5916\u5316\u8868\u73b0\uff0c\u662f\u610f\u8bc6\u7684\u4ea7\u7269\uff0c\u5b83\u4e0d\u80fd\u53d6\u4ee3\u4eba\u7c7b\u5bf9\u7269\u8d28\u4e16\u754c\u7684\u8ba4\u8bc6\uff0c\u9009\u9879B\u9519\u8bef\u3002\u65b0\u6750\u6599\u7684\u7814\u5236\u662f\u4e0d\u6613\u7684\uff0c\u9700\u8981\u7ecf\u8fc7\u957f\u671f\u7684\u7814\u7a76\u3001\u9884\u6d4b\uff0c\u4eba\u7c7b\u7684\u8ba4\u8bc6\u8fc7\u7a0b\u4e5f\u662f\u4e00\u4e2a\u4e0d\u65ad\u6df1\u5165\u7684\u8fc7\u7a0b\uff0c\u9009\u9879C\u6b63\u786e\u3002<span style=\\\"color: rgb(255, 0, 0); text-decoration: underline;\\\">\u4e16\u754c\u7684\u672c\u539f\u662f\u7269\u8d28\uff0c\u7269\u8d28\u7684\u5171\u540c\u7279\u6027\u662f\u5ba2\u89c2\u5b9e\u5728\u6027\uff0c\u6240\u4ee5\u5177\u4f53\u7684\u7269\u8d28\u7ed3\u6784\u548c\u6027\u8d28\u7684\u53d8\u5316\u4e0d\u4f1a\u6539\u53d8\u4e16\u754c\u7684\u7269\u8d28\u6027</span>\uff0c\u9009\u9879D\u6b63\u786e\u3002</p>\",\"options\":[\"<p>\u79d1\u5b66\u7814\u7a76\u80fd\u591f\u4efb\u610f\u6539\u53d8\u7269\u8d28\u7684\u6027\u8d28\u7ed3\u6784</p>\",\"<p>\u4eba\u5de5\u667a\u80fd\u80fd\u591f\u53d6\u4ee3\u4eba\u7c7b\u5bf9\u7269\u8d28\u4e16\u754c\u7684\u8ba4\u8bc6</p>\",\"<p>\u4eba\u7c7b\u5bf9\u7269\u8d28\u7684\u8ba4\u8bc6\u662f\u4e00\u4e2a\u4e0d\u65ad\u6df1\u5316\u7684\u8fc7\u7a0b</p>\",\"<p>\u5177\u4f53\u7684\u7269\u8d28\u7ed3\u6784\u548c\u6027\u8d28\u7684\u53d8\u5316\u5e76\u4e0d\u6539\u53d8\u4e16\u754c\u7684\u7269\u8d28\u6027</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":2,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":3851,\"rightCount\":3717,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":1,\"pType\":\"2\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1609,\"type\":\"2\",\"stem\":\"<p>\u65f6\u95f4\u662f\u4e07\u4e8b\u4e07\u7269\u5b58\u5728\u7684\u523b\u5ea6\uff0c1\u79d2\u949f\uff0c\u7535\u5f71\u653e\u662024\u5e27\u753b\u9762\uff0c\u730e\u8c79\u5728\u8349\u539f\u4e0a\u98de\u595428\u7c73\uff0c\u8702\u9e1f\u632f\u52a8\u7fc5\u818055\u6b21;1\u5206\u949f\uff0c\u767b\u5c71\u961f\u5458\u6500\u767b\u73e0\u5cf0\u9876\u5cf058.3\u5398\u7c73\uff0c&quot;\u590d\u5174\u53f7&quot;\u524d\u8fdb5833\u7c73\u3002\u65f6\u95f4\u521b\u9020\u65e0\u9650\u53ef\u80fd\u3002\u6709\u4eba\u52aa\u529b\u5954\u8dd1\uff0c\u7528\u5168\u529b\u4ee5\u8d74\u7684\u51b2\u523a\u7a81\u7834\u6781\u9650;\u6709\u4eba\u7825\u783a\u524d\u884c\uff0c\u4ee5\u65e5\u590d\u4e00\u65e5\u7684\u575a\u5b88\u8f9b\u52e4\u8015\u8018\u3002\u539f\u672c\u5300\u901f\u6d41\u52a8\u7684\u65f6\u95f4\uff0c\u6b63\u662f\u5728\u751f\u751f\u4e0d\u606f\u7684\u594b\u6597\u4e2d\uff0c\u5728\u6602\u626c\u594b\u53d1\u7684\u8fdb\u53d6\u4e2d\uff0c\u786e\u5b9a\u610f\u4e49\u3001\u4f53\u73b0\u4ef7\u503c\u3001\u8fdb\u800c\u5b9a\u4e49\u751f\u547d\u7684\u7cbe\u5f69\u3001\u5b9a\u683c\u5386\u53f2\u7684\u8109\u52a8\u3002\u4eba\u4eec\u5728\u594b\u6597\u4e2d&quot;\u5b9a\u4e49&quot;\u65f6\u95f4\uff0c\u8bf4\u660e\u65f6\u95f4\u662f\uff08\u2003\u2003\uff09\u3002</p>\",\"answer\":[0,1,3],\"analysis\":\"<p><span style=\\\"text-decoration: underline; color: rgb(255, 0, 0);\\\">\u7269\u8d28\u8fd0\u52a8\u603b\u662f\u5728\u4e00\u5b9a\u7684\u65f6\u95f4\u548c\u7a7a\u95f4\u4e2d\u8fdb\u884c\u7684\uff0c\u6ca1\u6709\u79bb\u5f00\u7269\u8d28\u8fd0\u52a8\u7684&quot;\u7eaf\u7cb9&quot;\u65f6\u95f4\u548c\u7a7a\u95f4\uff0c\u4e5f\u6ca1\u6709\u79bb\u5f00\u65f6\u95f4\u548c\u7a7a\u95f4\u7684\u7269\u8d28\u8fd0\u52a8</span>\u3002\u7269\u8d28\u8fd0\u52a8\u4e0e\u65f6\u95f4\u548c\u7a7a\u95f4\u7684\u4e0d\u53ef\u5206\u5272\uff0c\u8bc1\u660e\u4e86\u65f6\u95f4\u548c\u7a7a\u95f4\u7684\u5ba2\u89c2\u6027\u3002\u5177\u4f53\u7269\u8d28\u5f62\u6001\u7684\u65f6\u7a7a\u662f\u6709\u9650\u7684\uff0c\u800c\u6574\u4e2a\u7269\u8d28\u4e16\u754c\u7684\u65f6\u7a7a\u662f\u65e0\u9650\u7684\u3002\u6545C\u9519\u8bef\u3002AD\u6b63\u786e\u3002</p><p>\u65f6\u95f4\u548c\u7a7a\u95f4\u662f\u7269\u8d28\u8fd0\u52a8\u7684\u5b58\u5728\u5f62\u5f0f\uff0c\u65f6\u95f4\u662f\u6307\u7269\u8d28\u8fd0\u52a8\u7684\u6301\u7eed\u6027\u3001\u987a\u5e8f\u6027\uff0c\u7279\u70b9\u662f\u4e00\u7ef4\u6027\u3002\u6545B\u6b63\u786e\u3002</p>\",\"options\":[\"<p>\u6d4b\u91cf\u4e8b\u7269\u8fd0\u52a8\u7684\u5ba2\u89c2\u5c3a\u5ea6</p>\",\"<p>\u7269\u8d28\u8fd0\u52a8\u7684\u5b58\u5728\u5f62\u5f0f</p>\",\"<p>\u4e8b\u7269\u8fd0\u52a8\u7684\u4e3b\u89c2\u8054\u60f3</p>\",\"<p>\u4e0e\u7269\u8d28\u8fd0\u52a8\u4e0d\u53ef\u5206\u5272\u7684</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":2,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":4,\"studCount\":3923,\"rightCount\":2786,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"2\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1610,\"type\":\"2\",\"stem\":\"<p>\u5982\u4eca\uff0c&quot;\u9006\u88ad&quot;&quot;\u8d85\u7136&quot;&quot;\u8eba\u5e73&quot;&quot;\u51e1\u5c14\u8d5b&quot;&quot;YYDS&quot;\u7b49\u7f51\u7edc\u70ed\u8bcd\u4ee4\u4eba\u76ee\u4e0d\u6687\u63a5\uff0c\u4e86\u89e3\u8fd9\u4e9b\u7f51\u7edc\u8bdd\u7684\u610f\u601d\u7528\u6cd5\uff0c\u51e0\u4e4e\u6210\u4e86\u7f51\u4e0a\u51b2\u6d6a\u7684\u5fc5\u4fee\u8bfe\u3002\u5d4c\u5165\u65e5\u5e38\u751f\u6d3b\u4ea4\u6d41\u7684\u7f51\u7edc\u70ed\u8bcd\uff0c\u4e3a\u8bed\u8a00\u7684\u53d1\u5c55\u5e26\u6765\u65b0\u8bed\u6599\uff0c\u4e5f\u80fd\u591f\u8ba9\u4eba\u4eec\u4e00\u7aa5\u5f53\u4e0b\u7684\u793e\u4f1a\u751f\u6d3b\u548c\u793e\u4f1a\u5fc3\u6001\u3002\u7f51\u7edc\u70ed\u8bcd\u6d41\u884c\u7684\u73b0\u8c61\u8868\u660e\uff08\u2003\u2003\uff09\u3002</p>\",\"answer\":[0,1],\"analysis\":\"<p>\u672c\u9898\u4e3b\u8981\u8003\u67e5<span style=\\\"text-decoration: underline; color: rgb(255, 0, 0);\\\">\u793e\u4f1a\u5b58\u5728\u548c\u793e\u4f1a\u610f\u8bc6\u7684\u8fa9\u8bc1\u5173\u7cfb</span>\u3002\u793e\u4f1a\u5b58\u5728\u51b3\u5b9a\u793e\u4f1a\u610f\u8bc6\uff0c\u793e\u4f1a\u610f\u8bc6\u662f\u5bf9\u793e\u4f1a\u5b58\u5728\u7684\u80fd\u52a8\u53cd\u6620\u3002\u6545A\u6b63\u786e\u3002\u793e\u4f1a\u5b58\u5728\u51b3\u5b9a\u793e\u4f1a\u610f\u8bc6\uff0c\u793e\u4f1a\u610f\u8bc6\u968f\u7740\u793e\u4f1a\u5b58\u5728\u7684\u53d1\u5c55\u800c\u53d8\u5316\uff0c\u6545B\u6b63\u786e\u3002\u793e\u4f1a\u610f\u8bc6\u662f\u4e3b\u4f53\u5bf9\u793e\u4f1a\u751f\u6d3b\u81ea\u89c9\u7684\u80fd\u52a8\u7684\u53cd\u6620\uff0c\u4e0d\u662f\u81ea\u53d1\u53cd\u6620\uff0c\u6545C\u9519\u8bef\u3002\u793e\u4f1a\u5b58\u5728\u51b3\u5b9a\u793e\u4f1a\u751f\u6d3b\u7684\u591a\u6837\u6027\uff0c\u6545D\u9519\u8bef\u3002</p>\",\"options\":[\"<p>\u793e\u4f1a\u5fc3\u6001\u662f\u793e\u4f1a\u751f\u4ea7\u548c\u751f\u6d3b\u7684\u53cd\u6620</p>\",\"<p>\u793e\u4f1a\u610f\u8bc6\u968f\u7740\u793e\u4f1a\u5b58\u5728\u7684\u53d1\u5c55\u800c\u53d8\u5316</p>\",\"<p>\u793e\u4f1a\u610f\u8bc6\u662f\u4e3b\u4f53\u5bf9\u793e\u4f1a\u751f\u6d3b\u81ea\u53d1\u53cd\u6620</p>\",\"<p>\u793e\u4f1a\u5f62\u6001\u7684\u5dee\u5f02\u6027\u51b3\u5b9a\u793e\u4f1a\u751f\u4ea7\u7684\u591a\u6837\u6027</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":2,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":11,\"studCount\":4036,\"rightCount\":1697,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":76,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":26,\"pType\":\"2\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1611,\"type\":\"2\",\"stem\":\"<p>\u9a6c\u514b\u601d\u3001\u6069\u683c\u65af\u5728\u300a\u5171\u4ea7\u515a\u5ba3\u8a00\u300b\u4e2d\u6307\u51fa:&quot;\u8d44\u4ea7\u9636\u7ea7\u5728\u5b83\u7684\u4e0d\u5230\u4e00\u767e\u5e74\u7684\u9636\u7ea7\u7edf\u6cbb\u4e2d\u6240\u521b\u9020\u7684\u751f