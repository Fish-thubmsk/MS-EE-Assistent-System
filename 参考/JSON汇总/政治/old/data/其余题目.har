uster2.1", "name":"x-cluster"}, {"value":"gzip", "name":"content-encoding"}, {"value":"*", "name":"access-control-allow-origin"}, {"value":"true", "name":"access-control-allow-credentials"}, {"value":"POST,GET,OPTIONS,DELETE,PUT,PATCH", "name":"access-control-request-method"}, {"value":"POST,GET,OPTIONS,DELETE,PUT,PATCH", "name":"access-control-allow-methods"}], "cookies":[], "redirectURL":"", "statusText":"200", "status":200, "httpVersion":"HTTP/2", "content":{"text":"{\"count\":17,\"totalPages\":1,\"pageSize\":17,\"currentPage\":1,\"data\":{\"questions\":[{\"id\":12049,\"type\":\"2\",\"stem\":\"<p>\u9a6c\u514b\u601d\u3001\u6069\u683c\u65af\u5728\u9886\u5bfc\u65e0\u4ea7\u9636\u7ea7\u6597\u4e89\u7684\u5b9e\u8df5\u4e2d\uff0c\u59cb\u7ec8\u5f3a\u8c03\u9886\u8896\u6743\u5a01\u7684\u5fc5\u8981\u6027\u548c\u91cd\u8981\u6027\u3002\u9a6c\u514b\u601d\u8bf4\u8fc7\uff0c&quot;\u4e00\u4e2a\u5355\u72ec\u7684\u63d0\u7434\u624b\u662f\u81ea\u5df1\u6307\u6325\u81ea\u5df1\uff0c\u4e00\u4e2a\u4e50\u961f\u5c31\u9700\u8981\u4e00\u4e2a\u4e50\u961f\u6307\u6325\u3002&quot;\u6069\u683c\u65af\u4e5f\u6307\u51fa\uff0c&quot;\u6ca1\u6709\u6743\u5a01\uff0c\u5c31\u4e0d\u53ef\u80fd\u6709\u4efb\u4f55\u7684\u4e00\u81f4\u884c\u52a8&quot;\u3002\u5e76\u4ee5\u5927\u6d77\u822a\u884c\u7684\u4f8b\u5b50\u8bf4\u660e\u6743\u5a01\u7684\u91cd\u8981\u6027\u3002\u5728\u603b\u7ed3\u5df4\u9ece\u516c\u793e\u5931\u8d25\u7684\u7ecf\u9a8c\u6559\u8bad\u65f6\uff0c\u9a6c\u514b\u601d\u6df1\u523b\u6307\u51fa\uff0c\u9769\u547d\u80dc\u5229\u540e\u7ec4\u7ec7\u65b0\u653f\u6743\u3001\u7ef4\u62a4\u65b0\u653f\u6743\u3001\u5efa\u8bbe\u65b0\u653f\u6743\u90fd\u9700\u8981\u6743\u5a01\u3002\u6069\u683c\u65af\u5219\u660e\u786e\u6307\u51fa\uff0c&quot;\u5df4\u9ece\u516c\u793e\u906d\u5230\u706d\u4ea1\uff0c\u5c31\u662f\u7531\u4e8e\u7f3a\u4e4f\u96c6\u4e2d\u548c\u6743\u5a01&quot;\u3002\u8fd9\u8868\u660e\uff0c\u65e0\u4ea7\u9636\u7ea7\u9886\u8896\u5728\u5386\u53f2\u4e0a\u80fd\u591f</p>\\n\",\"answer\":[0,1,2],\"analysis\":\"<p><span style=\\\"text-decoration: underline; color: rgb(0, 176, 240); background-color: rgb(253, 234, 218);\\\">\u672c\u9898\u8003\u67e5\u4e2a\u4eba\u5728\u793e\u4f1a\u5386\u53f2\u4e2d\u7684\u4f5c\u7528</span>\u3002</p><p><span style=\\\"color: rgb(255, 0, 0); text-decoration: underline;\\\">\u65e0\u4ea7\u9636\u7ea7\u9886\u8896\u5728\u5386\u53f2\u4e0a\u6240\u63d0\u51fa\u7684\u601d\u60f3\u80fd\u591f\u6210\u4e3a\u793e\u4f1a\u53d8\u9769\u7684\u5148\u5bfc\uff0c\u5f15\u9886\u793e\u4f1a\u53d1\u5c55\u7684\u65b9\u5411</span>\u3002\u80fd\u591f\u5f71\u54cd\u5386\u53f2\u4e8b\u4ef6\u7684\u8fdb\u7a0b\uff0c\u51dd\u805a\u4eba\u6c11\u7fa4\u4f17\u7684\u529b\u91cf\u3002\u6545ABC\u8bf4\u6cd5\u6b63\u786e\uff0c\u4f46\u662f\uff0c\u4e0d\u80fd\u521b\u9020\u4eba\u7c7b\u793e\u4f1a\u7684\u5386\u53f2\uff0c\u4e0d\u7ba1\u4ec0\u4e48\u6837\u7684\u5386\u53f2\u4eba\u7269\uff0c\u5728\u5386\u53f2\u4e0a\u53d1\u6325\u4ec0\u4e48\u6837\u7684\u4f5c\u7528\uff0c\u90fd\u8981\u53d7\u5230\u793e\u4f1a\u53d1\u5c55\u5ba2\u89c2\u89c4\u5f8b\u7684\u5236\u7ea6\u800c\u4e0d\u80fd\u51b3\u5b9a\u548c\u6539\u53d8\u5386\u53f2\u53d1\u5c55\u7684\u603b\u8fdb\u7a0b\u548c\u603b\u65b9\u5411\uff0c\u6240\u4ee5\u4e0d\u80fd\u521b\u9020\u4eba\u7c7b\u793e\u4f1a\u7684\u5386\u53f2\u3002</p><p>\u6545\u9009\u9879D\u8bf4\u6cd5\u9519\u8bef\uff0c\u672c\u9898<span style=\\\"color: rgb(0, 176, 80);\\\"><strong>\u6b63\u786e\u9009\u9879\u4e3aABC</strong></span>\u3002</p>\",\"options\":[\"<p>\u5f15\u9886\u793e\u4f1a\u53d1\u5c55\u7684\u65b9\u5411</p>\\n\",\"<p>\u5f71\u54cd\u5386\u53f2\u4e8b\u4ef6\u7684\u8fdb\u7a0b</p>\\n\",\"<p>\u51dd\u805a\u4eba\u6c11\u7fa4\u4f17\u7684\u529b\u91cf</p>\\n\",\"<p>\u521b\u9020\u4eba\u7c7b\u793e\u4f1a\u7684\u5386\u53f2</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":6,\"studCount\":6125,\"rightCount\":3267,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":985,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":