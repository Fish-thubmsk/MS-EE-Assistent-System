nt-type,x-token,x-agent,x-platform,x-systemType,Authorization,x-sign,x-timestamp,x-appid", "name":"access-control-allow-headers"}, {"value":"theme,x-server-id,x-server-time", "name":"access-control-expose-headers"}, {"value":"#67cfcf", "name":"theme"}, {"value":"sae_3", "name":"x-server-id"}, {"value":"1774972760", "name":"x-server-time"}, {"value":"cluster2.1", "name":"x-cluster"}, {"value":"gzip", "name":"content-encoding"}, {"value":"*", "name":"access-control-allow-origin"}, {"value":"true", "name":"access-control-allow-credentials"}, {"value":"POST,GET,OPTIONS,DELETE,PUT,PATCH", "name":"access-control-request-method"}, {"value":"POST,GET,OPTIONS,DELETE,PUT,PATCH", "name":"access-control-allow-methods"}], "cookies":[], "redirectURL":"", "statusText":"200", "status":200, "httpVersion":"HTTP/2", "content":{"text":"{\"count\":33,\"totalPages\":1,\"pageSize\":33,\"currentPage\":1,\"data\":{\"questions\":[{\"id\":1756,\"type\":\"1\",\"stem\":\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u4ea7\u751f\u5177\u6709\u6df1\u523b\u7684\u793e\u4f1a\u6839\u6e90\u3001\u9636\u7ea7\u57fa\u7840\u548c\u601d\u60f3\u6e0a\u6e90\u3002\u5176\u521b\u59cb\u4eba\u9a6c\u514b\u601d1818\u5e745\u67085\u65e5\u51fa\u751f\u5728\u5fb7\u56fd\u7279\u5229\u5c14\u57ce\u7684\u4e00\u4e2a\u5f8b\u5e08\u5bb6\u5ead\uff0c\u6069\u683c\u65af1820\u5e7411\u670828\u65e5\u51fa\u751f\u5728\u5fb7\u56fd\u5df4\u95e8\u5e02\u7684\u4e00\u4e2a\u5de5\u5382\u4e3b\u5bb6\u5ead\uff0c\u4ed6\u4eec\u653e\u5f03\u4e86\u8212\u9002\u5b89\u9038\u7684\u751f\u6d3b\uff0c\u6bc5\u7136\u9009\u62e9\u4e86\u5145\u6ee1\u8346\u68d8\u574e\u5777\u7684\u9769\u547d\u9053\u8def\uff0c\u521b\u7acb\u4e86\u79d1\u5b66\u793e\u4f1a\u4e3b\u4e49\u3002\u9a6c\u514b\u601d\u3001\u6069\u683c\u65af\u4e4b\u6240\u4ee5\u80fd\u591f\u521b\u7acb\u79d1\u5b66\u793e\u4f1a\u4e3b\u4e49\uff0c\u4e3b\u8981\u662f\u56e0\u4e3a</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u4ea7\u751f\u4e8e19\u4e16\u7eaa40\u5e74\u4ee3\u3002\u9a6c\u514b\u601d\u4e3b\u4e49\u662f\u65f6\u4ee3\u7684\u4ea7\u7269\uff0c\u5b83\u7684\u4ea7\u751f\u6709\u5176\u6df1\u523b\u7684\u793e\u4f1a\u6839\u6e90\u3001\u9636\u7ea7\u57fa\u7840\u548c\u601d\u60f3\u6e0a\u6e90\u3002\u9996\u5148\uff0c\u8d44\u672c\u4e3b\u4e49\u7ecf\u6d4e\u7684\u53d1\u5c55\u4e3a\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u4ea7\u751f\u63d0\u4f9b\u4e86\u7ecf\u6d4e\u3001\u793e\u4f1a\u5386\u53f2\u6761\u4ef6\u3002\u5176\u6b21\uff0c\u65e0\u4ea7\u9636\u7ea7\u53cd\u5bf9\u8d44\u4ea7\u9636\u7ea7\u7684\u6597\u4e89\u65e5\u8d8b\u6fc0\u5316\uff0c\u5bf9\u79d1\u5b66\u7406\u8bba\u7684\u6307\u5bfc\u63d0\u51fa\u4e86\u5f3a\u70c8\u7684\u9700\u6c42\u3002\u518d\u6b21\uff0c\u9a6c\u514b\u601d\u3001\u6069\u683c\u65af\u7684\u9769\u547d\u5b9e\u8df5\u548c\u5bf9\u4eba\u7c7b\u6587\u660e\u6210\u679c\u7684\u7ee7\u627f\u4e0e\u521b\u65b0\u3002\u8d44\u672c\u4e3b\u4e49\u7ecf\u6d4e\u793e\u4f1a\u7684\u53d1\u5c55\u53ca\u5176\u77db\u76fe\u8fd0\u52a8\uff0c\u4e3a\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u4ea7\u751f\u63d0\u4f9b\u4e86\u5ba2\u89c2\u6761\u4ef6\uff0c\u65e0\u4ea7\u9636\u7ea7\u4e0e\u8d44\u4ea7\u9636\u7ea7\u7684\u6597\u4e89\u5bf9\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u4ea7\u751f\u63d0\u51fa\u4e86\u73b0\u5b9e\u9700\u6c42\uff0c\u8fd9\u4e9b\u90fd\u662f\u9a6c\u514b\u601d\u4e3b\u4e49\u4ea7\u751f\u7684\u65f6\u4ee3\u548c\u5b9e\u8df5\u57fa\u7840\u3002\u8fd9\u4e9b\u5ba2\u89c2\u6761\u4ef6\u53ea\u662f\u4e3a\u9a6c\u514b\u601d\u4e3b\u4e49\u4ea7\u751f\u63d0\u4f9b\u4e86\u53ef\u80fd\u6027\uff0c\u800c\u8fd9\u4e9b\u53ef\u80fd\u6027\u53ea\u6709\u901a\u8fc7\u9a6c\u514b\u601d\u3001\u6069\u683c\u65af\u7684\u9769\u547d\u5b9e\u8df5\u548c\u5bf9\u4eba\u7c7b\u6587\u660e\u6210\u679c\u7684\u7ee7\u627f\u4e0e\u521b\u65b0\uff0c\u624d\u4f1a\u53d8\u6210\u73b0\u5b9e\u3002\u9a6c\u514b\u601d\u4e3b\u4e49\u662f\u5728\u5438\u6536\u4e86\u51e0\u5343\u5e74\u6765\u4eba\u7c7b\u601d\u60f3\u548c\u6587\u5316\u53d1\u5c55\u4e2d\u7684\u4f18\u79c0\u6210\u679c\uff0c\u5c24\u5176\u662f\u5728\u6279\u5224\u5730\u7ee7\u627f\u3001\u5438\u6536\u5fb7\u56fd\u53e4\u5178\u54f2\u5b66\u3001\u82f1\u56fd\u53e4\u5178\u653f\u6cbb\u7ecf\u6d4e\u5b66\u548c\u6cd5\u56fd\u3001\u82f1\u56fd\u7684\u7a7a\u60f3\u793e\u4f1a\u4e3b\u4e49\u5408\u7406\u6210\u5206\u7684\u57fa\u7840\u4e0a\uff0c\u5728\u6df1\u523b\u5206\u6790\u8d44\u672c\u4e3b\u4e49\u793e\u4f1a\u7684\u53d1\u5c55\u8d8b\u52bf\u548c\u79d1\u5b66\u603b\u7ed3\u5de5\u4eba\u9636\u7ea7\u6597\u4e89\u5b9e\u8df5\u7684\u57fa\u7840\u4e0a\uff0c\u521b\u7acb\u548c\u53d1\u5c55\u8d77\u6765\u7684\u3002C\u6b63\u786e\u3002\u5176\u4ed6\u4e09\u4e2a\u9009\u9879\u90fd\u53ea\u662f\u6307\u51fa\u5ba2\u89c2\u7684\u6216\u8005\u4e3b\u89c2\u7684\u67d0\u4e00\u65b9\u9762\u7684\u6761\u4ef6\uff0c\u4e0d\u5168\u9762\uff0c\u4e5f\u4e0d\u51c6\u786e\uff0cA\u3001B\u3001D\u9519\u8bef\u3002</p>\\n\",\"options\":[\"<p>\u4ed6\u4eec\u62e5\u6709\u4f18\u826f\u7684\u5bb6\u5ead\u80cc\u666f\u548c\u6559\u80b2\u7ecf\u5386</p>\\n\",\"<p>\u4ed6\u4eec\u5bf9\u65f6\u4ee3\u6709\u7740\u8d85\u8d8a\u5e38\u4eba\u7684\u8ba4\u77e5\u80fd\u529b</p>\\n\",\"<p>\u793e\u4f1a\u5386\u53f2\u6761\u4ef6\u548c\u4e2a\u4eba\u52aa\u529b\u7684\u76f8\u4e92\u4f5c\u7528</p>\\n\",\"<p>\u5fb7\u56fd\u662f\u5f53\u65f6\u6700\u4e3a\u53d1\u8fbe\u7684\u8d44\u672c\u4e3b\u4e49\u56fd\u5bb6</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1841,\"rightCount\":1684,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":80,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":1,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1757,\"type\":\"1\",\"stem\":\"<p>&quot;\u9a6c\u8005\u6240\u4ee5\u547d\u5f62\u4e5f;\u767d\u8005\u6240\u4ee5\u547d\u8272\u4e5f\u3002\u547d\u8272\u8005\u975e\u547d\u5f62\u4e5f\uff0c\u6545\u66f0\u767d\u9a6c\u975e\u9a6c\u3002&quot;\u4ece\u552f\u7269\u8fa9\u8bc1\u6cd5\u7684\u89c2\u70b9\u770b\uff0c&quot;\u767d\u9a6c\u975e\u9a6c&quot;\u8fd9\u4e00\u547d\u9898\u7684\u9519\u8bef\u5728\u4e8e</p>\",\"answer\":[1],\"analysis\":\"<p>A\u9519\u8bef\u3002\u5f62\u6001\u7ed3\u6784\u548c\u529f\u80fd\u8303\u7574\u662f\u63ed\u793a\u4e8b\u7269\u5185\u90e8\u7684\u6784\u6210\u5f62\u6001\u548c\u4e8b\u7269\u540c\u73af\u5883\u76f8\u4e92\u4f5c\u7528\u7684\u52a8\u6001\u8fc7\u7a0b\uff0c\u7ed3\u6784\u8bf4\u660e\u4e8b\u7269\u7684\u5185\u90e8\u8054\u7cfb\u548c\u4f5c\u7528\uff0c\u529f\u80fd\u8bf4\u660e\u4e8b\u7269\u4e0e\u5916\u90e8\u7684\u8054\u7cfb\u548c\u4f5c\u7528\u3002\u4efb\u4f55\u8303\u7574\u90fd\u6709\u65b9\u6cd5\u8bba\u4f5c\u7528\u3002\u7ed3\u6784\u51b3\u5b9a\u7740\u529f\u80fd\uff0c\u529f\u80fd\u53cd\u4f5c\u7528\u4e8e\u7ed3\u6784\uff0c\u5f71\u54cd\u4e8b\u7269\u539f\u6709\u7ed3\u6784\u7684\u53d1\u5c55\u65b9\u5411\uff0c\u4e8c\u8005\u5728\u4e00\u5b9a\u6761\u4ef6\u4e0b\u76f8\u4e92\u8f6c\u5316\uff0c\u7ed3\u6784\u53d8\u5316\u4f1a\u5bfc\u81f4\u65b0\u529f\u80fd\u7684\u4ea7\u751f\uff0c\u529f\u80fd\u7684\u53d1\u6325\u4f1a\u5bfc\u81f4\u4e8b\u7269\u65b0\u7ed3\u6784\u7684\u4ea7\u751f\u3002\u9898\u5e72\u4e2d\u201c\u767d\u9a6c\u975e\u9a6c\u201d\u662f\u5728\u5f62\u4e0e\u8272\u8fd9\u4e00\u89d2\u5ea6\u7684\u8be1\u8fa9\uff0c\u5e76\u4e0d\u6d89\u53ca\u7ed3\u6784\u548c\u529f\u80fd\u7684\u5173\u7cfb\u3002</p><p>B\u6b63\u786e\u3002\u73b0\u5b9e\u4e8b\u7269\u662f\u5171\u6027\u548c\u4e2a\u6027\u7684\u6709\u673a\u7edf\u4e00\uff0c\u9898\u5e72\u4e2d\u767d\u9a6c\u7684\u7279\u6b8a\u6027\u5373\u4e2a\u6027\u5728\u4e8e\u201c\u767d\u201d\uff0c\u9a6c\u662f\u201c\u767d\u9a6c\u201d\u7684\u666e\u904d\u6027\u5373\u5171\u6027\u3002\u201c\u767d\u9a6c\u975e\u9a6c\u201d\u7684\u8be1\u8fa9\u4ee5\u8272\u201c\u767d\u201d\u5426\u8ba4\u5f62\u201c\u9a6c\u201d\uff0c\u5f3a\u884c\u5272\u88c2\u767d\u9a6c\u8fd9\u4e00\u73b0\u5b9e\u4e8b\u7269\u4e2d\u7684\u4e2a\u6027\u4e0e\u5171\u6027\uff0c\u8352\u8c2c\u81f3\u6781\u3002</p><p>C\u9519\u8bef\u3002\u5185\u5bb9\u548c\u5f62\u5f0f\u662f\u63ed\u793a\u4e8b\u7269\u5185\u5728\u8981\u7d20\u548c\u8981\u7d20\u7ed3\u6784\u3001\u8868\u73b0\u65b9\u5f0f\u5173\u7cfb\u7684\u8303\u7574\u3002\u5185\u5bb9\u662f\u8981\u7d20\u7684\u603b\u548c\uff0c\u5f62\u5f0f\u662f\u8981\u7d20\u7ed3\u5408\u7684\u7ed3\u6784\u548c\u65b9\u5f0f\uff0c\u5185\u5bb9\u51b3\u5b9a\u5f62\u5f0f\uff0c\u5f62\u5f0f\u53cd\u4f5c\u7528\u4e8e\u5185\u5bb9\u3002\u767d\u9a6c\u548c\u9a6c\u4e0d\u662f\u5185\u5bb9\u4e0e\u5f62\u5f0f\u7684\u5173\u7cfb\uff0c\u56e0\u800c\u201c\u767d\u9a6c\u975e\u9a6c\u201d\u7684\u8be1\u8fa9\u6df7\u6dc6\u4e86\u5185\u5bb9\u548c\u5f62\u5f0f\u7684\u533a\u522b\u4e5f\u5c31\u65e0\u4ece\u8bf4\u8d77\u3002</p><p>D\u9519\u8bef\u3002\u672c\u8d28\u548c\u73b0\u8c61\u662f\u63ed\u793a\u4e8b\u7269\u5916\u90e8\u8868\u73b0\u548c\u5185\u90e8\u8054\u7cfb\u7684\u5173\u7cfb\u7684\u8303\u7574\uff0c\u767d\u9a6c\u548c\u9a6c\u672c\u8eab\u662f\u73b0\u8c61\u548c\u672c\u8d28\u7684\u7edf\u4e00\uff0c\u4e8c\u8005\u4e4b\u95f4\u5e76\u4e0d\u662f\u73b0\u8c61\u672c\u8d28\u7684\u5173\u7cfb\uff0c\u56e0\u6b64\u9898\u5e72\u4e2d\u201c\u767d\u9a6c\u975e\u9a6c\u201d\u7684\u8be1\u8fa9\u4e0d\u6d89\u53ca\u73b0\u8c61\u4e0e\u672c\u8d28\u8303\u7574\u3002</p><p>\u6545\u6b63\u786e\u7b54\u6848\u4e3aB\u3002</p><p><br/></p>\",\"options\":[\"<p>\u6a21\u7cca\u4e86\u4e8b\u7269\u672c\u8d28\u548c\u73b0\u8c61\u4e4b\u95f4\u7684\u8054\u7cfb</p>\\n\",\"<p>\u5272\u88c2\u4e86\u4e8b\u7269\u5171\u6027\u548c\u4e2a\u6027\u4e4b\u95f4\u7684\u8054\u7cfb</p>\\n\",\"<p>\u6df7\u6dc6\u4e86\u4e8b\u7269\u5185\u5bb9\u548c\u5f62\u5f0f\u4e4b\u95f4\u7684\u533a\u522b</p>\\n\",\"<p>\u98a0\u5012\u4e86\u4e8b\u7269\u5f62\u6001\u548c\u529f\u80fd\u4e4b\u95f4\u7684\u5173\u7cfb</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1849,\"rightCount\":1490,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":80,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":2,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1758,\"type\":\"1\",\"stem\":\"<p>\u575a\u6301\u4ee5\u4eba\u6c11\u4e3a\u4e2d\u5fc3\uff0c\u5c31\u5fc5\u987b\u575a\u6301\u4eba\u6c11\u4e3b\u4f53\u5730\u4f4d\uff0c\u575a\u6301\u7acb\u515a\u4e3a\u516c\u3001\u6267\u653f\u4e3a\u6c11\uff0c\u8df5\u884c\u5168\u5fc3\u5168\u610f\u4e3a\u4eba\u6c11\u670d\u52a1\u7684\u6839\u672c\u5b97\u65e8\uff0c\u628a\u515a\u7684\u7fa4\u4f17\u8def\u7ebf\u8d2f\u5f7b\u5230\u6cbb\u56fd\u7406\u653f\u5168\u90e8\u6d3b\u52a8\u4e4b\u4e2d\uff0c\u628a\u4eba\u6c11\u5bf9\u7f8e\u597d\u751f\u6d3b\u7684\u5411\u5f80\u4f5c\u4e3a\u594b\u6597\u76ee\u6807\u3002&quot;\u575a\u6301\u4ee5\u4eba\u6c11\u4e3a\u4e2d\u5fc3&quot;\u7684\u7406\u8bba\u57fa\u7840\u662f\u552f\u7269\u53f2\u89c2\u5173\u4e8e</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u575a\u6301\u4ee5\u4eba\u6c11\u4e3a\u4e2d\u5fc3\uff0c\u5c31\u5fc5\u987b\u575a\u6301\u4eba\u6c11\u4e3b\u4f53\u5730\u4f4d\uff0c\u575a\u6301\u7acb\u515a\u4e3a\u516c\u3001\u6267\u653f\u4e3a\u6c11\uff0c\u8df5\u884c\u5168\u5fc3\u5168\u610f\u4e3a\u4eba\u6c11\u670d\u52a1\u7684\u6839\u672c\u5b97\u65e8\uff0c\u628a\u515a\u7684\u7fa4\u4f17\u8def\u7ebf\u8d2f\u5f7b\u5230\u6cbb\u56fd\u7406\u653f\u5168\u90e8\u6d3b\u52a8\u4e4b\u4e2d\uff0c\u628a\u4eba\u6c11\u5bf9\u7f8e\u597d\u751f\u6d3b\u7684\u5411\u5f80\u4f5c\u4e3a\u594b\u6597\u76ee\u6807\uff0c\u505a\u5230\u53d1\u5c55\u4e3a\u4e86\u4eba\u6c11\u3001\u53d1\u5c55\u4f9d\u9760\u4eba\u6c11\u3001\u53d1\u5c55\u6210\u679c\u7531\u4eba\u6c11\u5171\u4eab\u3002&quot;\u575a\u6301\u4ee5\u4eba\u6c11\u4e3a\u4e2d\u5fc3&quot;\u7684\u7406\u8bba\u57fa\u7840\u662f\u552f\u7269\u53f2\u89c2\u5173\u4e8e\u4eba\u6c11\u7fa4\u4f17\u662f\u5386\u53f2\u7684\u521b\u9020\u8005\u7684\u539f\u7406\u3002\u4eba\u6c11\u7fa4\u4f17\u662f\u793e\u4f1a\u5386\u53f2\u5b9e\u8df5\u7684\u4e3b\u4f53\uff0c\u662f\u5386\u53f2\u7684\u521b\u9020\u8005\u3002\u9996\u5148\uff0c\u4eba\u6c11\u7fa4\u4f17\u662f\u7269\u8d28\u8d22\u5bcc\u7684\u521b\u9020\u8005\u3002\u5176\u6b21\uff0c\u4eba\u6c11\u7fa4\u4f17\u662f\u793e\u4f1a\u7cbe\u795e\u8d22\u5bcc\u7684\u521b\u9020\u8005\u3002\u518d\u6b21\uff0c\u4eba\u6c11\u7fa4\u4f17\u662f\u793e\u4f1a\u53d8\u9769\u7684\u51b3\u5b9a\u529b\u91cf\u3002\u6700\u540e\uff0c\u4eba\u6c11\u7fa4\u4f17\u65e2\u662f\u5148\u8fdb\u751f\u4ea7\u529b\u548c\u5148\u8fdb\u6587\u5316\u7684\u521b\u9020\u4e3b\u4f53\uff0c\u4e5f\u662f\u5b9e\u73b0\u81ea\u8eab\u5229\u76ca\u7684\u6839\u672c\u529b\u91cf\u3002B\u6b63\u786e\u3002A\u3001C\u3001D\u4e09\u4e2a\u9009\u9879\u7684\u5185\u5bb9\u6b63\u786e\uff0c\u4f46\u90fd\u4e0d\u7b26\u5408\u9898\u610f\u3002</p>\\n\",\"options\":[\"<p>\u4eba\u7684\u672c\u8d28\u662f\u4e00\u5207\u793e\u4f1a\u5173\u7cfb\u7684\u603b\u548c\u7684\u539f\u7406</p>\\n\",\"<p>\u4eba\u6c11\u7fa4\u4f17\u662f\u5386\u53f2\u7684\u521b\u9020\u8005\u7684\u539f\u7406</p>\\n\",\"<p>\u4eba\u6c11\u7fa4\u4f17\u7684\u6d3b\u52a8\u53d7\u5230\u793e\u4f1a\u5386\u53f2\u6761\u4ef6\u5236\u7ea6\u7684\u539f\u7406</p>\\n\",\"<p>\u603b\u4f53\u7684\u4eba\u5728\u603b\u4f53\u7684\u5386\u53f2\u8fc7\u7a0b\u4e2d\u7684\u4e3b\u4f53\u5730\u4f4d\u7684\u539f\u7406</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":1780,\"rightCount\":1458,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":80,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":2,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1759,\"type\":\"1\",\"stem\":\"<p>\u300a\u8d44\u672c\u8bba\u300b\uff08\u5fb7\u6587\u7248\uff09\u7b2c\u4e00\u5377\u4e8e1867\u5e749\u6708\u5728\u6c49\u5821\u51fa\u7248\uff0c\u5176\u5f71\u54cd\u529b\u5386\u7ecf150\u5e74\u98ce\u96e8\u800c\u4e0d\u8870\uff0c\u81f3\u4eca\u5bf9\u6211\u4eec\u5206\u6790\u3001\u7406\u89e3\u73b0\u5b9e\u7ecf\u6d4e\u95ee\u9898\u4f9d\u7136\u5177\u6709\u5f88\u5f3a\u7684\u6307\u5bfc\u610f\u4e49\u3002\u9a6c\u514b\u601d\u4e3b\u4e49\u653f\u6cbb\u7ecf\u6d4e\u5b66\u7684\u7406\u8bba\u5341\u5206\u4e30\u5bcc\uff0c\u5176\u4e2d&quot;\u7406\u89e3\u653f\u6cbb\u7ecf\u6d4e\u5b66\u7684\u67a2\u7ebd&quot;\u7684\u7406\u8bba\u662f</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u653f\u6cbb\u7ecf\u6d4e\u5b66\u8ba4\u4e3a\uff0c\u5546\u54c1\u662f\u52b3\u52a8\u4ea7\u54c1\uff0c\u751f\u4ea7\u5546\u54c1\u7684\u52b3\u52a8\u53ef\u533a\u5206\u4e3a\u5177\u4f53\u52b3\u52a8\u548c\u62bd\u8c61\u52b3\u52a8\u3002\u5177\u4f53\u52b3\u52a8\u662f\u6307\u751f\u4ea7\u4e00\u5b9a\u4f7f\u7528\u4ef7\u503c\u7684\u5177\u4f53\u5f62\u5f0f\u7684\u52b3\u52a8\u3002\u62bd\u8c61\u52b3\u52a8\u662f\u6307\u6487\u5f00\u4e00\u5207\u5177\u4f53\u5f62\u5f0f\u7684\u3001\u65e0\u5dee\u522b\u7684\u822c\u4eba\u7c7b\u52b3\u52a8\uff0c\u5373\u4eba\u7684\u4f53\u529b\u548c\u8111\u529b\u7684\u6d88\u8017\u3002\u751f\u4ea7\u5546\u54c1\u7684\u5177\u4f53\u52b3\u52a8\u521b\u9020\u5546\u54c1\u7684\u4f7f\u7528\u4ef7\u503c\uff0c\u62bd\u8c61\u52b3\u52a8\u5f62\u6210\u5546\u54c1\u7684\u4ef7\u503c\u3002\u5177\u4f53\u52b3\u52a8\u548c\u62bd\u8c61\u52b3\u52a8\u662f\u540c\u4e00\u52b3\u52a8\u7684\u4e24\u79cd\u89c4\u5b9a\u3002\u4efb\u4f55\u4e00\u79cd\u52b3\u52a8\uff0c\u4e00\u65b9\u9762\u662f\u7279\u6b8a\u7684\u5177\u4f53\u52b3\u52a8\uff0c\u53e6\u65b9\u9762\u53c8\u662f\u4e00\u822c\u7684\u62bd\u8c61\u52b3\u52a8\uff0c\\n\u8fd9\u5c31\u662f\u52b3\u52a8\u7684\u4e8c\u91cd\u6027\u3002\u6b63\u662f\u52b3\u52a8\u7684\u4e8c\u91cd\u6027\u51b3\u5b9a\u4e86\u5546\u54c1\u7684\u4e8c\u56e0\u7d20\u3002\u5728\u9a6c\u514b\u601d\u4e4b\u524d\uff0c\u82f1\u56fd\u53e4\u5178\u653f\u6cbb\u7ecf\u6d4e\u5b66\u7684\u4ee3\u8868\u4eba\u7269\u4e9a\u5f53\u65af\u5bc6\u5df2\u7ecf\u8ba4\u8bc6\u5230\u4e86\u5546\u54c1\u7684\u4e8c\u56e0\u7d20,\u63d0\u51fa\u4e86\u52b3\u52a8\u521b\u9020\u4ef7\u503c\u7684\u89c2\u70b9;\u5927\u536b\u674e\u5609\u56fe\u751a\u81f3\u5df2\u7ecf\u8ba4\u8bc6\u5230\u51b3\u5b9a\u5546\u54c1\u4ef7\u503c\u91cf\u7684\u662f\u793e\u4f1a\u5fc5\u8981\u52b3\u52a8\u91cf\uff0c\u800c\u4e0d\u662f\u751f\u4ea7\u5546\u54c1\u5b9e\u9645\u8017\u8d39\u7684\u52b3\u52a8\u91cf\u3002\u4f46\u662f\u7531\u4e8e\u4ed6\u4eec\u6ca1\u6709\u533a\u5206\u52b3\u52a8\u7684\u4e8c\u91cd\u6027\uff0c\u6240\u4ee5\u4e0d\u80fd\u56de\u7b54\u4ec0\u4e48\u52b3\u52a8\u521b\u9020\u4ef7\u503c;\u4e0d\u80fd\u660e\u786e\u533a\u5206\u4ef7\u503c\u548c\u4ea4\u6362\u4ef7\u503c\uff0c\u4e0d\u662f\u901a\u8fc7\u751f\u4ea7\u5546\u54c1\u4e2d\u6240\u8017\u8d39\u7684\u52b3\u52a8\u6765\u89e3\u91ca\u4ef7\u503c\uff0c\u800c\u662f\u901a\u8fc7\u8be5\u5546\u54c1\u6240\u6362\u6765\u7684\u53e6\u79cd\u5546\u54c1\u5305\u542b\u7684\u52b3\u52a8\u91cf\u6765\u89e3\u91ca\u8be5\u5546\u54c1\u7684\u4ef7\u503c;\u4e0d\u7406\u89e3\u793e\u4f1a\u5fc5\u8981\u52b3\u52a8\u91cf\u662f\u5982\u4f55\u51b3\u5b9a\u7684\u3002\u7ed3\u679c\uff0c\u5728\u4ef7\u503c\u7684\u5f62\u5f0f\u3001\u4ef7\u503c\u7684\u672c\u8d28\u3001\u4ef7\u503c\u7684\u6e90\u6cc9\u548c\u4ef7\u503c\u91cf\u7684\u51b3\u5b9a\u7b49\u91cd\u5927\u7406\u8bba\u95ee\u9898\u7684\u8ba4\u8bc6\u4e0a\u51fa\u73b0\u4e86\u6df7\u4e71\u548c\u9519\u8bef\u3002\u9a6c\u514b\u601d\u5728\u7ee7\u627f\u82f1\u56fd\u53e4\u5178\u653f\u6cbb\u7ecf\u6d4e\u5b66\u52b3\u52a8\u521b\u9020\u4ef7\u503c\u7684\u7406\u8bba\u7684\u540c\u65f6\uff0c\u521b\u7acb\u4e86\u52b3\u52a8\u4e8c\u91cd\u6027\u7406\u8bba\uff0c\u786e\u5b9a\u4e86\u4ec0\u4e48\u6837\u7684\u52b3\u52a8\u5f62\u6210\u4ef7\u503c\uff0c\u4e3a\u4ec0\u4e48\u5f62\u6210\u4ef7\u503c\u4ee5\u53ca\u600e\u6837\u5f62\u6210\u4ef7\u503c\uff0c\u9610\u660e\u4e86\u5177\u4f53\u52b3\u52a8\u548c\u62bd\u8c61\u52b3\u52a8\u5728\u5546\u54c1\u4ef7\u503c\u5f62\u6210\u4e2d\u7684\u4e0d\u540c\u4f5c\u7528\uff0c\u4ece\u800c\u4e3a\u63ed\u793a\u5269\u4f59\u4ef7\u503c\u7684\u771f\u6b63\u6765\u6e90\u3001\u521b\u7acb\u5269\u4f59\u4ef7\u503c\u7406\u8bba\u5960\u5b9a\u4e86\u57fa\u7840\u3002\u6b64\u5916\uff0c\u9a6c\u514b\u601d\u7684\u8d44\u672c\u6709\u673a\u6784\u6210\u7406\u8bba\u3001\u8d44\u672c\u79ef\u7d2f\u7406\u8bba\u3001\u793e\u4f1a\u8d44\u672c\u518d\u751f\u4ea7\u7406\u8bba\u7b49\u653f\u6cbb\u7ecf\u6d4e\u5b66\u7684\u4e00\u7cfb\u5217\u91cd\u8981\u7406\u8bba\u7684\u521b\u7acb\u4e5f\u90fd\u540c\u52b3\u52a8\u4e8c\u91cd\u6027\u7406\u8bba\u6709\u5173\u3002\u56e0\u6b64\uff0c\u52b3\u52a8\u4e8c\u91cd\u6027\u7406\u8bba\u6210\u4e3a&quot;\u7406\u89e3\u653f\u6cbb\u7ecf\u6d4e\u5b66\u7684\u67a2\u7ebd&quot;\u3002C\u6b63\u786e\u3002</p>\\n\",\"options\":[\"<p>\u5546\u54c1\u4e8c\u56e0\u7d20\u7406\u8bba</p>\\n\",\"<p>\u4ef7\u503c\u89c4\u5f8b\u7406\u8bba</p>\\n\",\"<p>\u52b3\u52a8\u4e8c\u91cd\u6027\u7406\u8bba</p>\\n\",\"<p>\u5269\u4f59\u4ef7\u503c\u7406\u8bba</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1842,\"rightCount\":1114,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":80,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":9,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1760,\"type\":\"1\",\"stem\":\"<p>\u7ecf\u6d4e\u5efa\u8bbe\u662f\u5168\u515a\u7684\u4e2d\u5fc3\u5de5\u4f5c\uff0c\u575a\u6301\u4ee5\u7ecf\u6d4e\u5efa\u8bbe\u4e3a\u4e2d\u5fc3\u4e0d\u52a8\u6447\uff0c\u5c31\u5fc5\u987b\u575a\u6301\u4ee5\u7ecf\u6d4e\u4f53\u5236\u6539\u9769\u4e3a\u91cd\u70b9\u4e0d\u52a8\u6447\u3002\u5f53\u524d\uff0c\u6211\u56fd\u6df1\u5316\u7ecf\u6d4e\u4f53\u5236\u6539\u9769\u7684\u91cd\u70b9\u662f</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u515a\u7684\u5341\u4e5d\u5927\u62a5\u544a\u6307\u51fa\uff0c\u7ecf\u6d4e\u4f53\u5236\u6539\u9769\u5fc5\u987b\u4ee5\u5b8c\u5584\u4ea7\u6743\u5236\u5ea6\u548c\u8981\u7d20\u5e02\u573a\u5316\u914d\u7f6e\u4e3a\u91cd\u70b9\uff0c\u5b9e\u73b0\u4ea7\u6743\u6709\u6548\u6fc0\u52b1\u3001\u8981\u7d20\u81ea\u7531\u6d41\u52a8\u3001\u4ef7\u683c\u53cd\u5e94\u7075\u6d3b\u3001\u7ade\u4e89\u516c\u5e73\u6709\u5e8f\u3001\u4f01\u4e1a\u4f18\u80dc\u52a3\u6c70\u3002B\u6b63\u786e\u3002A\u3001D\u6240\u6d89\u53ca\u7684\u5185\u5bb9\u5c5e\u4e8e\u7ecf\u6d4e\u7ed3\u6784\u95ee\u9898\uff0cC\u6240\u6d89\u53ca\u7684\u662f\u5982\u4f55\u5168\u9762\u63d0\u9ad8\u5bf9\u5916\u5f00\u653e\u6c34\u5e73\u7684\u8981\u6c42\uff0cA\u3001C\u3001D\\n\u90fd\u4e0d\u7b26\u5408\u9898\u610f\u3002</p>\\n\",\"options\":[\"<p>\u6269\u5927\u4f18\u8d28\u589e\u91cf\u4f9b\u7ed9\uff0c\u5b9e\u73b0\u4f9b\u9700\u52a8\u6001\u5e73\u8861</p>\\n\",\"<p>\u5b8c\u5584\u4ea7\u6743\u5236\u5ea6\u548c\u8981\u7d20\u5e02\u573a\u5316\u914d\u7f6e</p>\\n\",\"<p>\u52a0\u5feb\u57f9\u80b2\u56fd\u9645\u7ecf\u6d4e\u5408\u4f5c\u548c\u7ade\u4e89\u65b0\u4f18\u52bf</p>\\n\",\"<p>\u5efa\u7acb\u66f4\u52a0\u6709\u6548\u7684\u533a\u57df\u534f\u8c03\u53d1\u5c55\u65b0\u673a\u5236</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1819,\"rightCount\":717,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":80,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":8,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1761,\"type\":\"1\",\"stem\":\"<p>\u5b9e\u884c\u4eba\u6c11\u6c11\u4e3b\uff0c\u4fdd\u8bc1\u4eba\u6c11\u5f53\u5bb6\u4f5c\u4e3b\uff0c\u5b9e\u73b0\u5f62\u5f0f\u662f\u4e30\u5bcc\u591a\u6837\u7684\u3002\u7ecf\u8fc7\u957f\u671f\u63a2\u7d22\uff0c\u6211\u56fd\u5728\u901a\u8fc7\u4f9d\u6cd5\u9009\u4e3e\u8ba9\u4eba\u6c11\u7684\u4ee3\u8868\u6765\u53c2\u4e0e\u56fd\u5bb6\u751f\u6d3b\u548c\u793e\u4f1a\u751f\u6d3b\u7ba1\u7406\u7684\u540c\u65f6\uff0c\u627e\u5230\u4e86\u4e00\u79cd\u4fdd\u8bc1\u4eba\u6c11\u5728\u65e5\u5e38\u653f\u6cbb\u751f\u6d3b\u4e2d\u6709\u5e7f\u6cdb\u6301\u7eed\u6df1\u5165\u53c2\u4e0e\u6743\u5229\u7684\u7279\u6709\u6c11\u4e3b\u5f62\u5f0f\uff0c\u8fd9\u4e00\u7279\u6709\u6c11\u4e3b\u5f62\u5f0f\u662f</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u515a\u7684\u5341\u4e5d\u5927\u62a5\u544a\u6307\u51fa\uff0c\u6709\u4e8b\u597d\u5546\u91cf\uff0c\u4f17\u4eba\u7684\u4e8b\u60c5\u7531\u4f17\u4eba\u5546\u91cf\uff0c\u662f\u4eba\u6c11\u6c11\u4e3b\u7684\u771f\u8c1b\u3002\\n\u534f\u5546\u6c11\u4e3b\u662f\u5b9e\u73b0\u515a\u7684\u9886\u5bfc\u7684\u91cd\u8981\u65b9\u5f0f\uff0c\u662f\u6211\u56fd\u793e\u4f1a\u4e3b\u4e49\u6c11\u4e3b\u653f\u6cbb\u7684\u7279\u6709\u5f62\u5f0f\u548c\u72ec\u7279\u4f18\u52bf\u3002\u8981\u63a8\u52a8\u534f\u5546\u6c11\u4e3b\u5e7f\u6cdb\u3001\u591a\u5c42\u3001\u5236\u5ea6\u5316\u53d1\u5c55\uff0c\u7edf\u7b79\u63a8\u8fdb\u653f\u515a\u534f\u5546\u3001\u4eba\u5927\u534f\u5546\u3001\u653f\u5e9c\u534f\u5546\u3001\u653f\u534f\u534f\u5546\u3001\u4eba\u6c11\u56e2\u4f53\u534f\u5546\u3001\u57fa\u5c42\u534f\u5546\u4ee5\u53ca\u793e\u4f1a\u7ec4\u7ec7\u534f\u5546\u3002\u52a0\u5f3a\u534f\u5546\u6c11\u4e3b\u5236\u5ea6\u5efa\u8bbe\uff0c\u5f62\u6210\u5b8c\u6574\u7684\u5236\u5ea6\u7a0b\u5e8f\u548c\u53c2\u4e0e\u5b9e\u8df5\uff0c\u4fdd\u8bc1\u4eba\u6c11\u5728\u76ee\u5e38\u653f\u6cbb\u751f\u6d3b\u4e2d\u6709\u5e7f\u6cdb\u6301\u7eed\u6df1\u5165\u53c2\u4e0e\u7684\u6743\u5229\u3002B\u6b63\u786e\uff0c\u5176\u4ed6\u9009\u9879\u90fd\u4e0d\u7b26\u5408\u9898\u610f\u3002</p>\\n\",\"options\":[\"<p>\u8c08\u5224\u6c11\u4e3b</p>\\n\",\"<p>\u534f\u5546\u6c11\u4e3b</p>\\n\",\"<p>\u7968\u51b3\u6c11\u4e3b</p>\\n\",\"<p>\u7ade\u4e89\u6027\u6c11\u4e3b</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":1632,\"rightCount\":1476,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":80,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":0,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1762,\"type\":\"1\",\"stem\":\"<p>\u515a\u7684\u5341\u516b\u5927\u4ee5\u6765\uff0c\u6211\u56fd\u5927\u529b\u5b9e\u65bd\u521b\u65b0\u9a71\u52a8\u53d1\u5c55\u6218\u7565\uff0c\u52a0\u5feb\u521b\u65b0\u578b\u56fd\u5bb6\u5efa\u8bbe\u6b65\u4f10\uff0c\u6210\u679c\u4e30\u7855\uff0c\u5929\u5bab\u3001\u86df\u9f99\u3001\u5929\u773c\u3001\u609f\u7a7a\u3001\u58a8\u5b50\u3001\u5927\u98de\u673a\u7b49\u91cd\u5927\u79d1\u6280\u6210\u679c\u76f8\u7ee7\u95ee\u4e16\u3002\u6211\u56fd\u5b9e\u65bd\u521b\u65b0\u9a71\u52a8\u53d1\u5c55\u6218\u7565\u6240\u575a\u6301\u7684\u65b9\u9488\u662f</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u5b9e\u65bd\u521b\u65b0\u9a71\u52a8\u53d1\u5c55\u6218\u7565\uff0c\u8981\u6811\u7acb\u5f3a\u70c8\u7684\u521b\u65b0\u81ea\u4fe1\uff0c\u6562\u4e8e\u8d70\u524d\u4eba\u6ca1\u8d70\u8fc7\u7684\u8def\uff0c\u6211\u4eec\u5728\u4e16\u754c\u5c16\u7aef\u6c34\u5e73\u4e0a\u4e00\u5b9a\u8981\u6709\u81ea\u4fe1\uff0c\u8981\u575a\u5b9a\u4e0d\u79fb\u8d70\u4e2d\u56fd\u7279\u8272\u81ea\u4e3b\u521b\u65b0\u9053\u8def\uff0c\u575a\u6301\u81ea\u4e3b\u521b\u65b0\u3001\u91cd\u70b9\u8de8\u8d8a\u3001\u652f\u6491\u53d1\u5c55\u3001\u5f15\u9886\u672a\u6765\u7684\u65b9\u9488\uff0c\u52a0\u5feb\u521b\u65b0\u578b\u56fd\u5bb6\u5efa\u8bbe\u6b65\u4f10\uff0c\u52c7\u4e8e\u521b\u9020\u5f15\u9886\u4e16\u754c\u6f6e\u6d41\u7684\u79d1\u6280\u6210\u679c\u3002C\u6b63\u786e\uff0cA\u3001D\u5c5e\u4e8e\u8fd9\u4e00\u65b9\u9488\u76f8\u5173\u7684\u5177\u4f53\u8981\u6c42\uff0cB\u6240\u6d89\u53ca\u7684\u662f\u6df1\u5316\u79d1\u6280\u4f53\u5236\u6539\u9769\u65b9\u9762\u7684\u95ee\u9898\u3002</p>\\n\",\"options\":[\"<p>\u96c6\u4e2d\u529b\u91cf\u3001\u91cd\u70b9\u7a81\u7834\u3001\u5b9e\u73b0\u8de8\u8d8a\u5f0f\u53d1\u5c55</p>\\n\",\"<p>\u4f01\u4e1a\u4e3a\u4e3b\u4f53\u3001\u5e02\u573a\u4e3a\u5bfc\u5411\u3001\u4ea7\u5b66\u7814\u76f8\u7ed3\u5408</p>\\n\",\"<p>\u81ea\u4e3b\u521b\u65b0\u3001\u91cd\u70b9\u8de8\u8d8a\u3001\u652f\u6491\u53d1\u5c55\u3001\u5f15\u9886\u672a\u6765</p>\\n\",\"<p>\u539f\u59cb\u521b\u65b0\u3001\u96c6\u6210\u521b\u65b0\u3001\u5f15\u8fdb\u6d88\u5316\u5438\u6536\u518d\u521b\u65b0</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1684,\"rightCount\":1321,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":80,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1763,\"type\":\"1\",\"stem\":\"<p>\u89e3\u51b3\u53f0\u6e7e\u95ee\u9898\u3001\