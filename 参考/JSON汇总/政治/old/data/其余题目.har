\":\"\",\"qNo\":null},{\"id\":1699,\"type\":\"1\",\"stem\":\"<p>1950 \u5e74\u81f3 1907\\n\u5e74\u95f4\uff0c\u8d44\u4ea7\u9636\u7ea7\u9769\u547d\u6d3e\u548c\u6539\u826f\u6d3e\u8fdb\u884c\u4e86\u4e00\u573a\u5927\u8bba\u6218\uff0c\u53cc\u65b9\u8bba\u6218\u7684\u7126\u70b9\u662f</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u8d44\u4ea7\u9636\u7ea7\u9769\u547d\u6d3e\u4e0e\u6539\u826f\u6d3e\u8bba\u6218\u4e3b\u8981\u662f\u9488\u5bf9\u4e09\u4e2a\u65b9\u9762\uff0c\u5206\u522b\u662f:\u8981\u4e0d\u8981\u4ee5\u9769\u547d\u624b\u6bb5\u63a8\u7ffb\u6e05\u653f\u5e9c;\u8981\u4e0d\u8981\u63a8\u7ffb\u5e1d\u5236\uff0c\u5b9e\u884c\u5171\u548c;\u8981\u4e0d\u8981\u793e\u4f1a\u9769\u547d\u3002\u5176\u4e2d\u8bba\u6218\u7684\u7126\u70b9\u96c6\u4e2d\u5728\u8981\u4e0d\u8981\u4ee5\u9769\u547d\u624b\u6bb5\u63a8\u7ffb\u6e05\u653f\u5e9c\u7684\u7edf\u6cbb\u4e0a\uff0c\u6240\u4ee5\u6b63\u786e\u7b54\u6848\u4e3a\\nB\u3002</p>\\n\",\"options\":[\"<p>\u8981\u4e0d\u8981\u63a8\u7ffb\u5e1d\u5236\u5b9e\u884c\u5171\u548c</p>\\n\",\"<p>\u8981\u4e0d\u8981\u4ee5\u9769\u547d\u624b\u6bb5\u63a8\u7ffb\u6e05\u738b\u671d</p>\\n\",\"<p>\u8981\u4e0d\u8981\u53d1\u52a8\u6c11\u4f17</p>\\n\",\"<p>\u8981\u4e0d\u8981\u793e\u4f1a\u9769\u547d</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":2315,\"rightCount\":1934,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":78,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":2,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1700,\"type\":\"1\",\"stem\":\"<p>\u4e2d\u56fd\u5171\u4ea7\u515a\u4e00\u7ecf\u6210\u7acb\u