7\u9769\u547d\u515a\u3002\u8fd9\u662f\u56e0\u4e3a\u793e\u4f1a\u89c4\u5f8b\u4e0e\u81ea\u7136\u89c4\u5f8b\u6709\u6240\u4e0d\u540c\uff0c\u5b83\u662f</p>\\n\",\"answer\":[0],\"analysis\":\"<p>\u89c4\u5f8b\u90fd\u662f\u5ba2\u89c2\u7684\uff0c\u4e0d\u4ee5\u4eba\u7684\u610f\u5fd7\u4e3a\u8f6c\u79fb\u3002\u81ea\u7136\u89c4\u5f8b\u662f\u81ea\u53d1\u7684\uff0c\u800c\u793e\u4f1a\u89c4\u5f8b\u5219\u662f\u5fc5\u987b\u901a\u8fc7\u4eba\u7684\u6709\u610f\u8bc6\u7684\u6d3b\u52a8\u6765\u5b9e\u73b0\u7684\u3002</p>\\n\",\"options\":[\"<p>\u901a\u8fc7\u4eba\u7684\u6709\u610f\u8bc6\u7684\u6d3b\u52a8\u5b9e\u73b0\u7684</p>\\n\",\"<p>\u7531\u591a\u6570\u4eba\u7684\u610f\u5fd7\u51b3\u5b9a\u7684</p>\\n\",\"<p>\u6bd4\u81ea\u7136\u89c4\u5f8b\u66f4\u6613\u4e8e\u8ba4\u8bc6\u7684\u89c4\u5f8b</p>\\n\",\"<p>\u4e0d\u5177\u6709\u91cd\u590d\u6027\u7684\u5ba2\u89c2\u89c4\u5f8b</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":1214,\"rightCount\":1090,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":85,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":0,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1894,\"type\":\"1\",\"stem\":\"<p>\u793e\u4f1a\u751f\u4ea7\u662f\u8fde\u7eed\u4e0d\u65ad\u8fdb\u884c\u7684\uff0c\u8fd9\u79cd\u8fde\u7eed\u4e0d\u65ad\u91cd\u590d\u7684\u751f\u4ea7\u5c31\u662f\u518d\u751f\u4ea7\u3002\u6bcf\u6b21\u7ecf\u6d4e\u5371\u673a\u53d1\u751f\u671f\u95f4\uff0c\u603b\u6709\u8bb8\u591a\u4f01\u4e1a\u6216\u56e0\u4ea7\u54c1\u79ef\u538b\u3001\u6216\u56e0\u8ba2\u5355\u7f3a\u4e4f\u7b49\u81f4\u4f7f\u5176\u65e0\u6cd5\u7ee7\u7eed\u8fdb\u884c\u518d\u751f\u4ea7\u800c\u88ab\u8feb\u5012\u95ed\u3002\u90a3\u4e9b\u56e0\u4ea7\u54c1\u79ef\u538b\u800c\u5012\u95ed\u7684\u4f01\u4e1a\u4e3b\u8981\u662f\u7531\u4e8e\u65e0\u6cd5\u5b9e\u73b0\u5176\u751f\u4ea7\u8fc7\u7a0b\u4e2d\u7684</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u793e\u4f1a\u8d44\u672c\u518d\u751f\u4ea7\u7684\u6838\u5fc3\u95ee\u9898\u662f\u793e\u4f1a\u603b\u4ea7\u54c1\u7684\u5b9e\u73b0\u95ee\u9898\u3002\u793e\u4f1a\u603b\u4ea7\u54c1\u7684\u5b9e\u73b0\u95ee\u9898\u5373\u793e\u4f1a\u603b\u4ea7\u54c1\u7684\u8865\u507f\u95ee\u9898\uff0c\u5b83\u5305\u62ec\u4e24\u4e2a\u65b9\u9762:\u5176\u4e00\u4e3a\u4ef7\u503c\u8865\u507f\uff0c\u5176\u4e8c\u4e3a\u5b9e\u7269\u8865\u507f\u3002\u9898\u5e72\u4e2d\u5de5\u5382\u56e0\u4ea7\u54c1\u79ef\u538b\u6ca1\u6709\u5b9e\u73b0\u4f7f\u7528\u4ef7\u503c\u7684\u8f6c\u6362\uff0c\u662f\u6ca1\u6709\u5f97\u5230\u4ef7\u503c\u8865\u507f\u3002</p>\\n\",\"options\":[\"<p>\u5b9e\u7269\u8865\u507f</p>\\n\",\"<p>\u4ef7\u503c\u8865\u507f</p>\\n\",\"<p>\u589e\u6b96\u8865\u507f</p>\\n\",\"<p>\u52b3\u52a8\u8865\u507f</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1252,\"rightCount\":894,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":85,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":2,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1895,\"type\":\"1\",\"stem\":\"<p>\u4e0e\u7b2c\u4e8c\u6b21\u4e16\u754c\u5927\u6218\u524d\u7684\u8d44\u672c\u4e3b\u4e49\u76f8\u6bd4\uff0c\u5f53\u4ee3\u8d44\u672c\u4e3b\u4e49\u5728\u8bb8\u591a\u65b9\u9762\u5df2\u7ecf\u5e76\u6b63\u5728\u53d1\u751f\u7740\u6df1\u523b\u7684\u53d8\u5316\uff0c\u6b63\u786e\u5206\u6790\u8fd9\u4e9b\u65b0\u53d8\u5316\u53d1\u751f\u7684\u539f\u56e0\uff0c\u6709\u5229\u4e8e\u6211\u4eec\u79d1\u5b66\u800c\u5168\u9762\u5730\u8ba4\u8bc6\u5f53\u4ee3\u8d44\u672c\u4e3b\u4e49\u793e\u4f1a\u3002\u5bfc\u81f4\u5f53\u4ee3\u8d44\u672c\u4e3b\u4e49\u65b0\u53d8\u5316\u53d1\u751f\u7684\u6839\u672c\u63a8\u52a8\u529b\u91cf\u662f</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u5f53\u4ee3\u8d44\u672c\u4e3b\u4e49\u65b0\u53d8\u5316\u7684\u539f\u56e0\u6709:\u9996\u5148\u3001\u79d1\u5b66\u6280\u672f\u9769\u547d\u548c\u751f\u4ea7\u529b\u7684\u53d1\u5c55\uff0c\u662f\u8d44\u672c\u4e3b\u4e49\u53d8\u5316\u7684\u6839\u672c\u63a8\u52a8\u529b\u91cf\u3002\u5176\u6b21\uff0c\u5de5\u4eba\u9636\u7ea7\u4e89\u53d6\u81ea\u8eab\u5229\u76ca\u548c\u5229\u76ca\u6597\u4e89\u7684\u4f5c\u7528\uff0c\u662f\u63a8\u52a8\u8d44\u672c\u4e3b\u4e49\u53d8\u5316\u7684\u91cd\u8981\u529b\u91cf\u3002\u518d\u6b21\uff0c\u793e\u4f1a\u4e3b\u4e49\u5236\u5ea6\u521d\u6b65\u663e\u793a\u7684\u4f18\u8d8a\u6027\uff0c\u5bf9\u8d44\u672c\u4e3b\u4e49\u4ea7\u751f\u4e86\u4e00\u5b9a\u5f71\u54cd\u3002\u6700\u540e\uff0c\u4e3b\u5f20\u6539\u826f\u4e3b\u4e49\u7684\u653f\u515a\u5bf9\u8d44\u672c\u4e3b\u4e49\u5236\u5ea6\u7684\u6539\u9769\uff0c\u4e5f\u5bf9\u8d44\u672c\u4e3b\u4e49\u7684\u53d8\u5316\u53d1\u6325\u4e86\u91cd\u8981\u4f5c\u7528\u3002</p>\\n\",\"options\":[\"<p>\u5de5\u4eba\u9636\u7ea7\u4e89\u53d6\u81ea\u8eab\u6743\u5229\u7684\u6597\u4e89</p>\\n\",\"<p>\u79d1\u5b66\u6280\u672f\u9769\u547d\u548c\u751f\u4ea7\u529b\u7684\u53d1\u5c55</p>\\n\",\"<p>\u6539\u826f\u4e3b\u4e49\u653f\u515a\u5bf9\u8d44\u672c\u4e3b\u4e49\u5236\u5ea6\u7684\u6539\u9769</p>\\n\",\"<p>\u793e\u4f1a\u4e3b\u4e49\u5236\u5ea6\u7684\u4f18\u8d8a\u6027\u5bf9\u8d44\u672c\u4e3b\u4e49\u7684\u5f71\u54cd</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1203,\"rightCo