type,x-token,x-agent,x-platform,x-systemType,Authorization,x-sign,x-timestamp,x-appid", "name":"access-control-allow-headers"}, {"value":"theme,x-server-id,x-server-time", "name":"access-control-expose-headers"}, {"value":"#67cfcf", "name":"theme"}, {"value":"sae_3", "name":"x-server-id"}, {"value":"1774972749", "name":"x-server-time"}, {"value":"cluster2.1", "name":"x-cluster"}, {"value":"gzip", "name":"content-encoding"}, {"value":"*", "name":"access-control-allow-origin"}, {"value":"true", "name":"access-control-allow-credentials"}, {"value":"POST,GET,OPTIONS,DELETE,PUT,PATCH", "name":"access-control-request-method"}, {"value":"POST,GET,OPTIONS,DELETE,PUT,PATCH", "name":"access-control-allow-methods"}], "cookies":[], "redirectURL":"", "statusText":"200", "status":200, "httpVersion":"HTTP/2", "content":{"text":"{\"count\":33,\"totalPages\":1,\"pageSize\":33,\"currentPage\":1,\"data\":{\"questions\":[{\"id\":1690,\"type\":\"1\",\"stem\":\"<p>\u6069\u683c\u65af\u4e8e 1820 \u5e74 11 \u6708 28\\n\u65e5\u51fa\u751f\u5728\u5fb7\u56fd\u5df4\u95e8\u5e02\u7684\u4e00\u4e2a\u5de5\u5382\u4e3b\u5bb6\u5ead\u3002\u4ed6\u79f0\u81ea\u5df1\u4e00\u751f\u6240\u505a\u7684\u4e8b\u5c31\u662f&quot;\u62c9\u7b2c\u4e8c\u5c0f\u63d0\u7434&quot;\u3002\u6069\u683c\u65af\u4e0d\u4ec5\u4e0e\u9a6c\u514b\u601d\u4e00-\u8d77\u521b\u7acb\u9a6c\u514b\u601d\u4e3b\u4e49\uff0c\u53c2\u52a0\u5e76\u6307\u5bfc\u56fd\u9645\u5de5\u4eba\u8fd0\u52a8\uff0c\u800c\u4e14\u5728\u4f20\u64ad\u548c\u53d1\u5c55\u9a6c\u514b\u601d\u4e3b\u4e49\u65b9\u9762\u4f5c\u51fa\u4e86\u6770\u51fa\u7684\u8d21\u732e\u3002\u6069\u683c\u65af\u5168\u9762\u9610\u8ff0\u9a6c\u514b\u601d\u4e3b\u4e49\u7406\u8bba\u4f53\u7cfb\u7684\u8457\u4f5c\u662f</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u6069\u683c\u65af\u7684\u300a\u53cd\u675c\u6797\u8bba\u300b\u603b\u7ed3\u4e86\u9a6c\u514b\u601d\u4e3b\u4e49\u8bde\u751f\u540e\u65e0\u4ea7\u9636\u7ea7\u9769\u547d\u7684\u7ecf\u9a8c\u548c\u81ea\u7136\u79d1\u5b66\u53d1\u5c55\u7684\u6210\u5c31\uff0c\u7b2c\u4e00\u6b21\u5168\u9762\u7cfb\u7edf\u5730\u9610\u8ff0\u4e86\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u4e09\u4e2a\u7ec4\u6210\u90e8\u5206\uff0c\u662f\u4e00\u90e8\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u767e\u79d1\u5168\u4e66\u3002</p>\\n\",\"options\":[\"<p>\u300a\u5171\u4ea7\u515a\u5ba3\u8a00\u300b</p>\\n\",\"<p>\u300a\u5bb6\u5ead\u3001\u79c1\u6709\u5236\u548c\u56fd\u5bb6\u7684\u8d77\u6e90\u300b</p>\\n\",\"<p>\u300a\u53cd\u675c\u6797\u8bba\u300b</p>\\n\",\"<p>\u300a\u81ea\u7136\u8fa9\u8bc1\u6cd5\u300b</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":2846,\"rightCount\":2072,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":78,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":7,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1691,\"type\":\"1\",\"stem\":\"<p>\u9010\u6e10&quot;\u98de\u5165\u5bfb\u5e38\u767e\u59d3\u5bb6&quot;\u7684\u4eba\u5de5\u667a\u80fd\u5bf9\u4eba\u7c7b\u7684\u793e\u4f1a\u751f\u6d3b\u4ea7\u751f\u4e86\u5de8\u5927\u5f71\u54cd\u3002\u5bf9\u6b64\uff0c\u6280\u672f\u4e50\u89c2\u6d3e\u8ba4\u4e3a\u4eba\u5de5\u667a\u80fd\u4e3a\u4eba\u7c7b\u53d1\u5c55\u66f4\u65b0\u4e86&quot;\u53d1\u52a8\u673a&quot;\uff0c\u60b2\u89c2\u6d3e\u5219\u8ba4\u4e3a\u4eba\u5de5\u667a\u80fd\u7684\u53d1\u5c55\u53ef\u80fd\u5bfc\u81f4&quot;\u4eba\u7c7b\u7684\u7ec8\u7ed3&quot;\u3002\u5bf9\u4eba\u5de5\u667a\u80fd\u793e\u4f1a\u6548\u7528\u7684\u8bc4\u4ef7\u662f</p>\\n\",\"answer\":[3],\"analysis\":\"<p>\u4ef7\u503c\u8bc4\u4ef7\u662f\u4e00\u79cd\u5173\u4e8e\u4ef7\u503c\u73b0\u8c61\u7684\u8bc4\u4ef7\u6027\u8ba4\u8bc6\u6d3b\u52a8\uff0c\u662f\u4e3b\u4f53\u5bf9\u5ba2\u4f53\u4ef7\u503c\u4ee5\u53ca\u4ef7\u503c\u5927\u5c0f\u6240\u505a\u7684\u8bc4\u5224\u6216\u5224\u65ad\u3002\u4eba\u5de5\u667a\u80fd\u6280\u672f\u7684\u53d1\u5c55\u5bf9\u4eba\u7c7b\u751f\u6d3b\u4ea7\u751f\u4e86\u5f71\u54cd\uff0c\u4eba\u4eec\u5728\u5bf9\u4eba\u5de5\u667a\u80fd\u6280\u672f\u8bc4\u4ef7\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u4e86&quot;\u4e50\u89c2&quot;\u548c&quot;\u60b2\u89c2&quot;\u7684\u4e0d\u540c\u770b\u6cd5\uff0c\u8fd9\u662f\u4eba\u4eec\u5728\u5bf9\u4e8b\u7269\u8fdb\u884c\u4ef7\u503c\u8bc4\u4ef7\u3002\u56e0\u6b64\u672c\u9898\u9009\\nD\u3002</p>\\n\",\"options\":[\"<p>\u5bf9\u5ba2\u89c2\u53d1\u5c55\u89c4\u5f8b\u7684\u771f\u7406\u6027\u8bc4\u4ef7</p>\\n\",\"<p>\u5bf9\u4e3b\u4f53\u53d1\u5c55\u7a0b\u5ea6\u7684\u8ba4\u77e5\u6027\u8bc4\u4ef7</p>\\n\",\"<p>\u53d7\u4e3b\u4f53\u60c5\u611f\u7684\u4e3b\u89c2\u6027\u8bc4\u4ef7</p>\\n\",\"<p>\u4ef7\u503c\u6027\u8bc4\u4ef7</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":4,\"studCount\":2812,\"rightCount\":1280,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":78,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":9,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1692,\"type\":\"1\",\"stem\":\"<p>\u5728\u76f8\u540c\u7684\u52b3\u52a8\u65f6\u95f4\u91cc\uff0c\u590d\u6742\u52b3\u52a8\u521b\u9020\u7684\u4ef7\u503c\u5927\u4e8e\u7b80\u5355\u52b3\u52a8\u521b\u9020\u7684\u4ef7\u503c\u3002\u5728\u4ee5\u79c1\u6709\u5236\u4e3a\u57fa\u7840\u7684\u5546\u54c1\u7ecf\u6d4e\u6761\u4ef6\u4e0b\uff0c\u590d\u6742\u52b3\u52a8\u8f6c\u5316\u4e3a\u7b80\u5355\u52b3\u52a8</p>\\n\",\"answer\":[3],\"analysis\":\"<p>\u590d\u6742\u52b3\u52a8\u8f6c\u5316\u4e3a\u7b80\u5355\u52b3\u52a8\uff0c\u662f\u5728\u5546\u54c1\u4ea4\u6362\u8fc7\u7a0b\u4e2d\u81ea\u53d1\u5b9e\u73b0\u7684\uff0c\u5728\u5546\u54c1\u4ea4\u6362\u8fc7\u7a0b\u4e2d\u5e02\u573a\u673a\u5236\u548c\u4ef7\u503c\u89c4\u5f8b\u662f\u8d44\u6e90\u914d\u7f6e\u7684\u51b3\u5b9a\u6027\u624b\u6bb5\u3002\u6545\u672c\u9898\u9009\\nD\u3002</p>\\n\",\"options\":[\"<p>\u662f\u5546\u54c1\u751f\u4ea7\u8005\u81ea\u89c9\u8ba1\u7b97\u51fa\u6765</p>\\n\",\"<p>\u662f\u5e02\u573a\u7ba1\u7406\u90e8\u95e8\u4e8b\u5148\u89c4\u5b9a\u7684</p>\\n\",\"<p>\u662f\u5546\u54c1\u751f\u4ea7\u8005\u534f\u5546\u51fa\u6765\u7684</p>\\n\",\"<p>\u662f\u5e02\u573a\u673a\u5236\u81ea\u53d1\u5b9e\u73b0\u7684</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":2599,\"rightCount\":2172,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":78,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":3,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1693,\"type\":\"1\",\"stem\":\"<p>\u5341\u6708\u9769\u547d\u4e4b\u524d\uff0c\u5217\u5b81\u603b\u7ed3\u5f53\u65f6\u53d8\u5316\u4e86\u7684\u65b0\u60c5\u51b5\uff0c\u5f97\u51fa&quot;\u793e\u4f1a\u4e3b\u4e49\u53ef\u80fd\u9996\u5148\u5728\u5c11\u6570\u751a\u81f3\u5728\u5355\u72ec\u4e00\u4e2a\u8d44\u672c\u4e3b\u4e49\u56fd\u5bb6\u5185\u83b7\u5f97\u80dc\u5229&quot;\u7684\u7ed3\u8bba\u3002\u5217\u5b81\u5f97\u51fa\u8fd9\u7ed3\u8bba\u7684\u7406\u8bba\u4f9d\u636e\u662f</p>\\n\",\"answer\":[0],\"analysis\":\"<p>\u5217\u5b81\u9