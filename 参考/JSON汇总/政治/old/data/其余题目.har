6\u5e94\u8be5\u4e86\u89e3\u5728\u6211\u56fd\u519c\u6751\u5b9e\u884c\u7684\u5bb6\u5ead\u8054\u4ea7\u627f\u5305\u8d23\u4efb\u5236\u6ca1\u6709\u53d8\uff0cB\u9009\u9879\u662f\u9519\u7684\u3002\u571f\u5730\u7ecf\u8425\u6743\u7684\u6d41\u8f6c\u5e76\u6ca1\u6709\u4f7f\u519c\u6c11\u5931\u53bb\u4e86\u5bf9\u571f\u5730\u7684\u627f\u5305\u6743\uff0c\u56e0\u4e3a\u4ece\u6839\u672c\u4e0a\u6211\u4eec\u7684\u5bb6\u5ead\u8054\u4ea7\u627f\u5305\u8d23\u4efb\u5236\u6ca1\u6709\u53d8\uff0c\u8fd8\u662f\u519c\u6c11\u62e5\u6709\u5bf9\u571f\u5730\u7684\u627f\u5305\u6743\u3002</p>\\n\",\"options\":[\"<p>\u519c\u4e1a\u7ecf\u8425\u4e3b\u4f53\u5448\u73b0\u591a\u6837\u5316\u8d8b\u52bf</p>\\n\",\"<p>\u571f\u5730\u7684\u96c6\u4f53\u6240\u6709\u6743\u6027\u8d28\u5df2\u7ecf\u53d1\u751f\u53d8\u5316</p>\\n\",\"<p>\u5bb6\u5ead\u627f\u5305\u7ecf\u8425\u4ecd\u7136\u662f\u6700\u57fa\u672c\u7684\u7ecf\u8425\u5f62\u5f0f</p>\\n\",\"<p>\u571f\u5730\u7ecf\u8425\u6743\u7684\u6d41\u8f6c\u4f7f\u519c\u6c11\u5931\u53bb\u4e86\u5bf9\u571f\u5730\u7684\u627f\u5305\u6743</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":2,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":1081,\"rightCount\":765,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":84,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":2,\"pType\":\"2\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1882,\"type\":\"2\",\"stem\":\"<p>\u4e0e\u5341\u4e00\u5c4a\u5168\u56fd\u4eba\u6c11\u4ee3\u8868\u5927\u4f1a\u76f8\u6bd4\uff0c\u5341\u4e8c\u5c4a\u4eba\u4ee3\u4f1a\u5728\u4ee3\u8868\u7ed3\u6784\u4e0e\u7ec4\u6210\u4e0a\uff0c\u5448\u73b0&quot;\u4e24\u5347\u4e00\u