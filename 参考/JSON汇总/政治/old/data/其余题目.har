uff0c\u662f\u56e0\u4e3a\u6709\u4e86\u76d0\uff0c\u52a0\u4e00\u70b9\u70b9\u5c31\u5982\u6b64\u9c9c\u7f8e\uff0c\u5982\u679c\u52a0\u66f4\u591a\u7684\u76d0\uff0c\u5c82\u4e0d\u66f4\u52a0\u597d\u5403?&quot;\u56de\u5bb6\u4e4b\u540e\uff0c\u4ed6\u628a\u4e00\u628a\u76d0\u653e\u8fdb\u5634\u91cc\uff0c\u7ed3\u679c\u53c8\u82e6\u53c8\u54b8\u3002\u8fd9\u5219\u5bd3\u8a00\u7ed9\u6211\u4eec\u7684\u542f\u793a\u662f</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u5ea6\u662f\u8d28\u548c\u91cf\u7684\u7edf\u4e00,\u662f\u4e8b\u7269\u4fdd\u6301\u81ea\u5df1\u8d28\u7684\u7a33\u5b9a\u6027\u7684\u6570\u91cf\u754c\u9650,\u5373\u4e8b\u7269\u7684\u8303\u56f4\u3001\u5e45\u5ea6\u548c\u9650\u5ea6\u3002\u9898\u5e72\u4e2d\u611a\u4eba\u7684\u505a\u6cd5\u8d85\u51fa\u4e86\u5ea6,\u6ca1\u6709\u628a\u63e1\u597d\u9002\u5ea6\u7684\u539f\u5219\u3002</p>\\n\",\"options\":[\"<p>\u5728\u4e8b\u7269\u7684\u53d1\u5c55\u8fc7\u7a0b\u4e2d\u8981\u65f6\u65f6\u6ce8\u610f\u4e8b\u7269\u7684\u81ea\u6211\u5426\u5b9a</p>\\n\",\"<p>\u5728\u8ba4\u8bc6\u548c\u5904\u7406\u95ee\u9898\u65f6\u8981\u638c\u63e1\u9002\u5ea6\u7684\u539f\u5219</p>\\n\",\"<p>\u4e0d\u53ef\u80fd\u901a\u8fc7\u4e00\u4e9b\u73b0\u8c61\u800c\u53bb\u8ba4\u8bc6\u67d0\u4e2a\u4e8b\u7269\u7684\u672c\u8d28</p>\\n\",\"<p>\u6301\u7eed\u7684\u91cf\u53d8\u4f1a\u5f15\u8d77\u4e8b\u7269\u53d1\u751f\u8d28\u7684\u53d8\u5316</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":1310,\"rightCount\":1201,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":83,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":1,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1827,\"type\":\"1\",\"stem\":\"<p>\u6709\u4e00\u79cd\u89c2\u70b9\u8ba4\u4e3a\uff0c&quot;\u81ea\u7531\u4e0d\u5728\u4e8e\u5e7b\u60f3\u4e2d\u6446\u8131\u81ea\u7136\u89c4\u5f8b\u800c\u72ec\u7acb\uff0c\u800c\u5728\u4e8e\u8ba4\u8bc6\u8fd9\u4e9b\u89c4\u5f8b\uff0c\u4ece\u800c\u80fd\u591f\u6709\u8ba1\u5212\u5730\u4f7f\u81ea\u7136\u89c4\u5f8b\u4e3a\u4e00\u5b9a\u7684\u76ee\u7684\u670d\u52a1&quot;\u3002\u8fd8\u6709\u4e00\u79cd\u89c2\u70b9\u8ba4\u4e3a\uff0c&quot;'\u81ea\u7531'\uff0c\u5012\u8fc7\u6765\u5c31\u662f'\u7531\u81ea'\uff0c\u56e0\u6b64'\u81ea\u7531'\u7b49\u4e8e'\u7531\u81ea'\uff0c'\u7531\u81ea'\u5373\u662f\u968f\u5fc3\u6240\u6b32&quot;\u3002\u8fd9\u4e24\u79cd\u5173\u4e8e\u81ea\u7531\u7684\u89c2\u70b9</p>\\n\",\"answer\":[3],\"analysis\":\"<p>\u54f2\u5b66\u4e2d\u7684\u81ea\u7531\u662f\u8868\u793a\u4eba\u7684\u6d3b\u52a8\u72b6\u6001\u7684\u8303\u7574\u3002\u9898\u5e72\u4e2d\u7684\u524d\u4e00\u79cd\u89c2\u70b9\u662f\u7531\u6069\u683c\u65af\u63d0\u51fa\u7684\\n\u5f3a\u8c03&quot;\u81ea\u7531\u5728\u4e8e\u8ba4\u8bc6\u89c4\u5f8b\u5e76\u5229\u7528\u89c4\u5f8b&quot;,\u5c5e\u4e8e\u552f\u7269\u8bc1\u6cd5\u7684\u8303\u7574\u3002\u540e\u4e00\u79cd\u89c2\u70b9\u8ba4\u4e3a&quot;\u7531\u81ea\u5373\u662f\u968f\u5fc3\u6240\u6b32&quot;,\u5ffd\u89c6\u4e86\u5ba2\u89c2\u89c4\u5f8b\u6027,\u7247\u9762\u5f3a\u8c03\u4eba\u7684\u4e3b\u89c2\u610f\u5fd7,\u5c5e\u4e8e\u552f\u5fc3\u4e3b\u4e49\u7684\u89c2\u70b9\u6216\u8005\u552f\u610f\u5fd7\u8bba\u3002</p>\\n\",\"options\":[\"<p>\u524d\u8005\u662f\u5386\u53f2\u552f\u5fc3\u4e3b\u4e49\u7684\u89c2\u70b9\uff0c\u540e\u8005\u662f\u5386\u53f2\u552f\u7269\u4e3b\u4e49\u7684\u89c2\u70b9</p>\\n\",\"<p>\u524d\u8005\u662f\u673a\u68b0\u552f\u7269\u4e3b\u4e49\u7684\u89c2\u70b9\uff0c\u540e\u8005\u662f\u552f\u5fc3\u4e3b\u4e49\u7684\u89c2\u70b9</p>\\n\",\"<p>\u524d\u8005\u662f\u4e3b\u89c2\u552f\u5fc3\u4e3b\u4e49\u7684\u89c2\u70b9\uff0c\u540e\u8005\u662f\u552f\u7269\u8fa9\u8bc1\u6cd5\u7684\u89c2\u70b9</p>\\n\",\"<p>\u524d\u8005\u662f\u552f\u7269\u8fa9\u8bc1\u6cd5\u7684\u89c2\u70b9\uff0c\u540e\u8005\u662f\u552f\u610f\u5fd7\u8bba\u7684\u89c2\u70b9</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":1295,\"rightCount\":1080,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":83,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":1,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1828,\"type\":\"1\",\"stem\":\"<p>\u67d0\u8d44\u672c\u5bb6\u6295\u8d44100\u4e07\u5143\u521b\u529e\u4f01\u4e1a\u4ece\u4e8b\u751f\u4ea7\uff0c60\u4e07\u5143\u7528\u4e8e\u56fa\u5b9a\u8d44\u672c\u3001\u4ee5\u8d2d\u4e70\u673a\u5668\u8bbe\u5907\u7b49\uff0c40\u4e07\u5143\u7528\u4e8e\u6d41\u52a8\u8d44\u672c\u3001\u4ee5\u8d2d\u4e70\u539f\u6750\u6599\u548c\u52b3\u52a8\u529b\u7b49\uff08\u5176\u4e2d\u8d2d\u4e70\u52b3\u52a8\u529b\u652f\u4ed8\u4e8610\u4e07\u5143\uff09\uff0c\u4e00\u8f6e\u751f\u4ea7\u7ed3\u675f\u540e\uff0c\u8be5\u4f01\u4e1a\u7684\u603b\u8d44\u672c\u8fbe\u5230\u4e86120\u4e07\u5143\u3002\u90a3\u4e48\uff0c\u8be5\u4f01\u4e1a\u7684\u5269\u4f59\u4ef7\u503c\u7387\u4e3a</p>\\n\",\"answer\":[0],\"analysis\":\"<p>\u5269\u4f59\u4ef7\u503c\u7387\u4e3a\u5269\u4f59\u4ef7\u503c\u4e0e\u53ef\u53d8\u8d44\u672c(\u8d2d\u4e70\u52a8\u529b\u7684\u8d44\u672c)\u7684\u6bd4\u503c\u3002\u6839\u636e\u9898\u5e72\u53ef\u77e5\u5269\u4f59\u4ef7\u503c=\u4f01\u4e1a\u603b\u8d44\u672c\u4e00\u9884\u4ed8\u606f\u8d44\u672c=120-100=20(\u4e07\u5143),\u8d2d\u5934\u52b3\u52a8\u529b\u8d44\u672c(\u53ef\u53d8\u8d44\u672c)\u4e3a10\u4e07\u5143,\u5219\u5269\u4f59\u4ef7\u503c\u7387=20/10=200%\u3002</p>\\n\",\"options\":[\"<p>200%</p>\\n\",\"<p>50%</p>\\n\",\"<p>100%</p>\\n\",\"<p>20%</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":1253,\"rightCount\":889,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":83,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":2,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1829,\"type\":\"1\",\"stem\":\"<p>20\u4e16\u7eaa70\u5e74\u4ee3\u4ee5\u6765\uff0c\u897f\u65b9\u8d44\u672c\u4e3b\u4e49\u56fd\u5bb6\u7684\u91d1\u878d\u8d44\u672c\u6025\u5267\u81a8\u80c0\uff0c\u8fd9\u4e00\u65b9\u9762\u4fc3\u8fdb\u4e86\u8d44\u672c\u4e3b\u4e49\u7684\u53d1\u5c55\uff0c\u53e6\u4e00\u65b9\u9762\u4e5f\u9020\u6210\u4e86\u7ecf\u6d4e\u8fc7\u5ea6\u865a\u62df\u5316\uff0c\u81f4\u4f7f\u91d1\u878d\u5371\u673a\u9891\u7e41\u53d1\u751f\u3002\u897f\u65b9\u8d44\u672c\u4e3b\u4e49\u91d1\u878d\u8d44\u672c\u5feb\u901f\u53d1\u5c55\u58ee\u5927\u7684\u91cd\u8981\u5236\u5ea6\u6761\u4ef6\u662f</p>\\n\",\"answer\":[3],\"analysis\":\"<p>20\u4e16\u7eaa70\u5e74\u4ee3\u521d,\u7531\u4e8e\u8d44\u672c\u4e3b\u4e49\u53d1\u5c55\u4e0d\u5e73\u8861\u7684\u52a0\u6df1\u548c\u56fd\u9645\u8d27\u5e01\u4f53\u7cfb\u5185\u5728\u77db\u76fe\u7684\u6fc0\u5316,\u5e03\u96f7\u987f\u68ee\u6797\u4f53\u7cfb\u6e83\u3002\u968f\u540e,\u897f\u65b9\u56fd\u5bb6\u666e\u904d\u8d70\u4e0a\u4e86\u91d1\u878d\u81ea\u7531\u5316\u548c\u91d1\u878d\u521b\u65b0\u7684\u9053\u8def\u3002\u91d1\u878d\u81ea\u7531\u5316\u4e0e\u91d1\u878d\u521b\u65b0\u662f\u91d1\u878d\u5784\u65ad\u8d44\u672c\u5f97\u4ee5\u5f62\u6210\u548c\u58ee\u5927\u7684\u91cd\u8981\u5236\u5ea6\u6761\u4ef6,\u63a8\u52a8\u7740\u8d44\u672c\u4e3b\u4e49\u7ecf\u6d4e\u7684\u91d1\u878d\u5316\u7a0b\u5ea6\u4e0d\u65ad\u63d0\u9ad8\u3002</p>\",\"options\":[\"<p>\u53bb\u5de5\u4e1a\u5316\u4e0e\u5927\u529b\u53d1\u5c55\u73b0\u4ee3\u670d\u52a1\u4e1a</p>\\n\",\"<p>\u6280\u672f\u521b\u65b0\u4e0e\u5927\u529b\u53d1\u5c55\u4e92\u8054\u7f51\u91d1\u878d</p>\\n\",\"<p>\u5168\u9762\u79c1\u6709\u5316\u4e0e\u653e\u677e\u91d1\u878d\u76d1\u7ba1</p>\\n\",\"<p>\u91d1\u878d\u81ea\u7531\u5316\u4e0e\u91d1\u878d\u521b\u65b0</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":1282,\"rightCount\":905,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":83,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":1830,\"type\":\"1\",\"stem\":\"<p>\u6bdb\u6cfd\u4e1c\u601d\u60f3\u548c\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\u7406\u8bba\u4f53\u7cfb\u662f\u9a6c\u514b\u601d\u4e3b\u4e49\u4e2d\u56fd\u5316\u7684\u4e24\u5927\u7406\u8bba\u6210\u679c\u3002\u8d2f\u7a7f\u8fd9\u4e24\u5927\u7406\u8bba\u6210\u679c\u59cb\u7ec8\uff0c\u5e76\u4f53\u73b0\u5728\u4e24\u5927\u6210\u679c\u5404\u4e2a\u57fa\u672c\u89c2\u70b9\u4e2d\u7684\u4e16\u754c\u89c2\u548c\u65b9\u6cd5\u8bba\u7684\u57fa\u7840\u662f</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u4e2d\u56fd\u5316\u4e24\u4eba\u7406\u8bba\u6210\u679c---\u6bdb\u6cfd\u4e1c\u601d\u60f3\u548c\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\u7406\u8bba\u4f53\u7cfb\u7684\u7cbe\\n\u9ad3\u662f\u5b9e\u4e8b\u6c42\u662f\u3002\u5b9e\