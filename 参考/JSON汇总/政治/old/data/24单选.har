u4f7f\u9a6c\u514b\u601d\u4e3b\u4e49\u8fd9\u4e2a\u9b42\u8109\u548c\u4e2d\u534e\u4f18\u79c0\u4f20\u7edf\u6587\u5316\u8fd9\u4e2a\u6839\u8109\u5185\u5728\u8d2f\u901a\u3001\u76f8\u4e92\u6210\u5c31\uff0c\u662f\u4e2d\u534e\u6c11\u65cf\u7684\u6587\u5316\u4e3b\u4f53\u6027\u6700\u6709\u529b\u7684\u4f53\u73b0\uff0c\u662f\u4e2d\u534e\u6587\u5316\u548c\u4e2d\u56fd\u7cbe\u795e\u7684\u65f6\u4ee3\u7cbe\u534e\u3002\u6240\u4ee5\uff0c\u6b63\u786e\u7b54\u6848\u4e3aA\u3002</p>\\n\",\"options\":[\"<p>\u9a6c\u514b\u601d\u4e3b\u4e49\u548c\u4e2d\u534e\u4f18\u79c0\u4f20\u7edf\u6587\u5316</p>\\n\",\"<p>\u5171\u4ea7\u4e3b\u4e49\u793e\u4f1a\u7406\u60f3\u548c&quot;\u5929\u4e0b\u5927\u540c&quot;\u7406\u60f3</p>\\n\",\"<p>\u5168\u4eba\u7c7b\u5171\u540c\u4ef7\u503c\u548c\u793e\u4f1a\u4e3b\u4e49\u6838\u5fc3\u4ef7\u503c\u89c2</p>\\n\",\"<p>\u5171\u4ea7\u4e3b\u4e49\u8fdc\u5927\u7406\u60f3\u548c\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\u5171\u540c\u7406\u60f3</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":7147,\"rightCount\":6327,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":5,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38725,\"type\":\"1\",\"stem\":\"<p>\u4e00\u4e2a\u5730\u65b9\u7684\u6c14\u5019\u4e3b\u8981\u53d6\u51b3\u4e8e\u7eac\u5ea6\u3001\u6d77\u9646\u4f4d\u7f6e\u3001\u5730\u5f62\uff0c\u4ee5\u53ca\u5927\u6c14\u73af\u6d41\u548c\u6d0b\u6d41\u7b49\u56e0\u7d20\u3002\u7eac\u5ea6\u3001\u6d77\u9646\u4f4d\u7f6e\u3001\u5730\u5f62\u7b49\u56e0\u7d20\u5728\u4e00\u5b9a\u65f6\u671f\u5185\u57fa\u672c\u4fdd\u6301\u4e0d\u53d8\uff0c\u5927\u6c14\u73af\u6d41\u4e0e\u6d0b\u6d41\u4e8c\u8005\u76f8\u4e92\u4f5c\u7528\u5c31\u5f62\u6210\u76f8\u5bf9\u7a33\u5b9a\u7684\u6c14\u5019\u72b6\u6001\uff0c\u4f46\u5f53\u5176\u4e2d\u4e00\u4e2a\u56e0\u7d20\u7a81\u7136&quot;\u6389\u94fe\u5b50&quot;,\u5c31\u4f1a\u53d1\u751f\u5384\u5c14\u5c3c\u8bfa\u4e4b\u7c7b\u7684\u5f02\u5e38\u73b0\u8c61\u3002\u5384\u5c14\u5c3c\u8bfa\u73b0\u8c61\u4e0d\u4ec5\u63a8\u9ad8\u5168\u7403\u53d8\u6696\u5e45\u5ea6\uff0c\u66f4\u53ef\u80fd\u5bfc\u81f4\u9891\u6b21\u66f4\u591a\u3001\u8303\u56f4\u66f4\u5e7f\u3001\u5f3a\u5ea6\u66f4\u5927\u7684\u6781\u7aef\u5929\u6c14\uff0c\u8fdb\u800c\u5f71\u54cd\u5168\u7403\u6c14\u5019\u3002\u5384\u5c14\u5c3c\u8bfa\u73b0\u8c61\u5bf9\u5168\u7403\u6c14\u5019\u7684\u5f71\u54cd\u8868\u660e\uff0c\u5076\u7136\u56e0\u7d20\u662f(\u2003\u2003)</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u5fc5\u7136\u6027\u662f\u6307\u5ba2\u89c2\u4e8b\u7269\u8054\u7cfb\u548c\u53d1\u5c55\u8fc7\u7a0b\u4e2d\u5408\u4e4e\u89c4\u5f8b\u7684\u3001\u4e00\u5b9a\u8981\u53d1\u751f\u7684\u3001\u786e\u5b9a\u4e0d\u79fb\u7684\u8d8b\u52bf\u3002\u5fc5\u7136\u6027\u5c31\u662f\u89c4\u5f8b\u6027\u3002\u5076\u7136\u6027\u662f\u6307\u5ba2\u89c2\u4e8b\u7269\u8054\u7cfb\u548c\u53d1\u5c55\u8fc7\u7a0b\u4e2d\u4e0d\u786e\u5b9a\u7684\u8d8b\u52bf\u3002\u4e24\u8005\u7684\u7edf\u4e00\u8868\u73b0\u4e3a\u5fc5\u7136\u6027\u5b58\u5728\u4e8e\u5076\u7136\u6027\u4e4b\u4e2d\uff0c\u5fc5\u7136\u6027\u901a\u8fc7\u5076\u7136\u6027\u8868\u73b0\u51fa\u6765;\u5076\u7136\\n\u6027\u662f\u5fc5\u7136\u6027\u7684\u8865\u5145\u548c\u8868\u73b0\u5f62\u5f0f\uff0c\u5076\u7136\u6027\u7684\u80cc\u540e\u9690\u85cf\u7740\u5fc5\u7136\u6027\uff0c\u5076\u7136\u6027\u53d7\u5185\u90e8\u5fc5\u7136\u6027\u7684\u652f\u914d\u3002\u4e8c\u8005\u5728\u4e00\u5b9a\u6761\u4ef6\u4e0b\u53ef\u4ee5\u76f8\u4e92\u8f6c\u5316\u3002\u6240\u4ee5\uff0c\u6b63\u786e\u7b54\u6848\u4e3aC\u3002</p>\\n\",\"options\":[\"<p>\u51b3\u5b9a\u4e8b\u7269\u53d1\u5c55\u8d8b\u52bf\u7684\u6839\u672c\u6027\u56e0\u7d20</p>\\n\",\"<p>\u4e8b\u7269\u53d1\u5c55\u4e2d\u53ef\u6709\u53ef\u65e0\u7684\u5f71\u54cd\u56e0\u7d20</p>\\n\",\"<p>\u4e8b\u7269\u53d1\u5c55\u4e2d\u4e0d\u53ef\u5ffd\u89c6\u7684\u5f71\u54cd\u56e0\u7d20</p>\\n\",\"<p>\u4e8b\u7269\u53d1\u5c55\u8fc7\u7a0b\u4e2d\u786e\u5b9a\u4e0d\u79fb\u7684\u56e0\u7d20</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":6856,\"rightCount\":6601,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":4,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38726,\"type\":\"1\",\"stem\":\"<p>\u9664\u4e86\u51e0\u5341\u9897\u536b\u661f\u7f16\u7ec7\u7684&quot;\u5929\u4e0a\u4e00\u5f20\u7f51&quot;,\u8fd8\u6709\u5730\u57fa\u589e\u5f3a\u7cfb\u7edf\u6784\u6210\u7684&quot;\u5730\u4e0a\u4e00\u5f20\u7f51&quot;,\u5317\u6597\u536b\u661f\u5bfc\u822a\u7cfb\u7edf\u5f00\u542f\u4e86\u9ad8\u7cbe\u5ea6\u5b9a\u4f4d\u6280\u672f\u8fdb\u6b65\u7684&quot;\u52a0\u901f\u5ea6&quot;\u3002\u6709\u4e86&quot;\u5929\u4e0a\u4e00\u5f20\u7f51&quot;,\u4e3a\u4ec0\u4e48\u8fd8\u8981\u518d\u5efa&quot;\u5730\u4e0a\u4e00\u5f20\u7f51&quot;?\u4f20\u7edf\u7684\u536b\u661f\u5bfc\u822a\u7cfb\u7edf\u80fd\u63d0\u4f9b\u7684\u7cbe\u5ea6\u4ec5\u4e3a5~10\u7c73\uff0c\u800c\u5317\u6597\u536b\u661f\u5bfc\u822a\u7cfb\u7edf\u53ef\u4ee5\u5b9e\u73b0\u63d0\u4f9b\u5b9e\u65f6\u7c73\u7ea7\u3001\u5206\u7c73\u7ea7\u3001\u5398\u7c73\u7ea7\u7684\u66f4\u9ad8\u7cbe\u5ea6\u7684\u5b9a\u4f4d\u670d\u52a1\u3002\u4ece\u519c\u6797\u7267\u6e14\u5230\u5403\u7a7f\u4f4f\u884c\uff0c\u968f\u7740\u5317\u6597\u536b\u661f\u5bfc\u822a\u82af\u7247\u6216\u6a21\u5757\u8d8a\u6765\u8d8a\u591a\u5d4c\u5165\u751f\u4ea7\u751f\u6d3b\uff0c\u6bcf\u4e00\u4e2a\u4eba\u90fd\u6108\u53d1\u6e05\u6670\u5730\u611f\u77e5\u5230\u5317\u6597\u7684\u529b\u91cf\u3002\u5317\u6597\u536b\u661f\u5bfc\u822a\u7cfb\u7edf\u5728\u53d1\u5c55\u4e2d\u5e94\u7528\u3001\u5728\u5e94\u7528\u4e2d\u53d1\u5c55\u8868\u660e\uff0c\u6280\u672f\u8fdb\u6b65\u7684\u6839\u672c\u52a8\u529b\u662f(\u2003\u2003)</p>\\n\",\"answer\":[3],\"analysis\":\"<p>\u5b9e\u8df5\u662f\u8ba4\u8bc6\u53d1\u5c55\u7684\u52a8\u529b\uff0c\u9996\u5148\uff0c\u5b9e\u8df5\u7684\u53d1\u5c55\u4e0d\u65ad\u5730\u63d0\u51fa\u8ba4\u8bc6\u7684\u65b0\u8bfe\u9898\uff0c\u63a8\u52a8\u7740\u8ba4\u8bc6\u5411\u524d\u53d1\u5c55\u3002\u5176\u6b21\uff0c\u5b9e\u8df5\u4e3a\u8ba4\u8bc6\u53d1\u5c55\u63d0\u4f9b\u5fc5\u8981\u7684\u6761\u4ef6\u3002\u6700\u540e\uff0c\u5b9e\u8df5\u953b\u70bc\u548c\u63d0\u9ad8\u4e86\u4e3b\u4f53\u7684\u8ba4\u8bc6\u80fd\u529b\u3002\u5176\u4e2d\u793e\u4f1a\u5b9e\u8df5\u7684\u9700\u8981\u4f1a\u4ea7\u751f\u65b0\u7684\u8bfe\u9898\uff0c\u56e0\u6b64\uff0c\u79d1\u6280\u8fdb\u6b65\u7684\u6839\u672c\u52a8\u529b\u662f\u793e\u4f1a\u5b9e\u8df5\u7684\u9700\u8981\u3002\u56e0\u6b64D\u9879\u6b63\u786e\u3002\u6240\u4ee5\uff0c\u6b63\u786e\u7b54\u6848\u4e3aD\u3002</p>\\n\",\"options\":[\"<p>\u79d1\u5b66\u7814\u7a76\u7684\u89c4\u8303</p>\\n\",\"<p>\u5b9e\u8df5\u4e3b\u4f53\u7684\u610f\u5fd7</p>\\n\",\"<p>\u8ba4\u8bc6\u4e3b\u4f53\u7684\u5174\u8da3</p>\\n\",\"<p>\u793e\u4f1a\u5b9e\u8df5\u7684\u9700\u8981</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":6764,\"rightCount\":6256,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":3,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38727,\"type\":\"1\",\"stem\":\"<p>\u5217\u5b81\u5728\u8c08\u5230\u672a\u6765\u793e\u4f1a\u65f6\u5199\u9053\uff0c\\n&quot;\u751f\u4ea7\u529b\u5c06\u4ee5\u4ec0\u4e48\u6837\u7684\u901f\u5ea6\u5411\u524d\u53d1\u5c55\uff0c\u5c06\u4ee5\u4ec0\u4e48\u6837\u7684\u901f\u5ea6\u53d1\u5c55\u5230\u6253\u7834\u5206\u5de5\u3001\u6d88\u706d\u8111\u529b\u52b3\u52a8\u548c\u4f53\u529b\u52b3\u52a8\u7684\u5bf9\u7acb\u3001\u628a\u52b3\u52a8\u53d8\u4e3a'\u751f\u6d3b\u7684\u7b2c\u4e00\u9700\u8981',\u8fd9\u90fd\u662f\u6211\u4eec\u6240\u4e0d\u77e5\u9053\u800c\u4e14\u4e5f\u4e0d\u53ef\u80fd\u77e5\u9053\u7684&quot;,\\n&quot;\u6211\u4eec\u53ea\u80fd\u8c08\u56fd\u5bb6\u6d88\u4ea1\u7684\u5fc5\u7136\u6027\uff0c\u540c\u65f6\u7740\u91cd\u6307\u51fa\u8fd9\u4e2a\u8fc7\u7a0b\u662f\u957f\u671f\u7684\uff0c\u6307\u51fa\u5b83\u7684\u957f\u77ed\u5c06\u53d6\u51b3\u4e8e\u5171\u4ea7\u4e3b\u4e49\u9ad8\u7ea7\u9636\u6bb5\u7684\u53d1\u5c55\u901f\u5ea6\uff0c\u800c\u628a\u6d88\u706d\u7684\u65e5\u671f\u6216\u6d88\u4ea1\u7684\u5177\u4f53\u5f62\u5f0f\u4f5c\u4e3a\u60ac\u6848\uff0c\u56e0\u4e3a\u73b0\u5728\u8fd8\u6ca1\u6709\u53ef\u4f9b\u89e3\u51b3\u8fd9\u4e9b\u95ee\u9898\u7684\u6750\u6599&quot;\u3002\u8fd9\u8868\u660e\uff0c\u5217\u5b81\u5728\u5c55\u671b\u672a\u6765\u793e\u4f1a\u65f6(\u2003\u2003)</p>\\n\",\"answer\":[3],\"analysis\":\"<p>\u5217\u5b81\u5e76\u6ca1\u6709\u63ed\u793a\u793e\u4f1a\u5386\u53f2\u7684\u5404\u9879\u4e3e\u63aa\u65b9\u5f0f\u7b49\uff0c\u56e0\u6b64A\u9879\u9519\u8bef;\u5217\u5b81\u7ee7\u627f\u4e86\u9a6c\u514b\u601d\u4e3b\u4e49\u7684\u552f\u7269\u53f2\u89c2\uff0c\u8ba4\u4e3a\u4eba\u7c7b\u793e\u4f1a\u5b58\u5728\u5ba2\u89c2\u7684\u53d1\u5c55\u89c4\u5f8b\uff0c\u56e0\u6b64B\u9879\u9519\u8bef;\u5217\u5b81\u63ed\u793a\u4e86\u672a\u6765\u793e\u4f1a\u53d1\u5c55\u7684\u65b9\u5411\u548c\u7279\u5f81\u7b49\uff0c\u5e76\u6ca1\u6709\u505a\u5177\u4f53\u7ec6\u8282\u63cf\u7ed8\uff0c\u800c\u628a\u5177\u4f53\u60c5\u5f62\u7559\u7ed9\u540e\u6765\u7684\u5b9e\u8df5\u53bb\u56de\u7b54\u3002\u6240\u4ee5\uff0c\u6b63\u786e\u7b54\u6848\u4e3aD\u3002</p>\\n\",\"options\":[\"<p>\u63ed\u793a\u4e86\u793e\u4f1a\u5386\u53f2\u53d1\u5c55\u7684\u5404\u9879\u63aa\u65bd\u3001\u65b9\u5f0f\u3001\u65b9\u6cd5</p>\\n\",\"<p>\u8ba4\u4e3a\u4e0d\u5b58\u5728\u9002\u7528\u4e8e\u5404\u79cd\u793e\u4f1a\u5f62\u6001\u53d1\u5c55\u7684\u666e\u904d\u89c4\u5f8b</p>\\n\",\"<p>\u6ca1\u6709\u63d0\u51fa\u672a\u6765\u793e\u4f1a\u53d1\u5c55\u7684\u65b9\u5411\u3001\u539f\u5219\u548c\u57fa\u672c\u7279\u5f81</p>\\n\",\"<p>\u4e0d\u5bf9\u5386\u53f2\u53d1\u5c55\u7684\u5404\u79cd\u7ec6\u8282\u4f5c\u5177\u4f53\u63cf\u7ed8</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":2,\"studCount\":6678,\"rightCount\":5019,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":6,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38728,\"type\":\"1\",\"stem\":\"<p>\u968f\u7740\u6211\u56fd\u751f\u4ea7\u8d44\u6599\u79c1\u6709\u5236\u793e\u4f1a\u4e3b\u4e49\u6539\u9020\u7684\u57fa\u672c\u5b8c\u6210\uff0c\u56fd\u5185\u7684\u793e\u4f1a\u77db\u76fe\u548c\u9636\u7ea7\u5173\u7cfb\u53d1\u751f\u91cd\u5927\u53d8\u5316\u3002\u5728\u6b64\u80cc\u666f\u4e0b\uff0c\u6bdb\u6cfd\u4e1c\u57281957\u5e742\u6708\u4f5c\u300a\u5173\u4e8e\u6b63\u786e\u5904\u7406\u4eba\u6c11\u5185\u90e8\u77db\u76fe\u7684\