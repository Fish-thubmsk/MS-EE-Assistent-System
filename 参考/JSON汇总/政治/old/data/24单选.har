55\u6c38\u65e0\u6b62\u5883\uff0c\u89e3\u653e\u601d\u60f3\u6c38\u65e0\u6b62\u5883\uff0c\u6539\u9769\u5f00\u653e\u4e5f\u6c38\u65e0\u6b62\u5883\uff0c\u6539\u9769\u5f00\u653e\u53ea\u6709\u8fdb\u884c\u65f6\u3001\u6ca1\u6709\u5b8c\u6210\u65f6\u3002&quot;\u65b0\u65f6\u4ee3\u575a\u6301\u548c\u53d1\u5c55\u4e2d\u56fd\u7279\u8272\u793e\u4f1a\u4e3b\u4e49\uff0c\u6839\u672c\u52a8\u529b\u4ecd\u7136\u662f\u5168\u9762\u6df1\u5316\u6539\u9769\u5f00\u653e\u3002\u6539\u9769\u5f00\u653e\u7684\u9c9c\u660e\u7279\u5f81\u548c\u9996\u8981\u4efb\u52a1\u662f(\u2003\u2003)</p>\\n\",\"answer\":[0],\"analysis\":\"<p>\u6539\u9769\u5f00\u653e45\u5e74\uff0c\u6211\u56fd\u53d6\u5f97\u4e86\u4e3e\u4e16\u77a9\u76ee\u7684\u6210\u5c31\uff0c\u79ef\u7d2f\u4e86\u5b9d\u8d35\u7ecf\u9a8c\u3002\u5176\u4e2d\uff0c\u575a\u6301\u628a\u89e3\u653e\u548c\u53d1\u5c55\u751f\u4ea7\u529b\u4f5c\u4e3a\u9996\u8981\u4efb\u52a1\uff0c\u662f\u6700\u91cd\u8981\u7684\u7ecf\u9a8c\u4e4b\u4e00\uff0c\u6210\u4e3a\u6211\u56fd\u6539\u9769\u5f00\u653e\u7684\u9c9c\u660e\u7279\u5f81\u3002\u6240\u4ee5\uff0c\u6b63\u786e\u7b54\u6848\u4e3aA\u3002</p>\\n\",\"options\":[\"<p>\u89e3\u653e\u548c\u53d1\u5c55\u793e\u4f1a\u751f\u4ea7\u529b</p>\\n\",\"<p>\u5f62\u6210\u66f4\u52a0\u6210\u719f\u66f4\u52a0\u5b9a\u578b\u7684\u5236\u5ea6</p>\\n\",\"<p>\u5904\u7406\u597d\u653f\u5e9c\u548c\u5e02\u573a\u7684\u5173\u7cfb</p>\\n\",\"<p>\u4fc3\u8fdb\u793e\u4f1a\u516c\u5e73\u6b63\u4e49\u3001\u589e\u8fdb\u4eba\u6c11\u798f\u7949</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":6442,\"rightCount\":5900,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":1,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38730,\"type\":\"1\",\"stem\":\"<p>\u793e\u4f1a\u6cbb\u7406\u662f\u56fd\u5bb6\u6cbb\u7406\u7684\u91cd\u8981\u9886\u57df\uff0c\u5173\u7cfb\u56fd\u5bb6\u957f\u6cbb\u4e45\u5b89\u3001\u793e\u4f1a\u5b89\u5b9a\u6709\u5e8f\u3001\u4eba\u6c11\u5b89\u5c45\u4e50\u4e1a\u3002\u4e8c\u5341\u4e16\u7eaa60\u5e74\u4ee3\u6d59\u6c5f\u67ab\u6865\u5e72\u90e8\u7fa4\u4f17\u521b\u9020\u4e86\u4f9d\u9760\u7fa4\u4f17\u5c31\u5730\u5316\u89e3\u77db\u76fe\u7684&quot;\u67ab\u6865\u7ecf\u9a8c&quot;\u3002\u4eca\u5e74\u662f\u6bdb\u6cfd\u4e1c\u540c\u5fd7\u6279\u793a\u5b66\u4e60\u63a8\u5e7f&quot;\u67ab\u6865\u7ecf\u9a8c&quot;60\u5468\u5e74\uff0c\u4e5f\u662f\u4e60\u8fd1\u5e73\u603b\u4e66\u8bb0\u6307\u793a\u575a\u6301\u548c\u53d1\u5c55&quot;\u67ab\u6865\u7ecf\u9a8c&quot;20\u5468\u5e74\u300211\u67086\u65e5\uff0c\u4e60\u8fd1\u5e73\u603b\u4e66\u8bb0\u5728\u4f1a\u89c1\u5168\u56fd&quot;\u67ab\u6865\u5f0f\u5de5\u4f5c\u6cd5&quot;\u5165\u9009\u5355\u4f4d\u4ee3\u8868\u65f6\uff0c\u518d\u6b21\u5f3a\u8c03\u8981\u575a\u6301\u548c\u53d1\u5c55\u597d\u65b0\u65f6\u4ee3&quot;\u67ab\u6865\u7ecf\u9a8c&quot;\u3002\u65b0\u65f6\u4ee3&quot;\u67ab\u6865\u7ecf\u9a8c&quot;\u6700\u7a81\u51fa\u7684\u7279\u70b9\u662f(\u2003\u2003)</p>\\n\",\"answer\":[1],\"analysis\":\"<p>&quot;\u67ab\u6865\u7ecf\u9a8c&quot;\u662f\u6211\u4eec\u5728\u5b9e\u8df5\u4e2d\u83b7\u53d6\u7684\u57fa\u5c42\u6cbb\u7406\u7ecf\u9a8c\u3002\u6240\u4ee5\u65b0\u65f6\u4ee3&quot;\u67ab\u6865\u7ecf\u9a8c&quot;\\n\u6700\u7a81\u51fa\u7684\u7279\u70b9\uff0c\u5c31\u662f\u7262\u7262\u6293\u4f4f\u57fa\u5c42\u57fa\u7840\uff0c\u6700\u5927\u9650\u5ea6\u628a\u77db\u76fe\u98ce\u9669\u9632\u8303\u5316\u89e3\u5728\u57fa\u5c42\u3002\u6240\u4ee5\uff0c\u6b63\u786e\u7b54\u6848\u4e3a\\nB\u3002</p>\\n\",\"options\":[\"<p>\u52a0\u5f3a\u793e\u4f1a\u6cbb\u7406\u7684\u9876\u5c42\u8bbe\u8ba1</p>\\n\",\"<p>\u6700\u5927\u9650\u5ea6\u628a\u77db\u76fe\u98ce\u9669\u9632\u8303\u5316\u89e3\u5728\u57fa\u5c42</p>\\n\",\"<p>\u628a\u4eba\u6587\u5173\u6000\u548c\u5fc3\u7406\u758f\u5bfc\u6709\u673a\u7ed3\u5408\u8d77\u6765</p>\\n\",\"<p>\u6709\u6548\u53d1\u6325\u653f\u5e9c\u7684\u4e3b\u5bfc\u4f5c\u7528</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":4,\"studCount\":6343,\"rightCount\":5019,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":6,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38731,\"type\":\"1\",\"stem\":\"<p>\u6211\u56fd\u662f\u4e00\u4e2a\u6709\u5341\u56db\u4ebf\u591a\u4eba\u53e3\u7684\u5927\u56fd\uff0c\u65e0\u8bba\u793e\u4f1a\u73b0\u4ee3\u5316\u7a0b\u5ea6\u6709\u591a\u9ad8\uff0c\u89e3\u51b3\u597d\u5403\u996d\u95ee\u9898\uff0c\u59cb\u7ec8\u662f\u6cbb\u56fd\u7406\u653f\u7684\u5934\u7b49\u5927\u4e8b\u3002\u4fdd\u969c\u6211\u56fd\u7cae\u98df\u5b89\u5168\u7684\u5173\u952e\u5728\u4e8e(\u2003\u2003)</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u4e60\u8fd1\u5e73\u603b\u4e66\u8bb0\u5f3a\u8c03\uff0c\u4fdd\u969c\u7cae\u98df\u5b89\u5168\uff0c\u6839\u672c\u5728\u8015\u5730\uff0c\u51fa\u8def\u5728\u79d1\u6280\uff0c\u5173\u952e\u8981\u843d\u5b9e\u85cf\u7cae\u4e8e\u5730\u3001\u85cf\u7cae\u4e8e\u6280\u6218\u7565\u3002\u85cf\u7cae\u4e8e\u5730\u7684\u6838\u5fc3\u662f\u8015\u5730\uff0c\u5c31\u662f\u8981\u5b9e\u884c\u6700\u4e25\u683c\u7684\u8015\u5730\u4fdd\u62a4\u5236\u5ea6\u3002\u6240\u4ee5\uff0c\u6b63\u786e\u7b54\u6848\u4e3aC\u3002</p>\\n\",\"options\":[\"<p>\u5065\u5168\u79cd\u7cae\u519c\u6c11\u6536\u76ca\u4fdd\u969c\u673a\u5236</p>\\n\",\"<p>\u63a8\u8fdb\u519c\u4e1a\u4f9b\u7ed9\u4fa7\u7ed3\u6784\u6027\u6539\u9769</p>\\n\",\"<p>\u843d\u5b9e\u85cf\u7cae\u4e8e\u5730\u3001\u85cf\u7cae\u4e8e\u6280\u6218\u7565</p>\\n\",\"<p>\u5b8c\u5584\u4e3b\u4ea7\u533a\u5229\u76ca\u8865\u507f\u5236\u5ea6</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":5,\"studCount\":6443,\"rightCount\":3448,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":10,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38732,\"type\":\"1\",\"stem\":\"<p>\u4e2d\u56fd\u662f\u5168\u56fd\u5404\u65cf\u4eba\u6c11\u5171\u540c\u7f14\u9020\u7684\u7edf\u4e00\u7684\u591a\u6c11\u65cf\u56fd\u5bb6\u3002\u4e2d\u56fd\u4e0a\u4e0b\u4e94\u5343\u5e74\u7684\u5386\u53f2\uff0c\u5c31\u662f\u4e00\u4e2a\u7edf\u4e00\u7684\u591a\u6c11\u65cf\u56fd\u5bb6\u5f62\u6210\u548c\u4e0d\u65ad\u53d1\u5c55\u7684\u5386\u53f2\u3002\u5bf9\u4e2d\u534e\u6c11\u65cf\u5f62\u6210\u8d77\u51b3\u5b9a\u4f5c\u7528\u7684\u662f(\u2003\u2003)</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u5bf9\u4e2d\u534e\u6c11\u65cf\u5f62\u6210\u8d77\u51b3\u5b9a\u4f5c\u7528\u7684\u662f\u5bf9\u4e2d\u534e\u6c11\u65cf\u5171\u540c\u4f53\u7684\u8ba4\u540c\u3002\u4e2d\u56fd\u662f\u4e00\u4e2a\u5386\u53f2\u60a0\u4e45\u7684\u7edf\u4e00\u7684\u591a\u6c11\u65cf\u56fd\u5bb6\uff0c\u5404\u6c11\u65cf\u8840\u8109\u76f8\u8fde\uff0c\u6587\u8109\u76f8\u901a\uff0c\u5171\u540c\u7f14\u9020\u4e86\u4f1f\u5927\u7684\u4e2d\u534e\u6c11\u65cf\uff0c\u5f62\u6210\u4e86\u4e2d\u534e\u6c11\u65cf\u591a\u5143\u4e00\u4f53\u7684\u683c\u5c40\u3002\u6240\u4ee5\uff0c\u6b63\u786e\u7b54\u6848\u4e3aB\u3002</p>\\n\",\"options\":[\"<p>\u5bf9\u79cd\u65cf\u548c\u8840\u7f18\u7684\u8ba4\u540c</p>\\n\",\"<p>\u5bf9\u4e2d\u534e\u6c11\u65cf\u5171\u540c\u4f53\u7684\u8ba4\u540c</p>\\n\",\"<p>\u5bf9\u5b97\u6559\u4fe1\u4ef0\u7684\u8ba4\u540c</p>\\n\",\"<p>\u5bf9\u5171\u540c\u751f\u6d3b\u5730\u57df\u7684\u8ba4\u540c</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":7,\"studCount\":6219,\"rightCount\":5751,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":6,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38733,\"type\":\"1\",\"stem\":\"<p>\u9e26\u7247\u6218\u4e89\u524d\u7684\u4e2d\u56fd\u793e\u4f1a\u662f\u5c01\u5efa\u793e\u4f1a\u3002\u9e26\u7247\u6218\u4e89\u4ee5\u540e\uff0c\u72ec\u7acb\u7684\u4e2d\u56fd\u9010\u6b65\u53d8\u6210\u534a\u6b96\u6c11\u5730\u7684\u4e2d\u56fd\uff0c\u5c01\u5efa\u7684\u4e2d\u56fd\u9010\u6b65\u53d8\u6210\u534a\u5c01\u5efa\u7684\u4e2d\u56fd\u3002\u6240\u8c13&quot;\u534a\u5c01\u5efa&quot;\u662f\u6307(\u2003\u2003)</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u9009\u9879A\u7684\u8868\u8ff0\u663e\u7136\u662f\u9519\u8bef\u7684\u3002C\u9009\u9879\u662f&quot;\u534a\u6b96\u6c11\u5730&quot;\u7684\u539f\u56e0\u4e4b\u4e00\uff0c\u800c\u672c\u9898\u95ee\u7684\u662f\\n&quot;\u534a\u5c01\u5efa&quot;\uff0c\u56e0\u6b64\u4e5f\u6392\u9664\u3002D\u9009\u9879\u7684\u8868\u8ff0\u4e5f\u662f\u9519\u8bef\u7684\uff0c\u5c01\u5efa\u5265\u524a\u5236\u5ea6\u7684\u6839\u57fa\u662f\u5730\u4e3b\u571f\u5730\u6240\u6709\u5236\uff0c\u5728\u8fd1\u4ee3\u4e2d\u56fd\uff0c\u5c01\u5efa\u5730\u4e3b\u571f\u5730\u6240\u6709\u5236\u5e76\u6ca1\u6709\u5f7b\u5e95\u52a8\u6447\u3002\u53ea\u6709B\u9009\u9879\u662f\u6b63\u786e\u7684\u3002\u6b63\u56e0\u4e3a\u8fd1\u4ee3\u4e2d\u56fd\u51fa\u73b0\u4e86\u4e0d\u53ef\u5ffd\u7565\u7684\u8d44\u672c\u4e3b\u4e49\u751f\u4ea7\u5173\u7cfb\uff0c\u6240\u4ee5\u624d\u4e0d\u518d\u662f\u4e00\u4e2a\u5b8c\u5168\u7684\u5c01\u5efa\u793e\u4f1a\uff0c\u800c\u662f\u4e00\u4e2a&quot;\u534a\u5c01\u5efa&quot;\u793e\u4f1a\u3002</p>\\n\",\"options\":[\"<p>\u5c01\u5efa\u7ecf\u6d4e\u5360\u6574\u4e2a\u7ecf\u6d4e\u7684\u4e00\u534a</p>\\n\",\"<p>\u4e2d\u56fd\u51fa\u73b0\u4e86\u8d44\u672c\u4e3b\u4e49\u751f\u4ea7\u5173\u7cfb</p>\\n\",\"<p>\u4e2d\u56fd\u4e27\u5931\u5b8c\u5168\u72ec\u7acb\u7684\u5730\u4f4d</p>\\n\",\"<p>\u5c01\u5efa\u5265\u524a\u5236\u5ea6\u7684\u6839\u57fa\u5f7b\u5e95\u52a8\u6447</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":1,\"studCount\":6346,\"rightCount\":4283,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":10,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38734,\"type\":\"1\",\"stem\":\"<p>\u5b59\u4e2d\u5c71\u5148\u751f\u662f\u4f1f\u5927\u7684\u6c11\u65cf\u82f1\u96c4\u3001\u4f1f\u5927\u7684\u7231\u56fd\u4e3b\u4e49\u8005\u3001\u4e2d\u56fd\u6c11\u4e3b\u9769\u547d\u7684\u4f1f\u5927\u5148\u9a71\u30021894\u5e7411\u6708\uff0c\u5728\u6a80\u9999\u5c71\u53ec\u5f00\u7684\u5174\u4e2d\u4f1a\u6210\u7acb\u5927\u4f1a\u901a\u8fc7\u4e86\u7531\u5b59\u4e2d\u5c71\u8d77\u8349\u7684\u300a\u5174\u4e2d\u4f1a\u7ae0\u7a0b\u300b\u3002\u5728\u7ae0\u7a0b\u4e2d\uff0c\u5b59\u4e2d\u5c71\u63d0\u51fa\u4e86(\u2003\u2003)</p>\",\"answer\":[0],\"analysis\":\"<p>\u672c\u9898\u8003\u67e5\u7684\u53f2\u7eb2\u7b2c\u4e00\u7ae0\u7684\u77e5\u8bc6\u70b9\u3002\u5b59\u4e2d\u5c711894\u5e7411\u6708\u5728\u521b\u7acb\u9769\u547d\u56e2\u4f53\u5174\u4e2d\u4f1a\u65f6\uff0c\u4ed6\u558a\u51fa\u4e86&quot;\u632f\u5174\u4e2d\u534e&quot;\u8fd9\u4e2a\u65f6\u4ee3\u7684\u6700\u5f3a\u97f3\u3002\u867d\u7136\u6ca1\u6709\u660e\u786e\u63d0\u5230\u300a\u5174\u4e2d\u4f1a\u7ae0\u7a0b\u300b\uff0c\u4f46\u7ed3\u5408\u8be5\u77e5\u8bc6\u70b9\uff0c\u4ee5\u53ca\u672c\u9898\u9898\u5e72\u4e2d\u6240\u63d0\u5230\u7684\u65f6\u95f4\uff0c\u53ef\u4ee5\u63a8\u65ad\u51faA\u9009\u9879\u662f\u6b63\u786e\u7684\u3002</p>\",\"options\":[\"<p>&quot;\u632f\u5174\u4e2d\u534e&quot;\u7684\u53e3\u53f7</p>\",\"<p>&quot;\u5efa\u7acb\u6c11\u56fd&quot;\u7684\u53e3\u53f7</p>\",\"<p>&quot;\u53cd\u5e1d\u53cd\u5c01&quot;\u7684\u53e3\u53f7</p>\",\"<p>&quot;\u6c11\u4e3b\u81ea\u7531&quot;\u7684\u53e3\u53f7</p>\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":0,\"studCount\":6196,\"rightCount\":5624,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":7,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38735,\"type\":\"1\",\"stem\":\"<p>1937\u5e747\u67087\u65e5\uff0c\u65e5\u672c\u5e1d\u56fd\u4e3b\u4e49\u53d1\u52a8\u4e86\u5362\u6c9f\u6865\u4e8b\u53d8\uff0c\u4f01\u56fe\u4ee5\u6b66\u529b\u541e\u5e76\u5168\u4e2d\u56fd\u3002\u5362\u6c9f\u6865\u4e8b\u53d8\u7684\u53d1\u751f(\u2003\u2003)</p>\\n\",\"answer\":[2],\"analysis\":\"<p>\u672c\u9898\u96be\u5ea6\u4e0d\u5927\u3002A\u548cB\u9009\u9879\u5bf9\u5e94\u7684\u5386\u53f2\u4e8b\u4ef6\u5e94\u4e3a&quot;\u4e5d\u4e00\u516b\u4e8b\u53d8&quot;\u3002D\u9009\u9879\u6807\u5fd7\u7740\u4e16\u754c\u53cd\u6cd5\u897f\u65af\u540c\u76df\u6b63\u5f0f\u5efa\u7acb\u7684\uff0c\u662f1942\u5e741\u67081\u65e5\uff0c\u82f1\u7f8e\u82cf\u4e2d\u7b4926\u4e2a\u56fd\u5bb6\u5728\u534e\u76db\u987f\u4e3e\u884c\u4f1a\u8bae\uff0c\u7b7e\u7f72\u4e86\u300a\u8054\u5408\u56fd\u5bb6\u5ba3\u8a00\u300b\u3002\u6545\u53ea\u6709C\u9009\u9879\u662f\u6b63\u786e\u7684\u3002</p>\\n\",\"options\":[\"<p>\u63ed\u5f00\u4e86\u6297\u65e5\u6218\u4e89\u7684\u5e8f\u5e55</p>\\n\",\"<p>\u6210\u4e3a\u4e2d\u56fd\u4eba\u6c11\u6297\u65e5\u6218\u4e89\u7684\u8d77\u70b9</p>\\n\",\"<p>\u6807\u5fd7\u7740\u4e2d\u56fd\u8fdb\u5165\u5168\u6c11\u65cf\u6297\u6218\u9636\u6bb5</p>\\n\",\"<p>\u6807\u5fd7\u7740\u4e16\u754c\u53cd\u6cd5\u897f\u65af\u540c\u76df\u7684\u6b63\u5f0f\u5efa\u7acb</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"categoryId\":0,\"containCount\":0,\"noteCounts\":8,\"studCount\":6261,\"rightCount\":4352,\"meanScoreRate\":0,\"qBankId\":5,\"chapterId\":4925,\"mediaId\":0,\"oldMediaId\":0,\"mediaTable\":\"old\",\"stemMediaId\":0,\"baseId\":0,\"kindId\":0,\"seq\":0,\"postNum\":14,\"pType\":\"1\",\"isHaveAnalysisText\":1,\"isExistTextAnalysis\":1,\"isHaveAnalysisVideo\":1,\"isExistVideoAnalysis\":0,\"isDid\":-1,\"isfavorite\":-1,\"stemMedia\":{\"mediaType\":\"\",\"mediaUri\":\"\",\"mediaTime\":\"\",\"videoPictureUri\":\"\",\"definition\":{},\"formatStream\":[]},\"analysisVideoThumb\":\"\",\"qNo\":null},{\"id\":38736,\"type\":\"1\",\"stem\":\"<p>1948\u5e74\uff0c\u89e3\u653e\u6218\u4e89\u5f62\u52bf\u5df2\u7ecf\u6709\u4e86\u6781\u5927\u7684\u8fdb\u5c55\uff0c\u8bb8\u591a\u89e3\u653e\u533a\u5df2\u7ecf\u8fde\u6210\u4e00\u7247\uff0c\u8bb8\u591a\u57ce\u5e02\u5df2\u7ecf\u89e3\u653e\u6216\u8005\u5373\u5c06\u89e3\u653e\uff0c\u4eba\u6c11\u89e3\u653e\u519b\u548c\u4eba\u6c11\u89e3\u653e\u6218\u4e89\u7684\u6b63\u89c4\u6027\u7a0b\u5ea6\u5927\u4e3a\u63d0\u9ad8\uff0c\u5168\u56fd\u80dc\u5229\u5df2\u7ecf\u5728\u671b\u3002\u8fd9\u79cd\u60c5\u51b5\u8981\u6c42\u515a\u8fc5\u901f\u514b\u670d\u5b58\u5728\u4e8e\u515a\u5185\u548c\u519b\u961f\u5185\u7684\u4efb\u4f55\u65e0\u7eaa\u5f8b\u65e0\u653f\u5e9c\u72b6\u6001\uff0c\u628a\u4e00\u5207\u5fc5\u987b\u548c\u53ef\u80fd\u96c6\u4e2d\u7684\u6743\u529b\u96c6\u4e2d\u4e8e\u4e2d\u592e\u3002\u4e3a\u6b64\uff0c\u4e2d\u5171\u4e2d\u592e\u51b3\u5b9a\u5efa\u7acb(\u2003\u2003)</p>\\n\",\"answer\":[1],\"analysis\":\"<p>\u672c\u9898\u5c5e\u4e8e\u8d85\u7eb2\u9898\u3002\u4f46\u901a\u8fc7\u7406\u89e3\u9898\u5e72\uff0c\u53ef\u4ee5\u63a8\u51fa\u7b54\u6848\u3002\u9898\u5e72\u4e2d\u95ee\uff0c\u4e3a\u4e86\u96c6\u4e2d\u4e2d\u592e\u7684\u6743\u529b\uff0c\u4e2d\u5171\u4e2d\u592e\u5efa\u7acb\u4e86\u4ec0\u4e48\u5236\u5ea6\u3002\u9009\u9879\u4e2d\u7684\u56db\u4e2a\u5236\u5ea6\uff0c\u53ea\u6709&quot;\u8bf7\u793a\u62a5\u544a\u5236\u5ea6&quot;\u662f\u7528\u6765\u96c6\u4e2d\u6743\u529b\u7684\u3002\u53e6\u5916\u4e09\u4e2a\u5236\u5ea6\uff0c\u90fd\u4e0e\u96c6\u4e2d\u6743\u529b\u65e0\u5173\u3002\u6545\u672c\u9898\u5e94\u9009B\u3002\u672c\u9898\u51fa\u81ea\u6bdb\u6cfd\u4e1c\u5199\u4e8e1948\u5e741\u6708\u7684\u300a\u5173\u4e8e\u5efa\u7acb\u62a5\u544a\u5236\u5ea6\u300b\u3002\u8be5\u6587\u5c5e\u4e8e\u8d85\u7eb2\u5185\u5bb9\uff0c\u4f46\u7531\u4e8e\u4eca\u5e74\u662f\u6bdb\u6cfd\u4e1c\u8bde\u8fb0130\u5468\u5e74\uff0c\u6240\u4ee5\u547d\u5236\u672c\u9898\u3002</p>\\n\",\"options\":[\"<p>\u7cbe\u5175\u7b80\u653f\u5236\u5ea6</p>\\n\",\"<p>\u8bf7\u793a\u62a5\u544a\u5236\u5ea6</p>\\n\",\"<p>\u6c11\u4e3b\u534f\u5546\u5236\u5ea6</p>\\n\",\"<p>\u515a\u5916\u901a\u62a5\u5236\u5ea6</p>\\n\"],\"difficulty\":2,\"parentId\":0,\"subCount\":0,\"nature\":3,\"score\":1,\"kind\":\"\",\"source\":\"\",\"cat