# 考研智能辅导系统 — 环境变量配置示例
# 复制本文件为 .env 并填写对应值：
#   cp .env.example .env

# ---------------------------------------------------------------------------
# SiliconFlow / LLM API
# ---------------------------------------------------------------------------
# SiliconFlow API Key（从 https://siliconflow.cn 获取）
SILICONFLOW_API_KEY=

# LLM 模型名称（必填，推荐 DeepSeek-V3；未配置将导致启动报错）
# 可选示例：deepseek-ai/DeepSeek-V3 / Qwen/Qwen2.5-72B-Instruct
LLM_MODEL=deepseek-ai/DeepSeek-V3

# LLM API 基础 URL（兼容 OpenAI Chat Completions 格式）
LLM_BASE_URL=https://api.siliconflow.cn/v1

# LLM 采样温度（0.0–1.0）
LLM_TEMPERATURE=0.3

# LLM 最大生成 token 数
LLM_MAX_TOKENS=2048

# LLM API 超时秒数
LLM_TIMEOUT=60

# ---------------------------------------------------------------------------
# SiliconFlow 速率限制 & 重试
# ---------------------------------------------------------------------------
# 每次请求前的基础延迟（秒），用于控制请求速率（RPM = 60 / 延迟）
SF_REQUEST_DELAY_SECONDS=1.0

# 遇到 429 或超时时的最大重试次数（指数退避）
SF_MAX_RETRIES=3

# 每次 API 请求的超时时间（秒）
SF_API_TIMEOUT=30

# ---------------------------------------------------------------------------
# Embedding
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# SiliconFlow Embedding API 完整 URL（含 /embeddings 路径）
# 若只想改主机/端口可改上面的 EMBEDDING_BASE_URL；若要完全自定义 URL 则用此项
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/embeddings

# Embedding 向量维度（bge-m3 = 1024；切换模型时需同步修改）
EMBEDDING_DIM=1024

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------
CHROMA_PERSIST_DIRECTORY=chroma_userdata
CHROMA_COLLECTION_NAME=user_notes

# ---------------------------------------------------------------------------
# FAISS
# ---------------------------------------------------------------------------
# Path to the FAISS vector index directory (relative to project root or absolute).
# Run `python knowledge_base/build_faiss_index.py` to generate these files.
FAISS_INDEX_DIR=knowledge_base/faiss_index

# Path to the SQLite knowledge base (relative to project root or absolute).
KNOWLEDGE_DB_PATH=datebase/knowledge_base.db

# ---------------------------------------------------------------------------
# 诊断 Agent
# ---------------------------------------------------------------------------
# 薄弱知识点判定阈值（准确率低于此值视为薄弱，范围 0.0–1.0，默认 0.6）
DIAGNOSIS_WEAK_THRESHOLD=0.6

# 每个薄弱知识点推荐题目数量（默认 3）
DIAGNOSIS_RECOMMEND_PER_POINT=3

# ---------------------------------------------------------------------------
# FastAPI / 服务
# ---------------------------------------------------------------------------
APP_TITLE=考研智能辅导系统 API
APP_VERSION=0.2.0

# CORS 允许来源（逗号分隔，生产环境请收紧）
# 示例：CORS_ORIGINS=["https://yourfrontend.com"]
CORS_ORIGINS=["*"]

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# JWT 认证
# ---------------------------------------------------------------------------
# JWT 签名密钥（生产环境必须替换为强随机字符串，例如：openssl rand -hex 32）
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_RANDOM_32_CHARS

# JWT 签名算法（HS256 为默认值）
# JWT_ALGORITHM=HS256

# JWT 有效期（分钟），默认 1440（24 小时）
# JWT_EXPIRE_MINUTES=1440
