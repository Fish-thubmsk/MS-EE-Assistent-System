# 考研智能辅导系统 — 环境变量配置示例
# 复制本文件为 .env 并填写对应值：
#   cp .env.example .env

# ---------------------------------------------------------------------------
# SiliconFlow / LLM API
# ---------------------------------------------------------------------------
# SiliconFlow API Key（从 https://siliconflow.cn 获取）
SILICONFLOW_API_KEY=

# LLM 模型名称（默认 DeepSeek-R1）
LLM_MODEL=deepseek-ai/DeepSeek-R1

# LLM API 基础 URL（兼容 OpenAI Chat Completions 格式）
LLM_BASE_URL=https://api.siliconflow.cn/v1

# LLM 采样温度（0.0–1.0）
LLM_TEMPERATURE=0.3

# LLM 最大生成 token 数
LLM_MAX_TOKENS=2048

# LLM API 超时秒数
LLM_TIMEOUT=60

# ---------------------------------------------------------------------------
# SiliconFlow 速率限制 & 重试
# ---------------------------------------------------------------------------
# 每次请求前的基础延迟（秒），用于控制请求速率（RPM = 60 / 延迟）
SF_REQUEST_DELAY_SECONDS=1.0

# 遇到 429 或超时时的最大重试次数（指数退避）
SF_MAX_RETRIES=3

# 每次 API 请求的超时时间（秒）
SF_API_TIMEOUT=30

# ---------------------------------------------------------------------------
# Embedding
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------
CHROMA_PERSIST_DIRECTORY=chroma_userdata
CHROMA_COLLECTION_NAME=notes

# ---------------------------------------------------------------------------
# FAISS
# ---------------------------------------------------------------------------
FAISS_INDEX_DIR=knowledge_base/faiss_index

# ---------------------------------------------------------------------------
# FastAPI / 服务
# ---------------------------------------------------------------------------
APP_TITLE=考研智能辅导系统 API
APP_VERSION=0.2.0

# CORS 允许来源（逗号分隔，生产环境请收紧）
# 示例：CORS_ORIGINS=["https://yourfrontend.com"]
CORS_ORIGINS=["*"]

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
